# ============================================================
# Aureon API Local — Configuração de Ambiente
# ESTE ARQUIVO É UM EXEMPLO — NÃO VERSIONAR O .env REAL
# Copie este arquivo para .env e preencha com seus valores
# ============================================================

# Porta da API Local (padrão: 7070)
AUREON_API_PORTA=7070

# Ambiente (desenvolvimento | producao)
AUREON_AMBIENTE=desenvolvimento

# Conexão PostgreSQL (NUNCA commitar com senha real)
# Formato: postgres://usuario:senha@host:porta/banco
DATABASE_URL=postgres://aureon:SENHA_AQUI@localhost:5432/aureon_db

# Diretório de dados (opcional — padrão: junto ao executável)
# AUREON_DADOS_DIR=C:/Aureon/data
