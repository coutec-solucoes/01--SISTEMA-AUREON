@using AureonPdvUi.Services
@inject TauriService Tauri

<div class="producao-container">
    <div class="card" style="margin-bottom: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h3 style="margin: 0;">Histórico de Produção (Últimos 50 envios)</h3>
            <button class="btn btn-primario" @onclick="CarregarEnvios" disabled="@Processando">Atualizar</button>
        </div>
    </div>

    @if (Carregando)
    {
        <div style="text-align: center; color: var(--cor-texto-sub); padding: 40px;">Carregando histórico...</div>
    }
    else if (Envios.Count == 0)
    {
        <div style="text-align: center; color: var(--cor-texto-sub); padding: 40px; background: rgba(0,0,0,0.2); border-radius: 8px;">
            Nenhum envio de produção registrado recentemente.
        </div>
    }
    else
    {
        <div class="producao-grid">
            <!-- LISTA ESQUERDA -->
            <div class="lista-envios card" style="flex: 1; overflow-y: auto; padding: 0;">
                @foreach (var envio in Envios)
                {
                    <div class="envio-item @(EnvioSelecionado?.Id == envio.Id ? "ativo" : "")" @onclick="() => SelecionarEnvio(envio)">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 4px;">
                            <span style="font-weight: 600;">@envio.OrigemTipo @envio.OrigemId.Substring(0,8)...</span>
                            <span style="font-size: 11px; color: var(--cor-texto-sub);">@envio.CriadoEm</span>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <span style="font-size: 13px; color: #ff9800;">Setor: @envio.SetorProducaoId</span>
                            <span class="status-badge status-@envio.Status.ToLower()">@envio.Status</span>
                        </div>
                    </div>
                }
            </div>

            <!-- DETALHE DIREITA -->
            <div class="detalhe-envio card" style="flex: 2; display: flex; flex-direction: column;">
                @if (EnvioSelecionado == null)
                {
                    <div style="text-align: center; color: var(--cor-texto-sub); margin: auto;">
                        Selecione um envio para visualizar os detalhes.
                    </div>
                }
                else
                {
                    <div style="display: flex; justify-content: space-between; margin-bottom: 16px;">
                        <h3 style="margin: 0;">Comprovante de Produção</h3>
                        <button class="btn btn-primario" @onclick="Reimprimir" disabled="@Processando">
                            REIMPRIMIR VIA
                        </button>
                    </div>

                    @if (ErroAcao != null)
                    {
                        <div style="color: #f44336; font-size: 13px; margin-bottom: 16px;">@ErroAcao</div>
                    }

                    @if (SucessoAcao != null)
                    {
                        <div style="color: #00e676; font-size: 13px; margin-bottom: 16px;">@SucessoAcao</div>
                    }

                    <div class="comprovante-txt" style="flex-grow: 1; overflow-y: auto; background: #1e1e1e; padding: 16px; border-radius: 4px; font-family: monospace; font-size: 13px; white-space: pre-wrap; color: #fff;">@TextoComprovante</div>
                }
            </div>
        </div>
    }
</div>

<style>
    .producao-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        padding-bottom: 24px;
    }
    .producao-grid {
        display: flex;
        gap: 24px;
        flex-grow: 1;
        min-height: 0;
    }
    .envio-item {
        padding: 16px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        cursor: pointer;
        transition: background 0.2s;
    }
    .envio-item:hover {
        background: rgba(255,255,255,0.05);
    }
    .envio-item.ativo {
        background: rgba(255,152,0,0.1);
        border-left: 4px solid #ff9800;
    }
    .status-badge {
        font-size: 10px;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: 600;
        background: rgba(255,255,255,0.1);
    }
    .status-enviado_producao { background: rgba(0,230,118,0.2); color: #00e676; }
    .status-preparado { background: rgba(33,150,243,0.2); color: #2196f3; }
</style>

@code {
    private bool Carregando = true;
    private bool Processando = false;
    private List<ProducaoEnvioResp> Envios = new();

    private ProducaoEnvioResp? EnvioSelecionado;
    private string TextoComprovante = "Carregando comprovante...";
    private string? ErroAcao;
    private string? SucessoAcao;

    protected override async Task OnInitializedAsync()
    {
        await CarregarEnvios();
    }

    private async Task CarregarEnvios()
    {
        Carregando = true;
        EnvioSelecionado = null;
        ErroAcao = null;
        SucessoAcao = null;

        var res = await Tauri.InvocarAsync<RespostaBase<List<ProducaoEnvioResp>>>("listar_todos_envios_producao");
        if (res?.Sucesso == true && res.Dados != null)
        {
            Envios = res.Dados;
        }

        Carregando = false;
    }

    private async Task SelecionarEnvio(ProducaoEnvioResp envio)
    {
        EnvioSelecionado = envio;
        ErroAcao = null;
        SucessoAcao = null;
        TextoComprovante = "Carregando texto de impressão...";

        var res = await Tauri.InvocarAsync<RespostaBase<string>>("gerar_texto_producao", new { envio_id = envio.Id });
        if (res?.Sucesso == true && res.Dados != null)
        {
            TextoComprovante = res.Dados;
        }
        else
        {
            TextoComprovante = "Erro ao gerar texto. " + (res?.Mensagem ?? "");
        }
    }

    private async Task Reimprimir()
    {
        if (EnvioSelecionado == null) return;
        Processando = true;
        ErroAcao = null;
        SucessoAcao = null;

        var res = await Tauri.InvocarAsync<RespostaBase<string>>("reimprimir_envio_producao", new { 
            envio_id = EnvioSelecionado.Id,
            usuario_id = "USR-001" // fixo p/ teste
        });

        if (res?.Sucesso == true)
        {
            SucessoAcao = "Reimpressão enviada com sucesso para o KDS/Impressora!";
        }
        else
        {
            ErroAcao = res?.Mensagem ?? "Erro ao solicitar reimpressão.";
        }
        Processando = false;
    }
}
