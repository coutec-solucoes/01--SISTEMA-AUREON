    #endregion

    #region Lógica de Controle do Componente

    private string abaAtiva = "vendas";
    private bool carregando = true;
    private string? erro;
    private string periodoSelecionado = "30dias";

    private string? dataInicioEnviada;
    private string? dataFimEnviada;

    private DateTime dataInicioInput = DateTime.Today.AddDays(-30);
    private DateTime dataFimInput = DateTime.Today;

    // Filtros adicionais
    private string? usuarioIdFilter;
    private string? sessaoCaixaIdFilter;
    private string? moedaCodigoFilter;
    private string? formaPagamentoFilter;

    // Dados Carregados
    private RelatorioVendasResp? vendasResp;
    private RelatorioCaixaResp? caixasResp;
    private RelatorioEstoqueResp? estoqueResp;
    private RelatorioComprasResp? comprasResp;
    private RelatorioFinanceiroResp? financeiroResp;
    private RelatorioGourmetDeliveryResp? gourmetResp;
    private List<ProdutoMaisVendidoResp>? rankingResp;

    protected override async Task OnInitializedAsync()
    {
        CalcularDatasPeriodo();
        await GerarRelatorioSelecionado();
    }

    private void CalcularDatasPeriodo()
    {
        DateTime inicio, fim;
        switch (periodoSelecionado)
        {
            case "hoje":
                inicio = DateTime.Today;
                fim = DateTime.Today.AddHours(23).AddMinutes(59).AddSeconds(59);
                break;
            case "7dias":
                inicio = DateTime.Today.AddDays(-7);
                fim = DateTime.Today.AddHours(23).AddMinutes(59).AddSeconds(59);
                break;
            case "mes":
                inicio = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
                fim = DateTime.Today.AddHours(23).AddMinutes(59).AddSeconds(59);
                break;
            case "30dias":
            default:
                inicio = DateTime.Today.AddDays(-30);
                fim = DateTime.Today.AddHours(23).AddMinutes(59).AddSeconds(59);
                break;
        }

        dataInicioInput = inicio;
        dataFimInput = fim;

        dataInicioEnviada = inicio.ToString("yyyy-MM-dd HH:mm:ss");
        dataFimEnviada = fim.ToString("yyyy-MM-dd HH:mm:ss");
    }

    private void FiltroDataAlterado()
    {
        periodoSelecionado = "custom";
        dataInicioEnviada = dataInicioInput.ToString("yyyy-MM-dd 00:00:00");
        dataFimEnviada = dataFimInput.ToString("yyyy-MM-dd 23:59:59");
    }

    private async Task MudarPeriodo(string novoPeriodo)
    {
        periodoSelecionado = novoPeriodo;
        CalcularDatasPeriodo();
        await GerarRelatorioSelecionado();
    }

    private async Task MudarAba(string novaAba)
    {
        abaAtiva = novaAba;
        await GerarRelatorioSelecionado();
    }

    private async Task GerarRelatorioSelecionado()
    {
        carregando = true;
        erro = null;

        var filtros = new FiltrosRelatorio(
            data_inicio: dataInicioEnviada,
            data_fim: dataFimEnviada,
            usuario_id: usuarioIdFilter,
            sessao_caixa_id: sessaoCaixaIdFilter,
            moeda_codigo: moedaCodigoFilter,
            forma_pagamento: formaPagamentoFilter
        );

        try
        {
            switch (abaAtiva)
            {
                case "vendas":
                    var rVendas = await Tauri.InvocarAsync<RespostaBase<RelatorioVendasResp>>("gerar_relatorio_vendas", new { filtros });
                    if (rVendas != null && rVendas.Sucesso) vendasResp = rVendas.Dados;
                    else erro = rVendas?.Mensagem ?? "Erro ao carregar relatório de vendas.";
                    break;
                case "caixas":
                    var rCaixas = await Tauri.InvocarAsync<RespostaBase<RelatorioCaixaResp>>("gerar_relatorio_caixa", new { filtros });
                    if (rCaixas != null && rCaixas.Sucesso) caixasResp = rCaixas.Dados;
                    else erro = rCaixas?.Mensagem ?? "Erro ao carregar relatório de caixas.";
                    break;
                case "estoque":
                    var rEstoque = await Tauri.InvocarAsync<RespostaBase<RelatorioEstoqueResp>>("gerar_relatorio_estoque_kardex", new { filtros });
                    if (rEstoque != null && rEstoque.Sucesso) estoqueResp = rEstoque.Dados;
                    else erro = rEstoque?.Mensagem ?? "Erro ao carregar relatório de estoque.";
                    break;
                case "compras":
                    var rCompras = await Tauri.InvocarAsync<RespostaBase<RelatorioComprasResp>>("gerar_relatorio_compras", new { filtros });
                    if (rCompras != null && rCompras.Sucesso) comprasResp = rCompras.Dados;
                    else erro = rCompras?.Mensagem ?? "Erro ao carregar relatório de compras.";
                    break;
                case "financeiro":
                    var rFin = await Tauri.InvocarAsync<RespostaBase<RelatorioFinanceiroResp>>("gerar_relatorio_financeiro", new { filtros });
                    if (rFin != null && rFin.Sucesso) financeiroResp = rFin.Dados;
                    else erro = rFin?.Mensagem ?? "Erro ao carregar relatório financeiro.";
                    break;
                case "gourmet":
                    var rGourmet = await Tauri.InvocarAsync<RespostaBase<RelatorioGourmetDeliveryResp>>("gerar_relatorio_gourmet_delivery", new { filtros });
                    if (rGourmet != null && rGourmet.Sucesso) gourmetResp = rGourmet.Dados;
                    else erro = rGourmet?.Mensagem ?? "Erro ao carregar relatório gourmet/delivery.";
                    break;
                case "ranking":
                    var rRank = await Tauri.InvocarAsync<RespostaBase<List<ProdutoMaisVendidoResp>>>("gerar_relatorio_produtos_mais_vendidos", new { filtros });
                    if (rRank != null && rRank.Sucesso) rankingResp = rRank.Dados;
                    else erro = rRank?.Mensagem ?? "Erro ao carregar ranking de vendas.";
                    break;
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro na comunicação local: {ex.Message}";
        }
        finally
        {
            carregando = false;
        }
    }

    private bool PodeExportar()
    {
        return abaAtiva switch
        {
            "vendas" => vendasResp != null,
            "caixas" => caixasResp != null,
            "estoque" => estoqueResp != null,
            "compras" => comprasResp != null,
            "financeiro" => financeiroResp != null,
            "gourmet" => gourmetResp != null,
            "ranking" => rankingResp != null,
            _ => false
        };
    }

    private async Task ExportarCSV()
    {
        StringBuilder csv = new StringBuilder();
        string filename = $"relatorio_{abaAtiva}_{DateTime.Now:yyyyMMdd_HHmmss}.csv";

        try
        {
            switch (abaAtiva)
            {
                case "vendas":
                    if (vendasResp?.Vendas == null) return;
                    csv.AppendLine("ID;Numero;Data;Cliente;Usuario;Status;Total Bruto;Desconto;Acrescimo;Total Liquido");
                    foreach (var v in vendasResp.Vendas)
                    {
                        csv.AppendLine($"{v.Id};{v.NumeroVenda};{v.DataVenda};{v.ClienteNome};{v.UsuarioId};{v.Status};{v.TotalBrutoMinor};{v.DescontoTotalMinor};{v.AcrescimoTotalMinor};{v.TotalLiquidoMinor}");
                    }
                    break;
                case "caixas":
                    if (caixasResp?.Sessoes == null) return;
                    csv.AppendLine("ID;Abertura;Fechamento;Operador;Terminal;Status;Moeda;Vlr Abertura;Vlr Esperado;Vlr Informado;Diferenca");
                    foreach (var s in caixasResp.Sessoes)
                    {
                        csv.AppendLine($"{s.Id};{s.AbertoEm};{s.FechadoEm};{s.OperadorId};{s.TerminalId};{s.Status};{s.MoedaCodigo};{s.ValorAberturaMinor};{s.ValorFechamentoEsperadoMinor};{s.ValorFechamentoInformadoMinor};{s.DiferencaMinor}");
                    }
                    break;
                case "estoque":
                    if (estoqueResp == null) return;
                    csv.AppendLine("POSICAO FISICA ATUAL");
                    csv.AppendLine("Produto ID;Nome;SKU;Controla Estoque;Qtd;Custo Unitario");
                    foreach (var p in estoqueResp.PosicaoEstoque)
                    {
                        csv.AppendLine($"{p.ProdutoId};{p.ProdutoNome};{p.ProdutoSku};{p.ControlaEstoque};{p.QuantidadeEscala3};{p.UltimoCustoMinor}");
                    }
                    csv.AppendLine();
                    csv.AppendLine("KARDEX MOVIMENTACOES FILTRADAS");
                    csv.AppendLine("ID;Produto ID;Produto Nome;Data;Tipo;Qtd;Origem;Usuario;Obs");
                    foreach (var k in estoqueResp.ItensKardex)
                    {
                        csv.AppendLine($"{k.Id};{k.ProdutoId};{k.ProdutoNome};{k.DataMovimentacao};{k.TipoMovimentacao};{k.QuantidadeEscala3};{k.OrigemId};{k.UsuarioId};{k.Observacao}");
                    }
                    break;
                case "compras":
                    if (comprasResp?.Compras == null) return;
                    csv.AppendLine("ID;Fornecedor;Data;Status;Moeda;Total Original;Total BRL;Total Itens");
                    foreach (var c in comprasResp.Compras)
                    {
                        csv.AppendLine($"{c.Id};{c.FornecedorNome};{c.DataCompra};{c.Status};{c.MoedaCodigo};{c.TotalOriginalMinor};{c.TotalPrincipalBrlMinor};{c.TotalItensEscala3}");
                    }
                    break;
                case "financeiro":
                    if (financeiroResp == null) return;
                    csv.AppendLine("CONTAS A PAGAR");
                    csv.AppendLine("ID;Fornecedor;Vencimento;Status;Moeda;Valor Original;Valor Pendente");
                    foreach (var cp in financeiroResp.ContasPagar)
                    {
                        csv.AppendLine($"{cp.Id};{cp.FornecedorNomeSnapshot};{cp.DataVencimento};{cp.Status};{cp.MoedaCodigo};{cp.ValorOriginalMinor};{cp.SaldoPendenteMinor}");
                    }
                    csv.AppendLine();
                    csv.AppendLine("CONTAS A RECEBER");
                    csv.AppendLine("ID;Cliente;Vencimento;Status;Moeda;Valor Original;Valor Pendente");
                    foreach (var cr in financeiroResp.ContasReceber)
                    {
                        csv.AppendLine($"{cr.Id};{cr.ClienteNomeSnapshot};{cr.DataVencimento};{cr.Status};{cr.MoedaCodigo};{cr.ValorOriginalMinor};{cr.SaldoPendenteMinor}");
                    }
                    csv.AppendLine();
                    csv.AppendLine("LANCAMENTOS FINANCEIROS");
                    csv.AppendLine("ID;Data;Tipo;Forma;Moeda;Valor Original;Valor BRL;Operador;Obs");
                    foreach (var l in financeiroResp.Lancamentos)
                    {
                        csv.AppendLine($"{l.Id};{l.DataPagamento};{l.TipoLancamento};{l.FormaPagamento};{l.MoedaCodigo};{l.ValorInformadoMinor};{l.ValorPrincipalMinor};{l.UsuarioId};{l.Observacao}");
                    }
                    break;
                case "gourmet":
                    if (gourmetResp == null) return;
                    csv.AppendLine("METRICA;MOEDA/STATUS;VALOR");
                    csv.AppendLine($"Total Pedidos Delivery;;{gourmetResp.TotalPedidosDelivery}");
                    csv.AppendLine($"Total Taxas Entrega;;{gourmetResp.TaxaEntregaTotalMinor}");
                    csv.AppendLine($"Total Atendimentos Gourmet;;{gourmetResp.TotalAtendimentosGourmet}");
                    csv.AppendLine($"Ticket Medio Gourmet BRL;;{gourmetResp.TicketMedioGourmetBrlMinor}");
                    if (gourmetResp.DeliveryPorStatus != null)
                    {
                        foreach (var d in gourmetResp.DeliveryPorStatus)
                        {
                            csv.AppendLine($"Entrega Status;{d.Status};{d.Quantidade}");
                        }
                    }
                    if (gourmetResp.FaturamentoDeliveryMoeda != null)
                    {
                        foreach (var fd in gourmetResp.FaturamentoDeliveryMoeda)
                        {
                            csv.AppendLine($"Fat Delivery Moeda;{fd.MoedaCodigo};{fd.ValorMinor}");
                        }
                    }
                    if (gourmetResp.FaturamentoGourmetMoeda != null)
                    {
                        foreach (var fg in gourmetResp.FaturamentoGourmetMoeda)
                        {
                            csv.AppendLine($"Fat Gourmet Moeda;{fg.MoedaCodigo};{fg.ValorMinor}");
                        }
                    }
                    break;
                case "ranking":
                    if (rankingResp == null) return;
                    csv.AppendLine("Produto ID;Nome;SKU;Qtd Vendida;Faturamento Bruto BRL");
                    foreach (var r in rankingResp)
                    {
                        csv.AppendLine($"{r.ProdutoId};{r.ProdutoNome};{r.ProdutoSku};{r.QuantidadeVendidaEscala3};{r.FaturamentoBrutoMinor}");
                    }
                    break;
            }

            await JS.InvokeVoidAsync("aureon.downloadFile", filename, "text/csv;charset=utf-8", csv.ToString());
        }
        catch (Exception ex)
        {
            erro = $"Erro ao exportar CSV: {ex.Message}";
        }
    }

    private async Task ImprimirRelatorio()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private string FormatarValor(long minor, string moeda)
    {
        decimal valor = minor / 100m;
        if (moeda == "BRL")
            return valor.ToString("C2", new CultureInfo("pt-BR"));
        if (moeda == "USD")
            return $"$ {valor.ToString("N2", CultureInfo.InvariantCulture)}";
        if (moeda == "EUR")
            return $"€ {valor.ToString("N2", CultureInfo.InvariantCulture)}";
        return $"{moeda} {valor.ToString("N2")}";
    }

    private string FormatarQuantidade(long escala3)
    {
        decimal qtd = escala3 / 1000m;
        return qtd.ToString("N3", new CultureInfo("pt-BR"));
    }

    private string FormatarDataHora(string isoString)
    {
        if (DateTime.TryParse(isoString, out var dt))
        {
            return dt.ToString("dd/MM/yyyy HH:mm:ss");
        }
        return isoString;
    }

    private string ObterBadgeStatusClass(string status)
    {
        switch (status)
        {
            // Caixas / Compras / Vendas / Contas
            case "FINALIZADA":
            case "PAGO":
            case "CONCLUIDO":
            case "ENTREGUE":
                return "bg-success text-white";
            case "PENDENTE":
            case "PAGO_PARCIAL":
            case "ABERTO":
            case "EM_ANDAMENTO":
                return "bg-warning text-dark";
            case "CANCELADO":
            case "CANCELADA":
            case "RECUSADO":
                return "bg-danger text-white";
            default:
                return "bg-secondary text-white";
        }
    }

    #endregion
}

