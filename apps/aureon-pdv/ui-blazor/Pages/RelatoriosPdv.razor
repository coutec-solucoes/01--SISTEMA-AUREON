@page "/relatorios"
@using AureonPdvUi.Services
@using System.Globalization
@using System.Text
@inject TauriService Tauri
@inject IJSRuntime JS

<div class="container-fluid py-4 fade-in no-print">
    <!-- Cabeçalho -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white m-0 font-outfit fw-bold tracking-tight">Hub de Relatórios</h2>
            <p class="text-muted small m-0">Consulte relatórios operacionais locais e realize exportações locais</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-light-custom" @onclick="ExportarCSV" disabled="@(carregando || !PodeExportar())">
                <i class="bi bi-file-earmark-spreadsheet me-2"></i>Exportar CSV
            </button>
            <button class="btn btn-purple" @onclick="ImprimirRelatorio" disabled="@carregando">
                <i class="bi bi-printer me-2"></i>Imprimir / PDF
            </button>
        </div>
    </div>

    <!-- Filtros Superiores -->
    <div class="card p-3 mb-4 card-filtros">
        <div class="row g-3 align-items-end">
            <!-- Atalhos de Período -->
            <div class="col-xl-3 col-md-6">
                <label class="text-muted small uppercase mb-2 d-block">Período Rápido</label>
                <div class="btn-group w-100" role="group">
                    <button type="button" class="btn btn-sm @(periodoSelecionado == "hoje" ? "btn-purple" : "btn-outline-dark-custom")" @onclick='() => MudarPeriodo("hoje")'>Hoje</button>
                    <button type="button" class="btn btn-sm @(periodoSelecionado == "7dias" ? "btn-purple" : "btn-outline-dark-custom")" @onclick='() => MudarPeriodo("7dias")'>7 Dias</button>
                    <button type="button" class="btn btn-sm @(periodoSelecionado == "mes" ? "btn-purple" : "btn-outline-dark-custom")" @onclick='() => MudarPeriodo("mes")'>Mês</button>
                    <button type="button" class="btn btn-sm @(periodoSelecionado == "30dias" ? "btn-purple" : "btn-outline-dark-custom")" @onclick='() => MudarPeriodo("30dias")'>30 Dias</button>
                </div>
            </div>

            <!-- Datas Customizadas -->
            <div class="col-xl-3 col-md-6">
                <div class="row g-2">
                    <div class="col-6">
                        <label class="text-muted small uppercase mb-1 d-block">Data Início</label>
                        <input type="date" class="form-control form-control-sm input-dark" @bind="dataInicioInput" @bind:after="FiltroDataAlterado" />
                    </div>
                    <div class="col-6">
                        <label class="text-muted small uppercase mb-1 d-block">Data Fim</label>
                        <input type="date" class="form-control form-control-sm input-dark" @bind="dataFimInput" @bind:after="FiltroDataAlterado" />
                    </div>
                </div>
            </div>

            <!-- Filtros Extras (Operador, Moeda, etc.) -->
            <div class="col-xl-4 col-md-8">
                <div class="row g-2">
                    <div class="col-4">
                        <label class="text-muted small uppercase mb-1 d-block">Operador (ID)</label>
                        <input type="text" class="form-control form-control-sm input-dark" placeholder="Todos" @bind="usuarioIdFilter" />
                    </div>
                    <div class="col-4">
                        <label class="text-muted small uppercase mb-1 d-block">Moeda</label>
                        <select class="form-select form-select-sm input-dark" @bind="moedaCodigoFilter">
                            <option value="">Todas</option>
                            <option value="BRL">BRL</option>
                            <option value="USD">USD</option>
                            <option value="EUR">EUR</option>
                        </select>
                    </div>
                    <div class="col-4">
                        <label class="text-muted small uppercase mb-1 d-block">Pagamento</label>
                        <select class="form-select form-select-sm input-dark" @bind="formaPagamentoFilter">
                            <option value="">Todas</option>
                            <option value="DINHEIRO">Dinheiro</option>
                            <option value="CREDITO_CLIENTE">Crediário</option>
                            <option value="CARTAO_DEBITO">Débito</option>
                            <option value="CARTAO_CREDITO">Crédito</option>
                            <option value="PIX">Pix</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Botão Buscar -->
            <div class="col-xl-2 col-md-4">
                <button class="btn btn-purple btn-sm w-100 py-2" @onclick="GerarRelatorioSelecionado" disabled="@carregando">
                    @if (carregando)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    else
                    {
                        <i class="bi bi-search me-2"></i>
                    }
                    Consultar
                </button>
            </div>
        </div>
    </div>

    <!-- Layout Principal: Lateral (Abas) + Conteúdo -->
    <div class="row">
        <!-- Menu Lateral -->
        <div class="col-lg-3 mb-4">
            <div class="list-group sidebar-list shadow-glass">
                <button class="list-group-item list-group-item-action @(abaAtiva == "vendas" ? "active" : "")" @onclick='() => MudarAba("vendas")'>
                    <i class="bi bi-cart3 me-3 text-success"></i>1. Relatório de Vendas
                </button>
                <button class="list-group-item list-group-item-action @(abaAtiva == "caixas" ? "active" : "")" @onclick='() => MudarAba("caixas")'>
                    <i class="bi bi-calculator me-3 text-info"></i>2. Sessões de Caixa
                </button>
                <button class="list-group-item list-group-item-action @(abaAtiva == "estoque" ? "active" : "")" @onclick='() => MudarAba("estoque")'>
                    <i class="bi bi-box-seam me-3 text-warning"></i>3. Estoque & Kardex
                </button>
                <button class="list-group-item list-group-item-action @(abaAtiva == "compras" ? "active" : "")" @onclick='() => MudarAba("compras")'>
                    <i class="bi bi-bag-plus me-3 text-danger"></i>4. Relatório de Compras
                </button>
                <button class="list-group-item list-group-item-action @(abaAtiva == "financeiro" ? "active" : "")" @onclick='() => MudarAba("financeiro")'>
                    <i class="bi bi-currency-dollar me-3 text-purple"></i>5. Financeiro Consolidado
                </button>
                <button class="list-group-item list-group-item-action @(abaAtiva == "gourmet" ? "active" : "")" @onclick='() => MudarAba("gourmet")'>
                    <i class="bi bi-egg-fried me-3 text-pink"></i>6. Gourmet & Delivery
                </button>
                <button class="list-group-item list-group-item-action @(abaAtiva == "ranking" ? "active" : "")" @onclick='() => MudarAba("ranking")'>
                    <i class="bi bi-star me-3 text-yellow"></i>7. Ranking de Venda
                </button>
            </div>
        </div>

        <!-- Conteúdo do Relatório -->
        <div class="col-lg-9">
            <!-- Feedback de Erro -->
            @if (erro != null)
            {
                <div class="alert alert-danger">@erro</div>
            }

            @if (carregando)
            {
                <div class="card p-5 text-center bg-card-dark border-card shadow-glass">
                    <div class="spinner-border text-purple mb-3" role="status"></div>
                    <h5 class="text-white">Carregando relatório...</h5>
                    <p class="text-muted small">Consultando dados no SQLite local...</p>
                </div>
            }
            else
            {
                <!-- Conteúdo Dinâmico por Aba -->
                <div class="card bg-card-dark border-card shadow-glass p-4 min-vh-50">
                    @if (abaAtiva == "vendas")
                    {
                        @RenderVendas()
                    }
                    else if (abaAtiva == "caixas")
                    {
                        @RenderCaixas()
                    }
                    else if (abaAtiva == "estoque")
                    {
                        @RenderEstoqueKardex()
                    }
                    else if (abaAtiva == "compras")
                    {
                        @RenderCompras()
                    }
                    else if (abaAtiva == "financeiro")
                    {
                        @RenderFinanceiro()
                    }
                    else if (abaAtiva == "gourmet")
                    {
                        @RenderGourmetDelivery()
                    }
                    else if (abaAtiva == "ranking")
                    {
                        @RenderRanking()
                    }
                </div>
            }
        </div>
    </div>
</div>

<!-- Layout de Impressão Puro -->
<div class="print-only">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <div>
            <h3 class="text-black m-0 font-outfit fw-bold">AUREON PDV — RELATÓRIO OPERACIONAL</h3>
            <p class="text-muted small m-0">Período: @dataInicioEnviada até @dataFimEnviada</p>
        </div>
        <div class="text-end">
            <span class="small text-black d-block">Data de Emissão: @DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss")</span>
            <span class="small text-black">Aba: @abaAtiva.ToUpper()</span>
        </div>
    </div>

    @if (abaAtiva == "vendas") { @RenderVendas(true) }
    else if (abaAtiva == "caixas") { @RenderCaixas(true) }
    else if (abaAtiva == "estoque") { @RenderEstoqueKardex(true) }
    else if (abaAtiva == "compras") { @RenderCompras(true) }
    else if (abaAtiva == "financeiro") { @RenderFinanceiro(true) }
    else if (abaAtiva == "gourmet") { @RenderGourmetDelivery(true) }
    else if (abaAtiva == "ranking") { @RenderRanking(true) }
</div>

@code {
    #region Renderizadores de Interface

    private RenderFragment RenderVendas(bool printMode = false) => __builder => {
        var tableClass = printMode ? "table table-sm table-bordered" : "table table-hover align-middle table-dark-custom";
        var headerClass = printMode ? "" : "text-white bg-item-dark";

        <h4 class="@(printMode ? "text-black" : "text-white") mb-3">Relatório Detalhado de Vendas</h4>
        
        <!-- Totais Resumo -->
        @if (vendasResp?.TotaisPorMoeda != null && vendasResp.TotaisPorMoeda.Any())
        {
            <div class="row g-3 mb-4">
                @foreach (var t in vendasResp.TotaisPorMoeda)
                {
                    <div class="col-md-4">
                        <div class="p-3 rounded bg-subcard border-left-success">
                            <div class="text-muted small">Faturamento (@t.MoedaCodigo)</div>
                            <h4 class="@(printMode ? "text-black" : "text-white") m-0 mt-1">@FormatarValor(t.ValorMinor, t.MoedaCodigo)</h4>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Detalhes por Forma de Pagamento -->
        @if (vendasResp?.VendasPorForma != null && vendasResp.VendasPorForma.Any())
        {
            <h5 class="@(printMode ? "text-black" : "text-white") mb-2 mt-4 small uppercase fw-bold">Por Forma de Pagamento</h5>
            <div class="table-responsive mb-4">
                <table class="@tableClass">
                    <thead>
                        <tr class="@headerClass">
                            <th>Forma de Pagamento</th>
                            <th>Moeda</th>
                            <th>Quantidade de Vendas</th>
                            <th class="text-end">Total Acumulado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in vendasResp.VendasPorForma)
                        {
                            <tr>
                                <td>@f.FormaPagamento</td>
                                <td><span class="badge bg-dark-purple">@f.MoedaCodigo</span></td>
                                <td>@f.Quantidade</td>
                                <td class="text-end fw-bold">@FormatarValor(f.TotalMinor, f.MoedaCodigo)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Lista de Vendas -->
        <h5 class="@(printMode ? "text-black" : "text-white") mb-2 mt-4 small uppercase fw-bold">Listagem Geral das Vendas</h5>
        @if (vendasResp?.Vendas == null || !vendasResp.Vendas.Any())
        {
            <p class="text-muted small">Nenhuma venda encontrada no período.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="@tableClass">
                    <thead>
                        <tr class="@headerClass">
                            <th>Nº Venda</th>
                            <th>Data/Hora</th>
                            <th>Cliente</th>
                            <th>Operador</th>
                            <th class="text-end">Desconto</th>
                            <th class="text-end">Total Líquido</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in vendasResp.Vendas)
                        {
                            <tr>
                                <td><strong>#@(v.NumeroVenda?.ToString() ?? "Rascunho")</strong></td>
                                <td>@FormatarDataHora(v.DataVenda)</td>
                                <td>@(v.ClienteNome ?? "Consumidor Final")</td>
                                <td>@v.UsuarioId</td>
                                <td class="text-end">@FormatarValor(v.DescontoTotalMinor, "BRL")</td>
                                <td class="text-end fw-bold">@FormatarValor(v.TotalLiquidoMinor, "BRL")</td>
                                <td class="text-center">
                                    <span class="badge @ObterBadgeStatusClass(v.Status)">@v.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    };

    private RenderFragment RenderCaixas(bool printMode = false) => __builder => {
        var tableClass = printMode ? "table table-sm table-bordered" : "table table-hover align-middle table-dark-custom";
        var headerClass = printMode ? "" : "text-white bg-item-dark";

        <h4 class="@(printMode ? "text-black" : "text-white") mb-3">Relatório de Sessões de Caixa</h4>

        @if (caixasResp?.Sessoes == null || !caixasResp.Sessoes.Any())
        {
            <p class="text-muted small">Nenhuma sessão de caixa encontrada no período.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="@tableClass">
                    <thead>
                        <tr class="@headerClass">
                            <th>Sessão ID / Operador</th>
                            <th>Abertura</th>
                            <th>Fechamento</th>
                            <th>Moeda</th>
                            <th class="text-end">Abertura</th>
                            <th class="text-end">Esperado</th>
                            <th class="text-end">Informado</th>
                            <th class="text-end">Diferença</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in caixasResp.Sessoes)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@s.Id.Substring(0, Math.Min(8, s.Id.Length))...</div>
                                    <div class="text-muted small">Op: @s.OperadorId | Term: @s.TerminalId</div>
                                </td>
                                <td class="small">@FormatarDataHora(s.AbertoEm)</td>
                                <td class="small">@(string.IsNullOrEmpty(s.FechadoEm) ? "-" : FormatarDataHora(s.FechadoEm))</td>
                                <td><span class="badge bg-dark-purple">@s.MoedaCodigo</span></td>
                                <td class="text-end">@FormatarValor(s.ValorAberturaMinor, s.MoedaCodigo)</td>
                                <td class="text-end fw-bold">@FormatarValor(s.ValorFechamentoEsperadoMinor, s.MoedaCodigo)</td>
                                <td class="text-end text-info fw-bold">@FormatarValor(s.ValorFechamentoInformadoMinor, s.MoedaCodigo)</td>
                                <td class="text-end fw-bold @(s.DiferencaMinor < 0 ? "text-danger" : s.DiferencaMinor > 0 ? "text-success" : "")">
                                    @FormatarValor(s.DiferencaMinor, s.MoedaCodigo)
                                </td>
                                <td class="text-center">
                                    <span class="badge @ObterBadgeStatusClass(s.Status)">@s.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    };

    private RenderFragment RenderEstoqueKardex(bool printMode = false) => __builder => {
        var tableClass = printMode ? "table table-sm table-bordered" : "table table-hover align-middle table-dark-custom";
        var headerClass = printMode ? "" : "text-white bg-item-dark";

        <h4 class="@(printMode ? "text-black" : "text-white") mb-3">Relatório de Estoque e Kardex</h4>

        <!-- Valorização de Estoque -->
        @if (estoqueResp != null)
        {
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <div class="p-3 rounded bg-subcard border-left-purple">
                        <div class="text-muted small">Valor Estimado do Estoque (Custo Principal BRL)</div>
                        <h4 class="@(printMode ? "text-black" : "text-white") m-0 mt-1">@FormatarValor(estoqueResp.CustoTotalEstimadoBrl, "BRL")</h4>
                        <div class="text-muted small mt-1">Soma das quantidades multiplicadas pelo último custo (convertido pela taxa)</div>
                    </div>
                </div>
            </div>
        }

        <!-- Posição Física -->
        <h5 class="@(printMode ? "text-black" : "text-white") mb-2 mt-4 small uppercase fw-bold">Posição Atual de Estoque (Produtos Ativos)</h5>
        @if (estoqueResp?.PosicaoEstoque == null || !estoqueResp.PosicaoEstoque.Any())
        {
            <p class="text-muted small">Nenhum produto físico encontrado para controle de estoque.</p>
        }
        else
        {
            <div class="table-responsive mb-5" style="max-height: 350px; overflow-y: auto;">
                <table class="@tableClass">
                    <thead>
                        <tr class="@headerClass">
                            <th>Produto / SKU</th>
                            <th>Controle</th>
                            <th class="text-end">Quantidade</th>
                            <th class="text-end">Último Custo Original</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in estoqueResp.PosicaoEstoque)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold">@p.ProdutoNome</div>
                                    <div class="text-muted small">SKU: @(string.IsNullOrEmpty(p.ProdutoSku) ? "-" : p.ProdutoSku)</div>
                                </td>
                                <td>@(p.ControlaEstoque ? "Sim" : "Não")</td>
                                <td class="text-end fw-bold @(p.QuantidadeEscala3 <= 0 ? "text-danger" : "")">@FormatarQuantidade(p.QuantidadeEscala3)</td>
                                <td class="text-end">@FormatarValor(p.UltimoCustoMinor, "BRL")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Kardex Extrato -->
        <h5 class="@(printMode ? "text-black" : "text-white") mb-2 mt-4 small uppercase fw-bold">Extrato de Movimentações (Kardex)</h5>
        @if (estoqueResp?.ItensKardex == null || !estoqueResp.ItensKardex.Any())
        {
            <p class="text-muted small">Nenhuma movimentação registrada no Kardex no período.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="@tableClass">
                    <thead>
                        <tr class="@headerClass">
                            <th>Data</th>
                            <th>Produto / SKU</th>
                            <th>Tipo Movimento</th>
                            <th class="text-end">Quantidade</th>
                            <th>Operador</th>
                            <th>Observação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var k in estoqueResp.ItensKardex)
                        {
                            <tr>
                                <td class="small">@FormatarDataHora(k.DataMovimentacao)</td>
                                <td>
                                    <div class="fw-bold">@k.ProdutoNome</div>
                                    <div class="text-muted small">SKU: @k.ProdutoSku</div>
                                </td>
                                <td>
                                    <span class="badge @(k.TipoMovimentacao == "ENTRADA" ? "bg-success" : "bg-danger")">@k.TipoMovimentacao</span>
                                </td>
                                <td class="text-end fw-bold">@FormatarQuantidade(k.QuantidadeEscala3)</td>
                                <td>@k.UsuarioId</td>
                                <td class="small text-muted">@k.Observacao</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    };

    private RenderFragment RenderCompras(bool printMode = false) => __builder => {
        var tableClass = printMode ? "table table-sm table-bordered" : "table table-hover align-middle table-dark-custom";
        var headerClass = printMode ? "" : "text-white bg-item-dark";

        <h4 class="@(printMode ? "text-black" : "text-white") mb-3">Relatório de Notas de Compra</h4>

        <!-- Totais por Moeda -->
        @if (comprasResp?.TotalPorMoeda != null && comprasResp.TotalPorMoeda.Any())
        {
            <div class="row g-3 mb-4">
                @foreach (var t in comprasResp.TotalPorMoeda)
                {
                    <div class="col-md-4">
                        <div class="p-3 rounded bg-subcard border-left-danger">
                            <div class="text-muted small">Total Compras (@t.MoedaCodigo)</div>
                            <h4 class="@(printMode ? "text-black" : "text-white") m-0 mt-1">@FormatarValor(t.ValorMinor, t.MoedaCodigo)</h4>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Fornecedores -->
        @if (comprasResp?.TotalPorFornecedor != null && comprasResp.TotalPorFornecedor.Any())
        {
            <h5 class="@(printMode ? "text-black" : "text-white") mb-2 mt-4 small uppercase fw-bold">Compras por Fornecedor (Equivalente BRL)</h5>
            <div class="table-responsive mb-4">
                <table class="@tableClass">
                    <thead>
                        <tr class="@headerClass">
                            <th>Fornecedor</th>
                            <th class="text-end">Total Principal BRL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in comprasResp.TotalPorFornecedor)
                        {
                            <tr>
                                <td class="fw-bold">@f.FornecedorNome</td>
                                <td class="text-end fw-bold">@FormatarValor(f.TotalPrincipalBrlMinor, "BRL")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Lista Geral -->
        <h5 class="@(printMode ? "text-black" : "text-white") mb-2 mt-4 small uppercase fw-bold">Listagem de Compras Realizadas</h5>
        @if (comprasResp?.Compras == null || !comprasResp.Compras.Any())
        {
            <p class="text-muted small">Nenhuma nota de compra encontrada no período.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="@tableClass">
                    <thead>
                        <tr class="@headerClass">
                            <th>Compra ID</th>
                            <th>Fornecedor</th>
                            <th>Data</th>
                            <th>Moeda Original</th>
                            <th class="text-end">Valor Original</th>
                            <th class="text-end">Valor Principal BRL</th>
                            <th class="text-end">Quantidade de Itens</th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in comprasResp.Compras)
                        {
                            <tr>
                                <td><strong>#@c.Id.Substring(0, Math.Min(8, c.Id.Length))...</strong></td>
                                <td>@c.FornecedorNome</td>
                                <td class="small">@FormatarDataHora(c.DataCompra)</td>
                                <td><span class="badge bg-dark-purple">@c.MoedaCodigo</span></td>
                                <td class="text-end">@FormatarValor(c.TotalOriginalMinor, c.MoedaCodigo)</td>
                                <td class="text-end fw-bold">@FormatarValor(c.TotalPrincipalBrlMinor, "BRL")</td>
                                <td class="text-end">@FormatarQuantidade(c.TotalItensEscala3)</td>
