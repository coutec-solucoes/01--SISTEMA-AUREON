@page "/seguranca"
@using AureonPdvUi.Services
@using AureonPdvUi.Shared
@inject AureonPdvUi.Services.TauriService Tauri
@inject NotificationService Toast

<div class="container-fluid mt-3">
    <h3>Segurança Operacional</h3>
    <hr />

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(TabAtiva == "Sessao" ? "active" : "")" @onclick="@(() => TabAtiva = "Sessao")">Sessão Atual</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(TabAtiva == "Usuarios" ? "active" : "")" @onclick="@(() => TabAtiva = "Usuarios")">Usuários Locais</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(TabAtiva == "Perfis" ? "active" : "")" @onclick="@(() => TabAtiva = "Perfis")">Perfis</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(TabAtiva == "Permissoes" ? "active" : "")" @onclick="@(() => TabAtiva = "Permissoes")">Permissões</button>
        </li>
    </ul>

    @if (TabAtiva == "Sessao")
    {
        if (Sessao != null && Sessao.Autenticado)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-success text-white">Usuário Logado</div>
                <div class="card-body">
                    <p><strong>Nome:</strong> @Sessao.Nome (@Sessao.Login)</p>
                    <p><strong>Perfis:</strong> @string.Join(", ", Sessao.Perfis)</p>
                    <p><strong>Desde:</strong> @Sessao.AbertaEm</p>
                    <button class="btn btn-warning" @onclick="FazerLogout">Sair / Logout</button>
                    <button class="btn btn-outline-secondary ms-2" @onclick="AbrirTrocarSenhaMinha">Trocar Minha Senha</button>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">Permissões Efetivas</div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var p in Sessao.Permissoes)
                        {
                            <span class="badge bg-secondary">@p</span>
                        }
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mt-3">
                <div class="card-header">Testar Permissão (Verificar Guarda)</div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Ex: CAIXA_ABRIR" @bind="PermissaoTeste">
                        <button class="btn btn-primary" @onclick="TestarGuardaPermissao">Testar</button>
                    </div>
                    @if (!string.IsNullOrEmpty(TesteResultado))
                    {
                        <div class="alert @TesteClasse">@TesteResultado</div>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">Nenhuma sessão ativa. <a href="/seguranca/login">Ir para Login</a></div>
        }
    }
    else if (TabAtiva == "Usuarios")
    {
        <div class="mb-3">
            <button class="btn btn-primary" @onclick="AbrirNovoUsuario">Novo Usuário</button>
        </div>
        <div class="table-responsive">
            <table class="table table-bordered table-striped align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Login</th>
                        <th>Status</th>
                        <th>Perfis</th>
                        <th>Último Acesso</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Usuarios)
                    {
                        <tr>
                            <td>@u.Nome</td>
                            <td>@u.Login</td>
                            <td>
                                @if (u.Ativo) { <span class="badge bg-success">Ativo</span> }
                                else { <span class="badge bg-danger">Inativo</span> }
                            </td>
                            <td>@string.Join(", ", u.Perfis)</td>
                            <td>@u.UltimoLoginEm</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => AbrirEditarUsuario(u)">Editar</button>
                                <button class="btn btn-sm btn-outline-warning ms-1" @onclick="() => AbrirRedefinirSenha(u)">Redefinir Senha</button>
                                @if (u.Ativo)
                                {
                                    <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => InativarUsuario(u.Id)">Inativar</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success ms-1" @onclick="() => AtivarUsuario(u.Id)">Ativar</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (TabAtiva == "Perfis")
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped">
                <thead class="table-light">
                    <tr>
                        <th>Código</th>
                        <th>Nome</th>
                        <th>Status</th>
                        <th>Descrição</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Perfis)
                    {
                        <tr>
                            <td><strong>@p.Codigo</strong></td>
                            <td>@p.Nome</td>
                            <td>
                                @if (p.Ativo) { <span class="badge bg-success">Ativo</span> }
                                else { <span class="badge bg-danger">Inativo</span> }
                            </td>
                            <td>@p.Descricao</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (TabAtiva == "Permissoes")
    {
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Módulo</th>
                        <th>Ação</th>
                        <th>Código (Tauri)</th>
                        <th>Risco</th>
                        <th>Descrição</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Permissoes)
                    {
                        <tr>
                            <td>@p.Modulo</td>
                            <td>@p.Acao</td>
                            <td><code>@p.Codigo</code></td>
                            <td>@p.Risco</td>
                            <td>@p.Descricao</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@if (ExibirUsuarioModal)
{
    <UsuarioModal UsuarioEdicao="UsuarioSendoEditado"
                  OnClose="() => ExibirUsuarioModal = false"
                  OnSaved="AoSalvarUsuario" />
}

@if (ExibirTrocaSenhaModal && Sessao != null)
{
    <TrocarSenhaModal UsuarioId="@Sessao.UsuarioId"
                      OnClose="() => ExibirTrocaSenhaModal = false"
                      OnSaved="AoSalvarTrocaSenha" />
}

@if (ExibirRedefinirSenhaModal && UsuarioSendoEditado != null)
{
    <RedefinirSenhaModal UsuarioId="@UsuarioSendoEditado.Id"
                         OnClose="() => ExibirRedefinirSenhaModal = false"
                         OnSaved="AoSalvarRedefinicaoSenha" />
}

@code {
    private string TabAtiva = "Sessao";
    
    private SessaoUsuarioResp? Sessao;
    private List<UsuarioLocalResp> Usuarios = new();
    private List<PerfilLocalResp> Perfis = new();
    private List<PermissaoLocalResp> Permissoes = new();

    private string PermissaoTeste = "";
    private string TesteResultado = "";
    private string TesteClasse = "";

    // Controle de Modais
    private bool ExibirUsuarioModal = false;
    private bool ExibirTrocaSenhaModal = false;
    private bool ExibirRedefinirSenhaModal = false;
    private UsuarioLocalResp? UsuarioSendoEditado = null;

    protected override async Task OnInitializedAsync()
    {
        await CarregarSessao();
        await CarregarUsuarios();
        await CarregarPerfis();
        await CarregarPermissoes();
    }

    private async Task CarregarSessao()
    {
        try
        {
            var res = await Tauri.InvocarAsync<SessaoUsuarioResp>("obter_sessao_usuario_atual", null);
            if (res != null) Sessao = res;
        }
        catch { /* ignora erro */ }
    }

    private async Task TestarGuardaPermissao()
    {
        if (string.IsNullOrWhiteSpace(PermissaoTeste)) return;
        try
        {
            var req = new VerificarPermissaoOperacaoReq { PermissaoCodigo = PermissaoTeste };
            var res = await Tauri.InvocarAsync<VerificarPermissaoOperacaoResp>("verificar_permissao_operacao", new { req });
            if (res != null && res.Permitido)
            {
                TesteResultado = $"Permitido! {res.Mensagem}";
                TesteClasse = "alert-success";
            }
            else
            {
                TesteResultado = $"Negado. {res?.Mensagem}";
                TesteClasse = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            TesteResultado = $"Erro/Negado: {ex.Message}";
            TesteClasse = "alert-danger";
        }
    }

    private async Task CarregarUsuarios()
    {
        var usrs = await Tauri.InvocarAsync<List<UsuarioLocalResp>>("listar_usuarios_local", null);
        if (usrs != null) Usuarios = usrs;
    }

    private async Task CarregarPerfis()
    {
        var prfs = await Tauri.InvocarAsync<List<PerfilLocalResp>>("listar_perfis_local", null);
        if (prfs != null) Perfis = prfs;
    }

    private async Task CarregarPermissoes()
    {
        var pms = await Tauri.InvocarAsync<List<PermissaoLocalResp>>("listar_permissoes_local", null);
        if (pms != null) Permissoes = pms;
    }

    private async Task FazerLogout()
    {
        await Tauri.InvocarAsync<bool>("logout_local", null);
        await CarregarSessao();
    }

    // Modal Handlers
    private void AbrirNovoUsuario()
    {
        UsuarioSendoEditado = null;
        ExibirUsuarioModal = true;
    }

    private void AbrirEditarUsuario(UsuarioLocalResp u)
    {
        UsuarioSendoEditado = u;
        ExibirUsuarioModal = true;
    }

    private void AbrirRedefinirSenha(UsuarioLocalResp u)
    {
        UsuarioSendoEditado = u;
        ExibirRedefinirSenhaModal = true;
    }

    private void AbrirTrocarSenhaMinha()
    {
        ExibirTrocaSenhaModal = true;
    }

    private async Task AoSalvarUsuario()
    {
        ExibirUsuarioModal = false;
        await CarregarUsuarios();
    }

    private void AoSalvarTrocaSenha()
    {
        ExibirTrocaSenhaModal = false;
    }

    private async Task AoSalvarRedefinicaoSenha()
    {
        ExibirRedefinirSenhaModal = false;
        await CarregarUsuarios();
    }

    private async Task InativarUsuario(string id)
    {
        try
        {
            var res = await Tauri.InvocarAsync<UsuarioOperacaoResp>("inativar_usuario_local", new { usuarioId = id });
            if (res != null && res.Sucesso)
            {
                Toast.ShowSuccess(res.Mensagem);
                await CarregarUsuarios();
            }
            else Toast.ShowError(res?.Mensagem ?? "Erro ao inativar.");
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

    private async Task AtivarUsuario(string id)
    {
        try
        {
            var res = await Tauri.InvocarAsync<UsuarioOperacaoResp>("ativar_usuario_local", new { usuarioId = id });
            if (res != null && res.Sucesso)
            {
                Toast.ShowSuccess(res.Mensagem);
                await CarregarUsuarios();
            }
            else Toast.ShowError(res?.Mensagem ?? "Erro ao ativar.");
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }
}
