@page "/caixa"
@using AureonPdvUi.Services
@inject TauriService Tauri

<PageTitle>Caixa — Aureon PDV</PageTitle>

<div class="fade-in">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1 style="font-size:24px; font-weight:700;">Gerenciamento de Caixa</h1>
        <span class="badge @(SessaoAtiva != null ? "badge-ok" : "badge-erro")">
            @(SessaoAtiva != null ? "CAIXA ABERTO" : "CAIXA FECHADO")
        </span>
    </div>

    @if (Carregando)
    {
        <div style="text-align: center; margin-top: 40px; color: var(--cor-texto-sub);">Carregando status do caixa...</div>
    }
    else
    {
        @if (ErroMsg != null)
        {
            <div class="card" style="border-left: 4px solid #f44336; margin-bottom: 24px;">
                <div style="color: #f44336; font-weight: bold;">Erro</div>
                <div style="color: var(--cor-texto-sub); font-size: 14px;">@ErroMsg</div>
                <button class="btn btn-primario" style="margin-top: 12px;" @onclick="LimparErro">OK</button>
            </div>
        }

        @if (SessaoAtiva == null)
        {
            <!-- ABERTURA DE CAIXA -->
            <div class="card" style="max-width: 600px;">
                <div class="card-titulo" style="margin-bottom: 16px;">Abertura de Caixa</div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                    <div>
                        <label style="display: block; font-size: 13px; color: var(--cor-texto-sub); margin-bottom: 4px;">Moeda</label>
                        <select class="input-moderno" @bind="NovaAberturaMoeda">
                            <option value="BRL">BRL - Real Brasileiro</option>
                            <option value="USD">USD - Dólar Americano</option>
                            <option value="PYG">PYG - Guarani Paraguaio</option>
                        </select>
                    </div>
                    <div>
                        <label style="display: block; font-size: 13px; color: var(--cor-texto-sub); margin-bottom: 4px;">Fundo de Caixa Informado</label>
                        <input type="number" class="input-moderno" @bind="NovaAberturaValor" step="0.01" min="0" placeholder="0.00" />
                    </div>
                </div>

                <div style="display: flex; gap: 12px; justify-content: flex-end; align-items: center;">
                    <div style="flex-grow: 1; font-size: 13px; color: var(--cor-texto-sub);">
                        Nota: No momento abrindo apenas com 1 moeda (será evoluído para múltiplo).
                    </div>
                    <button class="btn btn-primario" @onclick="AbrirCaixa" disabled="@Processando">
                        @(Processando ? "Abrindo..." : "Abrir Caixa")
                    </button>
                </div>
            </div>
        }
        else
        {
            <!-- CAIXA ABERTO - RESUMO E OPERACIONAL -->
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
                
                <div class="card">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                        <div class="card-titulo">Resumo do Turno Atual</div>
                        <div style="display: flex; gap: 8px;">
                            <button class="btn btn-primario" style="background-color: #00e676; color: #000;" @onclick="@(() => AbrirModalMovimentacao("Suprimento", "registrar_suprimento"))">Suprimento (+)</button>
                            <button class="btn btn-primario" style="background-color: #ff9800; color: #fff;" @onclick="@(() => AbrirModalMovimentacao("Sangria", "registrar_sangria"))">Sangria (-)</button>
                            <button class="btn btn-primario" style="background-color: #ff9800; color: #fff;" @onclick="@(() => AbrirModalMovimentacao("Vale Funcionário", "registrar_vale_funcionario"))">Vale (-)</button>
                            <a href="/caixa/historico" class="btn" style="background: rgba(255,255,255,0.1);">Histórico</a>
                        </div>
                    </div>
                    
                    <div style="margin-bottom: 16px; display: flex; justify-content: space-between;">
                        <div>
                            <div style="font-size: 12px; color: var(--cor-texto-sub);">ID Sessão</div>
                            <div style="font-family: monospace; font-size: 13px;">@SessaoAtiva.Id</div>
                        </div>
                        <div style="text-align: right;">
                            <div style="font-size: 12px; color: var(--cor-texto-sub);">Abertura</div>
                            <div style="font-size: 14px;">@SessaoAtiva.AbertoEm</div>
                        </div>
                    </div>

                    @if (ResumoCaixa != null)
                    {
                        <table style="width: 100%; border-collapse: collapse; font-size: 13px; text-align: right;">
                            <thead>
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.1); color: var(--cor-texto-sub);">
                                    <th style="padding: 8px; text-align: left;">Moeda</th>
                                    <th style="padding: 8px;">Abertura</th>
                                    <th style="padding: 8px;">Vendas</th>
                                    <th style="padding: 8px;">Suprimentos</th>
                                    <th style="padding: 8px;">Sangrias</th>
                                    <th style="padding: 8px;">Vales</th>
                                    <th style="padding: 8px; font-weight: bold; font-size: 14px; color: #fff;">Esperado</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in ResumoCaixa)
                                {
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <td style="padding: 8px; text-align: left; font-weight: 600;">@r.MoedaCodigo</td>
                                        <td style="padding: 8px;">@FormatarValor(r.MoedaCodigo, r.AberturaMinor)</td>
                                        <td style="padding: 8px; color: #00e676;">@FormatarValor(r.MoedaCodigo, r.VendasMinor)</td>
                                        <td style="padding: 8px; color: #00e676;">@FormatarValor(r.MoedaCodigo, r.SuprimentosMinor)</td>
                                        <td style="padding: 8px; color: #ff9800;">@FormatarValor(r.MoedaCodigo, r.SangriasMinor)</td>
                                        <td style="padding: 8px; color: #ff9800;">@FormatarValor(r.MoedaCodigo, r.ValesFuncionariosMinor)</td>
                                        <td style="padding: 8px; font-weight: bold; font-size: 14px; color: #00e676;">@FormatarValor(r.MoedaCodigo, r.EsperadoMinor)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div style="text-align: center; color: var(--cor-texto-sub); padding: 16px;">Carregando resumo...</div>
                    }
                </div>

                <!-- Ação: Fechamento -->
                <div class="card">
                    <div class="card-titulo" style="margin-bottom: 16px;">Fechamento Físico</div>
                    <div style="font-size: 13px; color: var(--cor-texto-sub); margin-bottom: 16px;">
                        Informe os valores contados fisicamente na gaveta para cada moeda.
                    </div>

                    @foreach(var s in SessaoAtiva.Saldos)
                    {
                        <div style="margin-bottom: 16px;">
                            <label style="display: block; font-size: 13px; color: var(--cor-texto-sub); margin-bottom: 4px;">Valor em gaveta (@s.MoedaCodigo)</label>
                            <input type="number" class="input-moderno" step="0.01" min="0" placeholder="0.00"
                                   value="@_fechamentoValores[s.MoedaCodigo]"
                                   @onchange="@(e => AtualizarFechamento(s.MoedaCodigo, e.Value?.ToString()))" />
                        </div>
                    }

                    <div style="margin-top: 24px; display: flex; justify-content: flex-end;">
                        <button class="btn btn-primario" style="background-color: #f44336; color: white;" @onclick="FecharCaixa" disabled="@Processando">
                            @(Processando ? "Fechando..." : "Encerrar Turno")
                        </button>
                    </div>
                </div>
            </div>
        }
    }

    <!-- SEÇÃO DE HISTÓRICO DE FECHAMENTOS -->
    @if (HistoricoSessoes.Count > 0)
    {
        <div style="margin-top: 40px;">
            <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 16px;">Últimos Turnos Fechados (Auditoria)</h2>
            <div style="display: flex; flex-direction: column; gap: 16px;">
                @foreach (var hist in HistoricoSessoes)
                {
                    <div class="card">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 12px; color: var(--cor-texto-sub);">
                            <span>ID: @hist.Id.Substring(0,8)</span>
                            <span>Fechado em: @hist.FechadoEm</span>
                        </div>
                        <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
                            <thead>
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.1); color: var(--cor-texto-sub);">
                                    <th style="padding: 8px 4px; text-align: left;">Moeda</th>
                                    <th style="padding: 8px 4px; text-align: right;">Abertura</th>
                                    <th style="padding: 8px 4px; text-align: right;">Esperado (Calc)</th>
                                    <th style="padding: 8px 4px; text-align: right;">Físico (Info)</th>
                                    <th style="padding: 8px 4px; text-align: right;">Diferença</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in hist.Saldos)
                                {
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <td style="padding: 8px 4px; font-weight: 600;">@s.MoedaCodigo</td>
                                        <td style="padding: 8px 4px; text-align: right;">@FormatarValor(s.MoedaCodigo, s.ValorAberturaMinor)</td>
                                        <td style="padding: 8px 4px; text-align: right; color:#00e676;">@FormatarValor(s.MoedaCodigo, s.ValorEsperadoMinor ?? 0)</td>
                                        <td style="padding: 8px 4px; text-align: right;">@FormatarValor(s.MoedaCodigo, s.ValorFechamentoInformadoMinor ?? 0)</td>
                                        <td style="padding: 8px 4px; text-align: right; color: @((s.DiferencaMinor ?? 0) < 0 ? "#f44336" : (s.DiferencaMinor ?? 0) > 0 ? "#00e676" : "inherit");">
                                            @FormatarValor(s.MoedaCodigo, s.DiferencaMinor ?? 0)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

</div>

<AureonPdvUi.Shared.SangriaSuprimentoModal @ref="SangriaModal" OnLancado="MovimentacaoRegistrada" />

@code {
    private bool Carregando = true;
    private bool Processando = false;
    private string? ErroMsg = null;
    private SessaoCaixaResp? SessaoAtiva;
    private List<SessaoCaixaResp> HistoricoSessoes = new();
    private List<ResumoCaixaResp>? ResumoCaixa;

    private AureonPdvUi.Shared.SangriaSuprimentoModal SangriaModal = default!;

    // Abertura
    private string NovaAberturaMoeda = "BRL";
    private decimal NovaAberturaValor = 0m;

    // Fechamento (MoedaCodigo -> Valor informado em decimal pelo usuario)
    private Dictionary<string, decimal> _fechamentoValores = new();

    private string _terminalId = "TERM-1"; // Fixo para teste
    private string _usuarioId = "USR-001"; // Fixo para teste

    protected override async Task OnInitializedAsync()
    {
        await CarregarSessao();
        await CarregarHistorico();
    }

    private async Task CarregarSessao()
    {
        Carregando = true;
        ErroMsg = null;
        try
        {
            var res = await Tauri.InvocarAsync<RespostaBase<SessaoCaixaResp?>>("obter_sessao_ativa", new { registradora_id = _terminalId });
            if (res?.Sucesso == true)
            {
                SessaoAtiva = res.Dados;
                _fechamentoValores.Clear();
                if (SessaoAtiva != null)
                {
                    foreach(var s in SessaoAtiva.Saldos)
                    {
                        _fechamentoValores[s.MoedaCodigo] = 0m;
                    }

                    // Carregar resumo detalhado
                    var resResumo = await Tauri.InvocarAsync<RespostaBase<List<ResumoCaixaResp>>>("obter_resumo_caixa", new { sessao_caixa_id = SessaoAtiva.Id });
                    if (resResumo?.Sucesso == true)
                    {
                        ResumoCaixa = resResumo.Dados;
                    }
                }
            }
            else
            {
                ErroMsg = res?.Mensagem ?? "Erro ao comunicar com backend.";
            }
        }
        catch (Exception ex)
        {
            ErroMsg = ex.Message;
        }
        finally
        {
            Carregando = false;
        }
    }

    private void AbrirModalMovimentacao(string tipo, string comando)
    {
        if (SessaoAtiva == null) return;
        SangriaModal.Abrir(tipo, comando, SessaoAtiva.Id, _usuarioId);
    }

    private async Task MovimentacaoRegistrada(CaixaMovimentacaoResp mov)
    {
        await CarregarSessao(); // Recarrega resumo
    }

    private async Task AbrirCaixa()
    {
        if (NovaAberturaValor < 0)
        {
            ErroMsg = "O valor não pode ser negativo.";
            return;
        }

        Processando = true;
        ErroMsg = null;
        try
        {
            // Converter decimal informado na UI para minor unit (i64/long) enviado ao Rust
            long valorMinor = ConverterParaMinor(NovaAberturaMoeda, NovaAberturaValor);

            var saldos = new List<SaldoMoedaReq> { new SaldoMoedaReq(NovaAberturaMoeda, valorMinor) };
            var req = new AbrirCaixaReq(_terminalId, _usuarioId, saldos);

            var res = await Tauri.InvocarAsync<RespostaBase<SessaoCaixaResp>>("abrir_caixa", new { dto = req });
            
            if (res?.Sucesso == true)
            {
                await CarregarSessao();
            }
            else
            {
                ErroMsg = res?.Mensagem ?? "Erro desconhecido";
            }
        }
        catch (Exception ex)
        {
            ErroMsg = ex.Message;
        }
        finally
        {
            Processando = false;
        }
    }

    private async Task FecharCaixa()
    {
        if (SessaoAtiva == null) return;

        Processando = true;
        ErroMsg = null;
        try
        {
            var saldosFechamento = new List<SaldoMoedaReq>();
            foreach(var kv in _fechamentoValores)
            {
                long minor = ConverterParaMinor(kv.Key, kv.Value);
                saldosFechamento.Add(new SaldoMoedaReq(kv.Key, minor));
            }

            var req = new FecharCaixaReq(SessaoAtiva.Id, _usuarioId, saldosFechamento, "Fechamento UI");
            
            var res = await Tauri.InvocarAsync<RespostaBase<SessaoCaixaResp>>("fechar_caixa", new { dto = req });
            
            if (res?.Sucesso == true)
            {
                await CarregarSessao(); // recarrega, SessaoAtiva vai ficar null
            }
            else
            {
                ErroMsg = res?.Mensagem ?? "Erro desconhecido";
            }
        }
        catch (Exception ex)
        {
            ErroMsg = ex.Message;
        }
        finally
        {
            Processando = false;
        }
    }

    private async Task CarregarHistorico()
    {
        var res = await Tauri.InvocarAsync<RespostaBase<List<SessaoCaixaResp>>>("listar_sessoes", new { limite = 5 });
        if (res?.Sucesso == true && res.Dados != null)
        {
            HistoricoSessoes = res.Dados.Where(s => s.Status == "FECHADO").ToList();
        }
    }

    private void AtualizarFechamento(string moeda, string? valorStr)
    {
        if (decimal.TryParse(valorStr, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v))
        {
            _fechamentoValores[moeda] = v;
        }
    }

    private void LimparErro() => ErroMsg = null;

    // === Helpers Financeiros na UI ===
    // O Blazor APENAS converte entre input do usuario (decimal) e backend (minor unit)
    
    private long ConverterParaMinor(string moeda, decimal valorInformado)
    {
        if (moeda.ToUpper() == "PYG" || moeda.ToUpper() == "JPY")
            return (long)Math.Round(valorInformado); // Moeda sem centavos
        return (long)Math.Round(valorInformado * 100m);
    }

    private string FormatarValor(string moeda, long valorMinor)
    {
        if (moeda.ToUpper() == "PYG" || moeda.ToUpper() == "JPY")
            return $"{valorMinor}";
        return (valorMinor / 100m).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
    }
}
