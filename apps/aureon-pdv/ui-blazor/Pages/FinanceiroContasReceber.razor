@code {
    private List<ContaReceberResp> contas = new();
    private string? statusFiltro = "PENDENTE"; // Inicia exibindo pendentes
    private bool carregando = true;
    private string? erro;

    private bool exibirBaixaModal = false;
    private bool exibirCancelarModal = false;
    private ContaReceberResp? contaSelecionada;
    private bool cancelando = false;

    private long totalPendentePrincipalBrl = 0;
    private long totalOriginalPrincipalBrl = 0;

    protected override async Task OnInitializedAsync()
    {
        await CarregarContas();
    }

    private async Task CarregarContas()
    {
        carregando = true;
        erro = null;
        try
        {
            var resp = await Tauri.InvocarAsync<RespostaBase<List<ContaReceberResp>>>("listar_contas_receber", new { status = statusFiltro });
            if (resp != null && resp.Sucesso && resp.Dados != null)
            {
                contas = resp.Dados;
                CalcularTotais();
            }
            else
            {
                erro = resp?.Mensagem ?? "Erro ao recuperar contas a receber.";
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro de comunicação: {ex.Message}";
        }
        finally
        {
            carregando = false;
        }
    }

    private void CalcularTotais()
    {
        totalPendentePrincipalBrl = 0;
        totalOriginalPrincipalBrl = 0;
        foreach (var c in contas)
        {
            long saldoPrincipal = c.SaldoPendenteMinor;
            if (c.MoedaCodigo != "BRL" && c.TaxaCambioEscala6 > 0)
            {
                saldoPrincipal = (c.SaldoPendenteMinor * c.TaxaCambioEscala6) / 1000000;
            }

            totalPendentePrincipalBrl += saldoPrincipal;
            totalOriginalPrincipalBrl += c.ValorOriginalPrincipalMinor;
        }
    }

    private async Task MudarFiltro(string? status)
    {
        statusFiltro = status;
        await CarregarContas();
    }

    private void AbrirBaixaModal(ContaReceberResp conta)
    {
        contaSelecionada = conta;
        exibirBaixaModal = true;
    }

    private void FecharBaixaModal()
    {
        exibirBaixaModal = false;
        contaSelecionada = null;
    }

    private async Task AoConfirmarBaixa()
    {
        exibirBaixaModal = false;
        contaSelecionada = null;
        await CarregarContas();
    }

    private void ConfirmarCancelar(ContaReceberResp conta)
    {
        contaSelecionada = conta;
        exibirCancelarModal = true;
    }

    private void FecharCancelarModal()
    {
        exibirCancelarModal = false;
        contaSelecionada = null;
    }

    private async Task CancelarConta()
    {
        if (contaSelecionada == null) return;
        cancelando = true;
        erro = null;

        try
        {
            var req = new CancelarContaReceberReq(
                conta_receber_id: contaSelecionada.Id,
                motivo: "Cancelamento solicitado pela interface do operador",
                usuario_id: "operador_local"
            );

            var resp = await Tauri.InvocarAsync<RespostaBase<ContaReceberResp>>("cancelar_conta_receber", new { dto = req });
            if (resp != null && resp.Sucesso)
            {
                exibirCancelarModal = false;
                contaSelecionada = null;
                await CarregarContas();
            }
            else
            {
                erro = resp?.Mensagem ?? "Erro ao cancelar título.";
                exibirCancelarModal = false;
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro na requisição: {ex.Message}";
            exibirCancelarModal = false;
        }
        finally
        {
            cancelando = false;
        }
    }

    private string FormatarValor(long minor, string moeda)
    {
        decimal valor = minor / 100m;
        if (moeda == "BRL")
            return valor.ToString("C2", new CultureInfo("pt-BR"));
        if (moeda == "USD")
            return $"$ {valor.ToString("N2", CultureInfo.InvariantCulture)}";
        if (moeda == "EUR")
            return $"€ {valor.ToString("N2", CultureInfo.InvariantCulture)}";
        return $"{moeda} {valor.ToString("N2")}";
    }

    private string FormatarData(string isoString)
    {
        if (DateTime.TryParse(isoString, out var dt))
        {
            return dt.ToString("dd/MM/yyyy");
        }
        return isoString;
    }

    private string ObterClasseVencimento(string dataVencimentoIso, string status)
    {
        if (status == "PAGO" || status == "CANCELADO") return "text-muted";

        if (DateTime.TryParse(dataVencimentoIso, out var dt))
        {
            if (dt < DateTime.Today) return "text-danger-vencido";
            if (dt == DateTime.Today) return "text-warning-light fw-bold";
        }
        return "text-white-50";
    }

    private string ObterBadgeStatusClass(string status)
    {
        switch (status)
        {
            case "PENDENTE": return "status-pendente";
            case "PAGO_PARCIAL": return "status-pago_parcial";
            case "PAGO": return "status-pago";
            case "CANCELADO": return "status-cancelada";
            default: return "bg-secondary text-white";
        }
    }
}
