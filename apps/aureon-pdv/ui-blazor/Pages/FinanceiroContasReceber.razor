@page "/financeiro/contas-receber"
@using AureonPdvUi.Services
@using System.Globalization
@inject TauriService Tauri

<div class="container-fluid py-4 fade-in">
    <!-- Cabeçalho -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-white m-0">Contas a Receber (Crediário)</h2>
            <p class="text-muted small m-0">Acompanhamento e recebimento de créditos e contas de clientes (fiado)</p>
        </div>
        <div class="text-muted small">
            <em>Alimentado automaticamente a partir de vendas finalizadas no Crediário</em>
        </div>
    </div>

    <!-- Indicadores Rápidos -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card p-3 d-flex flex-row justify-content-between align-items-center bg-card-dark">
                <div>
                    <div class="text-muted small uppercase">Total a Receber Pendente (BRL)</div>
                    <h3 class="text-white m-0 mt-1">@FormatarValor(totalPendentePrincipalBrl, "BRL")</h3>
                </div>
                <div class="icon-box bg-success-light text-success">
                    <i class="bi bi-wallet2 fs-3"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3 d-flex flex-row justify-content-between align-items-center bg-card-dark">
                <div>
                    <div class="text-muted small uppercase">Total Original da Listagem (Principal)</div>
                    <h3 class="text-white m-0 mt-1">@FormatarValor(totalOriginalPrincipalBrl, "BRL")</h3>
                </div>
                <div class="icon-box bg-purple-light text-purple">
                    <i class="bi bi-piggy-bank fs-3"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros de Status -->
    <div class="card p-3 mb-4 card-filtros">
        <div class="row align-items-center">
            <div class="col-md-9">
                <div class="btn-group" role="group">
                    <button type="button" class="btn @(statusFiltro == null ? "btn-active-filter" : "btn-outline-filter")" @onclick="() => MudarFiltro(null)">
                        Todas
                    </button>
                    <button type="button" class="btn @(statusFiltro == "PENDENTE" ? "btn-active-filter" : "btn-outline-filter")" @onclick='() => MudarFiltro("PENDENTE")'>
                        Pendentes
                    </button>
                    <button type="button" class="btn @(statusFiltro == "PAGO_PARCIAL" ? "btn-active-filter" : "btn-outline-filter")" @onclick='() => MudarFiltro("PAGO_PARCIAL")'>
                        Pago Parcial
                    </button>
                    <button type="button" class="btn @(statusFiltro == "PAGO" ? "btn-active-filter" : "btn-outline-filter")" @onclick='() => MudarFiltro("PAGO")'>
                        Pagas
                    </button>
                    <button type="button" class="btn @(statusFiltro == "CANCELADA" ? "btn-active-filter" : "btn-outline-filter")" @onclick='() => MudarFiltro("CANCELADO")'>
                        Canceladas
                    </button>
                </div>
            </div>
            <div class="col-md-3 text-end">
                <button class="btn btn-outline-secondary" @onclick="CarregarContas">
                    <i class="bi bi-arrow-clockwise me-2"></i>Atualizar
                </button>
            </div>
        </div>
    </div>

    <!-- Feedback de Erro -->
    @if (erro != null)
    {
        <div class="alert alert-danger">@erro</div>
    }

    <!-- Tabela de Contas -->
    @if (carregando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-purple" role="status"></div>
            <p class="text-muted mt-2">Carregando contas a receber...</p>
        </div>
    }
    else if (contas == null || !contas.Any())
    {
        <div class="card p-5 text-center bg-card-dark border-dashed">
            <i class="bi bi-bookmark-x fs-1 text-muted mb-3"></i>
            <h5 class="text-white">Nenhuma conta a receber encontrada</h5>
            <p class="text-muted small">Vendas concluídas com a forma "Crédito Cliente" aparecerão aqui.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle table-dark-custom">
                <thead>
                    <tr>
                        <th>Cliente / Descrição</th>
                        <th>Venda ID</th>
                        <th>Vencimento</th>
                        <th>Moeda</th>
                        <th class="text-end">Valor Original</th>
                        <th class="text-end">Saldo Pendente</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width: 200px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in contas)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold text-white">@(string.IsNullOrEmpty(c.ClienteNomeSnapshot) ? "Cliente não identificado" : c.ClienteNomeSnapshot)</div>
                                <div class="text-muted small">@c.Descricao</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(c.VendaId))
                                {
                                    <span class="font-monospace text-white-50" style="font-size:12px;">@c.VendaId.Substring(0, Math.Min(8, c.VendaId.Length))...</span>
                                }
                                else
                                {
                                    <span class="text-muted small">-</span>
                                }
                            </td>
                            <td>
                                <span class="@ObterClasseVencimento(c.DataVencimento, c.Status)">@FormatarData(c.DataVencimento)</span>
                            </td>
                            <td>
                                <span class="badge bg-dark-purple">@c.MoedaCodigo</span>
                            </td>
                            <td class="text-end fw-bold text-white">
                                @FormatarValor(c.ValorOriginalMinor, c.MoedaCodigo)
                                @if (c.MoedaCodigo != "BRL")
                                {
                                    <div class="text-muted small font-monospace">eqv. @FormatarValor(c.ValorOriginalPrincipalMinor, "BRL")</div>
                                }
                            </td>
                            <td class="text-end fw-bold text-success">
                                @FormatarValor(c.SaldoPendenteMinor, c.MoedaCodigo)
                            </td>
                            <td class="text-center">
                                <span class="badge-status @ObterBadgeStatusClass(c.Status)">@c.Status</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-2 justify-content-center">
                                    <button class="btn btn-sm btn-success-custom py-1 px-2"
                                            @onclick="() => AbrirBaixaModal(c)"
                                            disabled="@(c.Status == "PAGO" || c.Status == "CANCELADO")">
                                        Receber
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger py-1 px-2"
                                            @onclick="() => ConfirmarCancelar(c)"
                                            disabled="@(c.Status != "PENDENTE")">
                                        Cancelar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal de Baixa de Título -->
@if (exibirBaixaModal && contaSelecionada != null)
{
    <BaixaTituloModal IsContaPagar="false"
                      TituloId="@contaSelecionada.Id"
                      Descricao="@($"Receber de {contaSelecionada.ClienteNomeSnapshot} - {contaSelecionada.Descricao}")"
                      SaldoPendenteMinor="@contaSelecionada.SaldoPendenteMinor"
                      MoedaCodigo="@contaSelecionada.MoedaCodigo"
                      TaxaCambioEscala6="@contaSelecionada.TaxaCambioEscala6"
                      OnClose="FecharBaixaModal"
                      OnSuccess="AoConfirmarBaixa" />
}

<!-- Modal Confirmação de Cancelamento -->
@if (exibirCancelarModal && contaSelecionada != null)
{
    <div class="modal-overlay">
        <div class="modal-content card" style="max-width: 400px; width: 100%;">
            <div class="modal-header d-flex justify-content-between align-items-center mb-3">
                <h4 class="m-0 text-danger">Confirmar Cancelamento</h4>
                <button type="button" class="btn-close btn-close-white" @onclick="FecharCancelarModal"></button>
            </div>
            <div class="modal-body text-white">
                <p>Tem certeza de que deseja cancelar esta conta a receber de <strong>@(contaSelecionada.ClienteNomeSnapshot ?? "Cliente")</strong>?</p>
                <p class="text-danger small">Esta ação não poderá ser desfeita!</p>
            </div>
            <div class="modal-footer d-flex gap-2 justify-content-end mt-3">
                <button type="button" class="btn btn-outline-secondary" @onclick="FecharCancelarModal">Não</button>
                <button type="button" class="btn btn-danger" @onclick="CancelarConta" disabled="@cancelando">
                    @if (cancelando)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    Sim, Cancelar
                </button>
            </div>
        </div>
    </div>
}

