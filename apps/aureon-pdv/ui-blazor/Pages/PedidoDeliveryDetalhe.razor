@using AureonPdvUi.Services
@using System.Globalization
@inject TauriService Tauri
@inject NavigationManager Nav

@if (CarregandoGeral)
{
    <div style="text-align: center; color: var(--cor-texto-sub); padding: 40px;">Carregando pedido...</div>
}
else if (Pedido == null)
{
    <div style="text-align: center; color: #f44336; padding: 40px;">
        Erro ao carregar pedido.
        <button class="btn" style="margin-top: 16px;" @onclick="OnVoltar">Voltar</button>
    </div>
}
else
{
    var isFinalizado = Pedido.Status == "FECHADO" || Pedido.Status == "CANCELADO";

    <div class="detalhe-container">

        <!-- CABEÇALHO -->
        <div class="detalhe-header">
            <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
                <button class="btn btn-voltar" @onclick="OnVoltar">← Voltar</button>
                <h2 style="margin: 0;">Pedido #@Pedido.NumeroPedido</h2>
                <span class="del-badge-@Pedido.Status.ToLower()">@Pedido.Status</span>
                @if (Pedido.Origem == "ONLINE")
                {
                    <span style="font-size:11px; padding: 3px 8px; border-radius: 4px; background: rgba(255,193,7,0.2); color: #ffc107; font-weight: 700;">ONLINE</span>
                }
                else
                {
                    <span style="font-size:11px; padding: 3px 8px; border-radius: 4px; background: rgba(41,182,246,0.15); color: #29b6f6; font-weight: 700;">LOCAL</span>
                }
            </div>

            @if (!isFinalizado)
            {
                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                    <!-- Aceitar/Recusar para pedido ONLINE NOVO -->
                    @if (Pedido.Status == "NOVO" && Pedido.Origem == "ONLINE")
                    {
                        <button class="btn" style="background: rgba(0,230,118,0.15); color: #00e676; border: 1px solid rgba(0,230,118,0.3);"
                                @onclick="AceitarPedido" disabled="@Processando">
                            ✔ Aceitar
                        </button>
                        <button class="btn" style="background: rgba(244,67,54,0.1); color: #f44336; border: 1px solid rgba(244,67,54,0.3);"
                                @onclick="() => ExibirModalRecusa = true" disabled="@Processando">
                            ✖ Recusar
                        </button>
                    }
                    else
                    {
                        <!-- Avançar Status -->
                        @if (ProximoStatus() != null)
                        {
                            <button class="btn" style="background: rgba(41,182,246,0.15); color: #29b6f6;"
                                    @onclick="AvancarStatus" disabled="@Processando">
                                → @ProximoStatus()
                            </button>
                        }
                        <!-- Converter em venda (só se houver itens e status permitido) -->
                        @if (PodeConverterEmVenda())
                        {
                            <button class="btn" style="background: linear-gradient(135deg,#0288d1,#29b6f6); color:white; font-weight: 700;"
                                    @onclick="FecharEmVenda" disabled="@(Processando || Pedido.Itens.Count == 0)">
                                💰 FECHAR → Pagamento no PDV
                            </button>
                        }
                    }
                </div>
            }
            else if (Pedido.Status == "FECHADO")
            {
                <div style="background: rgba(0,230,118,0.1); border: 1px solid rgba(0,230,118,0.3); padding: 10px 16px; border-radius: 8px; font-size: 13px; color: #00e676; font-weight: 600;">
                    ✔ Venda EM_ANDAMENTO — prossiga para pagamento no PDV
                </div>
            }
        </div>

        @if (MensagemErro != null)
        {
            <div style="color: #f44336; font-size: 13px; margin-bottom: 16px; padding: 12px; background: rgba(244,67,54,0.1); border-radius: 6px;">@MensagemErro</div>
        }
        @if (MensagemSucesso != null)
        {
            <div style="color: #00e676; font-size: 13px; margin-bottom: 16px; padding: 12px; background: rgba(0,230,118,0.1); border-radius: 6px;">@MensagemSucesso</div>
        }

        <div class="detalhe-grid">

            <!-- ESQUERDA: Itens -->
            <div class="card" style="display: flex; flex-direction: column; flex: 2; min-width: 0;">
                <h3 style="margin-bottom: 16px; font-size: 16px;">Itens do Pedido</h3>

                @if (!isFinalizado)
                {
                    <!-- Adicionar item -->
                    <form @onsubmit="AdicionarItem" style="display: flex; gap: 8px; margin-bottom: 16px;">
                        <input type="text" class="input-moderno" placeholder="Código do Produto"
                               @bind="BuscaCodigo" @bind:event="oninput"
                               disabled="@Processando" style="flex-grow: 1; font-size: 14px;" />
                        <input type="number" class="input-moderno" style="width: 80px; text-align: center;"
                               @bind="BuscaQtd" step="0.001" min="0.001"
                               disabled="@Processando" />
                        <button type="submit" class="btn btn-primario"
                                disabled="@(Processando || string.IsNullOrWhiteSpace(BuscaCodigo))">
                            Adicionar
                        </button>
                    </form>
                }

                <!-- Lista de itens -->
                <div style="flex-grow: 1; overflow-y: auto;">
                    @if (!Pedido.Itens.Any())
                    {
                        <div style="color: var(--cor-texto-sub); text-align: center; padding: 20px;">Nenhum item lançado.</div>
                    }
                    else
                    {
                        <table style="width: 100%; text-align: left; border-collapse: collapse;">
                            <thead>
                                <tr style="border-bottom: 1px solid rgba(255,255,255,0.1); color: var(--cor-texto-sub); font-size: 12px;">
                                    <th style="padding: 8px 0;">Item</th>
                                    <th style="padding: 8px 0; text-align:right;">Qtd</th>
                                    <th style="padding: 8px 0; text-align:right;">Total</th>
                                    <th style="padding: 8px 0; text-align:center;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Pedido.Itens.OrderByDescending(i => i.CriadoEm))
                                {
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05); @(item.Cancelado ? "opacity:0.4; text-decoration:line-through;" : "")">
                                        <td style="padding: 12px 0;">
                                            <div style="font-weight: 600; font-size: 14px;">@item.DescricaoProduto</div>
                                            <div style="font-size: 11px; color: var(--cor-texto-sub);">@FormatarValor(item.PrecoUnitarioMinor) / un.</div>
                                        </td>
                                        <td style="padding: 12px 0; text-align:right;">@FormatarQtd(item.QuantidadeEscala3)</td>
                                        <td style="padding: 12px 0; text-align:right; font-weight:600;">@FormatarValor(item.TotalItemMinor)</td>
                                        <td style="padding: 12px 0; text-align:center;">
                                            @if (!item.Cancelado && !isFinalizado)
                                            {
                                                <button class="btn" style="padding: 4px 8px; font-size: 10px; background: rgba(244,67,54,0.1); color: #f44336;"
                                                        @onclick="() => PrepararCancelamento(item)">
                                                    Cancelar
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <!-- DIREITA: Resumo e Ações -->
            <div style="display: flex; flex-direction: column; flex: 1; min-width: 250px; gap: 16px;">

                <!-- Resumo financeiro -->
                <div class="card">
                    <h3 style="font-size: 14px; color: var(--cor-texto-sub); margin-bottom: 16px;">Resumo</h3>

                    <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 14px;">
                        <span style="color: var(--cor-texto-sub);">Consumo:</span>
                        <span>@FormatarValor(Pedido.TotalConsumoMinor)</span>
                    </div>
                    @if (Pedido.TaxaEntregaMinor > 0)
                    {
                        <div style="display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 14px;">
                            <span style="color: var(--cor-texto-sub);">Taxa entrega:</span>
                            <span style="color: #ff9800;">@FormatarValor(Pedido.TaxaEntregaMinor)</span>
                        </div>
                    }
                    <div style="border-top: 1px solid rgba(255,255,255,0.1); margin: 12px 0;"></div>
                    <div style="display: flex; justify-content: space-between; align-items: baseline;">
                        <span style="font-size: 16px; font-weight: 600;">Total</span>
                        <span style="font-size: 28px; font-weight: 700; color: #29b6f6;">
                            @FormatarValor(Pedido.TotalConsumoMinor + Pedido.TaxaEntregaMinor)
                        </span>
                    </div>
                </div>

                <!-- Dados do cliente e entrega -->
                <div class="card">
                    <h3 style="font-size: 14px; color: var(--cor-texto-sub); margin-bottom: 16px;">Cliente / Entrega</h3>

                    <div style="font-size: 13px; display: flex; flex-direction: column; gap: 6px;">
                        <div><span style="color: var(--cor-texto-sub);">Nome: </span>@Pedido.NomeClienteInformal</div>
                        @if (!string.IsNullOrEmpty(Pedido.Telefone))
                        {
                            <div><span style="color: var(--cor-texto-sub);">Fone: </span>@Pedido.Telefone</div>
                        }
                        <div>
                            <span style="color: var(--cor-texto-sub);">Tipo: </span>
                            <strong style="color: @(Pedido.TipoPedido == "ENTREGA" ? "#ff9800" : "#29b6f6");">
                                @Pedido.TipoPedido
                            </strong>
                        </div>
                        @if (!string.IsNullOrEmpty(Pedido.EnderecoCompleto))
                        {
                            <div><span style="color: var(--cor-texto-sub);">Endereço: </span>@Pedido.EnderecoCompleto</div>
                        }
                        @if (!string.IsNullOrEmpty(Pedido.Observacao))
                        {
                            <div><span style="color: #ff9800;">Obs: </span>@Pedido.Observacao</div>
                        }
                    </div>
                </div>

                <!-- Entregador (somente ENTREGA) -->
                @if (Pedido.TipoPedido == "ENTREGA" && !isFinalizado)
                {
                    <div class="card">
                        <h3 style="font-size: 14px; color: var(--cor-texto-sub); margin-bottom: 16px;">Entregador</h3>
                        @if (Entregadores.Any())
                        {
                            <select class="input-moderno" @bind="EntregadorSelecionado" style="margin-bottom: 10px;">
                                <option value="">-- Selecionar entregador --</option>
                                @foreach (var e in Entregadores)
                                {
                                    <option value="@e.Id">@e.Nome</option>
                                }
                            </select>
                            <button class="btn btn-primario" style="width: 100%;"
                                    @onclick="DefinirEntregador"
                                    disabled="@(Processando || string.IsNullOrEmpty(EntregadorSelecionado))">
                                Definir Entregador
                            </button>
                        }
                        else
                        {
                            <div style="font-size: 12px; color: var(--cor-texto-sub);">Nenhum entregador ativo cadastrado.</div>
                        }
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- Modal cancelamento de item -->
    @if (ItemParaCancelar != null)
    {
        <div class="modal-overlay">
            <div class="modal-content card" style="max-width: 400px; width: 100%;">
                <h3 style="margin-bottom: 16px; color: #f44336;">Cancelar Item</h3>
                <p style="font-size: 14px; margin-bottom: 16px;">@ItemParaCancelar.DescricaoProduto</p>
                <div style="margin-bottom: 16px;">
                    <label style="font-size: 12px; color: var(--cor-texto-sub);">Motivo (obrigatório)</label>
                    <input type="text" class="input-moderno" @bind="MotivoCancelamento" placeholder="Ex: Cliente desistiu" />
                </div>
                @if (ErroCancelamento != null)
                {
                    <div style="color: #f44336; font-size: 13px; margin-bottom: 16px;">@ErroCancelamento</div>
                }
                <div style="display: flex; gap: 8px; justify-content: flex-end;">
                    <button class="btn" style="background: rgba(255,255,255,0.1);" @onclick="() => ItemParaCancelar = null" disabled="@Processando">Cancelar</button>
                    <button class="btn" style="background: #f44336;" @onclick="ConfirmarCancelamento" disabled="@Processando">Confirmar</button>
                </div>
            </div>
        </div>
    }

    <!-- Modal recusa de pedido online -->
    @if (ExibirModalRecusa)
    {
        <div class="modal-overlay">
            <div class="modal-content card" style="max-width: 400px; width: 100%;">
                <h3 style="margin-bottom: 16px; color: #f44336;">Recusar Pedido</h3>
                <p style="font-size: 14px; margin-bottom: 16px;">Informe o motivo da recusa para o pedido #@Pedido?.NumeroPedido.</p>
                <div style="margin-bottom: 16px;">
                    <label style="font-size: 12px; color: var(--cor-texto-sub);">Motivo (obrigatório)</label>
                    <input type="text" class="input-moderno" @bind="MotivoRecusa" placeholder="Ex: Fora da área de entrega" />
                </div>
                @if (ErroRecusa != null)
                {
                    <div style="color: #f44336; font-size: 13px; margin-bottom: 16px;">@ErroRecusa</div>
                }
                <div style="display: flex; gap: 8px; justify-content: flex-end;">
                    <button class="btn" style="background: rgba(255,255,255,0.1);" @onclick="() => ExibirModalRecusa = false" disabled="@Processando">Voltar</button>
                    <button class="btn" style="background: #f44336;" @onclick="RecusarPedido" disabled="@(Processando || string.IsNullOrWhiteSpace(MotivoRecusa))">Confirmar Recusa</button>
                </div>
            </div>
        </div>
    }
}

<style>
    .detalhe-container { display: flex; flex-direction: column; height: 100%; }
    .detalhe-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 24px; flex-wrap: wrap; gap: 12px;
    }
    .detalhe-grid { display: flex; gap: 24px; flex-grow: 1; min-height: 0; }
    .btn-voltar { background: rgba(255,255,255,0.1); padding: 8px 16px; }

    /* Badges de status */
    [class^="del-badge-"] {
        font-size: 12px; padding: 4px 12px; border-radius: 4px; font-weight: 600;
    }
    .del-badge-novo { background: rgba(255,193,7,0.2); color: #ffc107; }
    .del-badge-aceito { background: rgba(41,182,246,0.2); color: #29b6f6; }
    .del-badge-preparando { background: rgba(171,71,188,0.2); color: #ab47bc; }
    .del-badge-pronto { background: rgba(0,230,118,0.2); color: #00e676; }
    .del-badge-despachado { background: rgba(255,152,0,0.2); color: #ff9800; }
    .del-badge-fechado { background: rgba(255,255,255,0.1); color: #aaa; }
    .del-badge-cancelado { background: rgba(244,67,54,0.2); color: #f44336; }
</style>

@code {
    [Parameter] public string DeliveryId { get; set; } = "";
    [Parameter] public string SessaoCaixaId { get; set; } = "";
    [Parameter] public string UsuarioId { get; set; } = "";
    [Parameter] public EventCallback OnVoltar { get; set; }

    private bool CarregandoGeral = true;
    private bool Processando = false;
    private DeliveryOperacionalResp? Pedido;
    private List<EntregadorResp> Entregadores = new();
    private string? MensagemErro;
    private string? MensagemSucesso;

    // Adicionar item
    private string BuscaCodigo = "";
    private decimal BuscaQtd = 1m;

    // Cancelamento de item
    private DeliveryItemResp? ItemParaCancelar;
    private string MotivoCancelamento = "";
    private string? ErroCancelamento;

    // Recusa
    private bool ExibirModalRecusa = false;
    private string MotivoRecusa = "";
    private string? ErroRecusa;

    // Entregador
    private string EntregadorSelecionado = "";

    // Mapeamento de transições de status permitidas
    private static readonly Dictionary<string, string> TransicoesStatus = new()
    {
        { "ACEITO", "PREPARANDO" },
        { "PREPARANDO", "PRONTO" },
        { "PRONTO", "DESPACHADO" },
    };

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        CarregandoGeral = true;
        MensagemErro = null;

        // Carrega pedido
        var resPed = await Tauri.InvocarAsync<RespostaBase<DeliveryOperacionalResp>>("obter_pedido_delivery", new { delivery_id = DeliveryId });
        if (resPed?.Sucesso == true && resPed.Dados != null)
        {
            Pedido = resPed.Dados;
        }

        // Carrega entregadores
        var resEnt = await Tauri.InvocarAsync<RespostaBase<List<EntregadorResp>>>("listar_entregadores_delivery");
        if (resEnt?.Sucesso == true && resEnt.Dados != null)
        {
            Entregadores = resEnt.Dados.Where(e => e.Ativo).ToList();
        }

        CarregandoGeral = false;
    }

    private string? ProximoStatus()
    {
        if (Pedido == null) return null;
        if (Pedido.TipoPedido == "ENTREGA" && Pedido.Status == "PRONTO" && string.IsNullOrEmpty(Pedido.EntregadorId))
            return null; // Bloqueia PRONTO → DESPACHADO sem entregador
        return TransicoesStatus.GetValueOrDefault(Pedido.Status);
    }

    private bool PodeConverterEmVenda()
    {
        if (Pedido == null) return false;
        return Pedido.Status is "ACEITO" or "PREPARANDO" or "PRONTO" or "DESPACHADO";
    }

    private async Task AvancarStatus()
    {
        if (Pedido == null) return;
        var proximo = ProximoStatus();
        if (proximo == null) return;

        // Verificar entregador para DESPACHADO
        if (proximo == "DESPACHADO" && Pedido.TipoPedido == "ENTREGA" && string.IsNullOrEmpty(Pedido.EntregadorId))
        {
            MensagemErro = "Defina um entregador antes de despachar o pedido.";
            return;
        }

        Processando = true;
        MensagemErro = null;
        MensagemSucesso = null;

        var req = new AtualizarStatusDeliveryReq(DeliveryId, proximo, UsuarioId);
        var res = await Tauri.InvocarAsync<RespostaBase<string>>("atualizar_status_delivery", new { dto = req });

        if (res?.Sucesso == true)
        {
            MensagemSucesso = $"Status atualizado para {proximo}.";
            await CarregarDados();
        }
        else
        {
            MensagemErro = res?.Mensagem ?? "Erro ao atualizar status.";
        }
        Processando = false;
    }

    private async Task AceitarPedido()
    {
        Processando = true;
        MensagemErro = null;
        var req = new AceitarPedidoReq(DeliveryId, SessaoCaixaId);
        var res = await Tauri.InvocarAsync<RespostaBase<string>>("aceitar_pedido_online", new { dto = req });
        if (res?.Sucesso == true)
        {
            MensagemSucesso = "Pedido aceito.";
            await CarregarDados();
        }
        else
        {
            MensagemErro = res?.Mensagem ?? "Erro ao aceitar pedido.";
        }
        Processando = false;
    }

    private async Task RecusarPedido()
    {
        if (Pedido == null || string.IsNullOrWhiteSpace(MotivoRecusa)) return;
        Processando = true;
        ErroRecusa = null;

        var req = new RecusarPedidoReq(DeliveryId, MotivoRecusa, UsuarioId);
        var res = await Tauri.InvocarAsync<RespostaBase<string>>("recusar_pedido_online", new { dto = req });

        if (res?.Sucesso == true)
        {
            ExibirModalRecusa = false;
            await OnVoltar.InvokeAsync();
        }
        else
        {
            ErroRecusa = res?.Mensagem ?? "Erro ao recusar pedido.";
        }
        Processando = false;
    }

    private async Task DefinirEntregador()
    {
        if (string.IsNullOrEmpty(EntregadorSelecionado)) return;
        Processando = true;
        MensagemErro = null;

        var req = new DefinirEntregadorReq(DeliveryId, EntregadorSelecionado, UsuarioId);
        var res = await Tauri.InvocarAsync<RespostaBase<string>>("definir_entregador", new { dto = req });

        if (res?.Sucesso == true)
        {
            MensagemSucesso = "Entregador definido com sucesso.";
            await CarregarDados();
        }
        else
        {
            MensagemErro = res?.Mensagem ?? "Erro ao definir entregador.";
        }
        Processando = false;
    }

    private async Task AdicionarItem()
    {
        if (string.IsNullOrWhiteSpace(BuscaCodigo) || Pedido == null) return;
        Processando = true;
        MensagemErro = null;

        var resProd = await Tauri.InvocarAsync<RespostaBase<ProdutoPdvResp?>>("buscar_produto_pdv", new { codigo = BuscaCodigo });
        if (resProd?.Sucesso == true && resProd.Dados != null)
        {
            var prod = resProd.Dados;
            long qtdEscala3 = (long)Math.Round(BuscaQtd * 1000m);

            var req = new AdicionarItemDeliveryReq(
                delivery_id: DeliveryId,
                produto_id: prod.ProdutoId,
                descricao_produto: prod.Nome,
                codigo_produto: prod.Codigo,
                quantidade_escala3: qtdEscala3,
                preco_unitario_minor: prod.PrecoVendaMinor,
                desconto_item_minor: 0,
                acrescimo_item_minor: 0,
                observacao_producao: null,
                local_producao_id: null,
                usuario_id: UsuarioId
            );

            var res = await Tauri.InvocarAsync<RespostaBase<string>>("adicionar_item_delivery", new { dto = req });
            if (res?.Sucesso == true)
            {
                BuscaCodigo = "";
                BuscaQtd = 1m;
                await CarregarDados();
            }
            else
            {
                MensagemErro = res?.Mensagem ?? "Erro ao adicionar item.";
            }
        }
        else
        {
            MensagemErro = "Produto não encontrado.";
        }
        Processando = false;
    }

    private void PrepararCancelamento(DeliveryItemResp item)
    {
        ItemParaCancelar = item;
        MotivoCancelamento = "";
        ErroCancelamento = null;
    }

    private async Task ConfirmarCancelamento()
    {
        if (ItemParaCancelar == null || string.IsNullOrWhiteSpace(MotivoCancelamento))
        {
            ErroCancelamento = "Motivo é obrigatório.";
            return;
        }
        Processando = true;
        ErroCancelamento = null;

        var req = new CancelarItemDeliveryReq(ItemParaCancelar.Id, MotivoCancelamento, UsuarioId, null, null);
        var res = await Tauri.InvocarAsync<RespostaBase<string>>("cancelar_item_delivery", new { dto = req });

        if (res?.Sucesso == true)
        {
            ItemParaCancelar = null;
            await CarregarDados();
        }
        else
        {
            ErroCancelamento = res?.Mensagem ?? "Erro ao cancelar item.";
        }
        Processando = false;
    }

    private async Task FecharEmVenda()
    {
        Processando = true;
        MensagemErro = null;

        var req = new FecharEmVendaReq(DeliveryId, SessaoCaixaId, UsuarioId, "DELIVERY");
        var res = await Tauri.InvocarAsync<RespostaBase<FechamentoEmVendaResp>>("fechar_delivery_em_venda", new { dto = req });

        if (res?.Sucesso == true)
        {
            // Venda criada como EM_ANDAMENTO. O numero_venda só é gerado ao finalizar o pagamento no caixa.
            Nav.NavigateTo("/pdv");
        }
        else
        {
            MensagemErro = res?.Mensagem ?? "Erro ao fechar pedido.";
            Processando = false;
        }
    }

    private string FormatarValor(long minor) => (minor / 100m).ToString("C2", new CultureInfo("pt-BR"));
    private string FormatarQtd(long qtdEscala3) => (qtdEscala3 / 1000m).ToString("0.###", CultureInfo.InvariantCulture);
}
