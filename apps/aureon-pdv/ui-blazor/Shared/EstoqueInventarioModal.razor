@using AureonPdvUi.Services
@inject TauriService Tauri
@inject IJSRuntime JSRuntime

<div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    Lançamento de Inventário
                </h5>
                <button type="button" class="btn-close" @onclick="() => OnClose.InvokeAsync(false)"></button>
            </div>
            <div class="modal-body">
                @if (mensagemErro != null)
                {
                    <div class="alert alert-danger">@mensagemErro</div>
                }

                <div class="alert alert-info">
                    <strong>Dica:</strong> Informe o <strong>Saldo Real</strong> conferido no estoque físico. 
                    Se não preencher ou deixar em branco, o produto não será ajustado. O sistema calculará o delta (+/-) automaticamente.
                </div>

                <div class="mb-3">
                    <label class="form-label">Motivo do Inventário (Opcional)</label>
                    <input type="text" class="form-control" @bind="motivo" placeholder="Ex: Contagem Semanal, Balanço Anual..." />
                </div>

                <table class="table table-sm table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Código</th>
                            <th>Descrição</th>
                            <th class="text-end">Saldo no Sistema</th>
                            <th style="width: 200px;">Novo Saldo Real</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var prod in Produtos)
                        {
                            <tr>
                                <td>@prod.Codigo</td>
                                <td>@prod.Descricao</td>
                                <td class="text-end text-muted">
                                    @(Math.Round(prod.QuantidadeEscala3 / 1000m, 3).ToString("N3"))
                                </td>
                                <td>
                                    <input type="number" 
                                           class="form-control text-end" 
                                           step="0.001" 
                                           @bind="contagens[prod.ProdutoId]" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="() => OnClose.InvokeAsync(false)" disabled="@salvando">Cancelar</button>
                <button class="btn btn-primary" @onclick="Confirmar" disabled="@salvando">
                    @if (salvando)
                    {
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span class="ms-2">Processando...</span>
                    }
                    else
                    {
                        <span>Gravar Inventário</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<EstoqueSaldoResp> Produtos { get; set; } = new();

    [Parameter]
    public EventCallback<bool> OnClose { get; set; }

    private string motivo = "";
    private string? mensagemErro;
    private bool salvando = false;

    // Dicionário para armazenar o input do usuário (nullable decimal para aceitar vazio)
    private Dictionary<string, decimal?> contagens = new();

    protected override void OnInitialized()
    {
        // Inicializar todas as contagens como null
        foreach (var p in Produtos)
        {
            contagens[p.ProdutoId] = null;
        }
    }

    private async Task Confirmar()
    {
        mensagemErro = null;

        var itensParaEnviar = new List<ContagemInventario>();

        foreach (var kvp in contagens)
        {
            if (kvp.Value.HasValue)
            {
                // Se preencheu valor, converte pra escala 3
                long qtdEscala3 = (long)Math.Round(kvp.Value.Value * 1000m);
                itensParaEnviar.Add(new ContagemInventario(kvp.Key, qtdEscala3));
            }
        }

        if (!itensParaEnviar.Any())
        {
            mensagemErro = "Nenhum saldo informado. Preencha pelo menos um produto para gerar o inventário.";
            return;
        }

        salvando = true;

        try
        {
            var req = new InventarioEstoqueReq(
                idempotency_key: Guid.NewGuid().ToString(),
                contagens: itensParaEnviar,
                motivo: string.IsNullOrWhiteSpace(motivo) ? null : motivo,
                usuario_id: "SISTEMA"
            );

            var resp = await Tauri.InvocarAsync<RespostaBase<bool>>("registrar_inventario", new { dto = req });

            if (resp.Sucesso)
            {
                await OnClose.InvokeAsync(true);
            }
            else
            {
                mensagemErro = resp.Mensagem;
            }
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro ao salvar inventário: {ex.Message}";
        }
        finally
        {
            salvando = false;
        }
    }
}
