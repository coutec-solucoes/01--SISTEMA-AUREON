@inject TauriService Tauri
@inject NotificationService Toast

<div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(IsEdicao ? "Editar Usuário" : "Novo Usuário")</h5>
                <button type="button" class="btn-close" @onclick="OnClose"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Nome Completo</label>
                    <input class="form-control" @bind="Nome" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Login</label>
                    <input class="form-control" @bind="Login" disabled="@IsEdicao" />
                </div>
                
                @if (!IsEdicao)
                {
                    <div class="mb-3">
                        <label class="form-label">Senha Inicial</label>
                        <input type="password" class="form-control" @bind="Senha" />
                        <div class="form-text">Mínimo 8 caracteres.</div>
                    </div>
                }

                <div class="mb-3 form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" id="ativoSwitch" @bind="Ativo">
                    <label class="form-check-label" for="ativoSwitch">Usuário Ativo</label>
                </div>

                @if (!IsEdicao)
                {
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="exigeTrocaSenha" @bind="ExigeTrocaSenha" />
                        <label class="form-check-label" for="exigeTrocaSenha">Exigir troca de senha no primeiro login</label>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Perfis (Códigos separados por vírgula)</label>
                    <input class="form-control" @bind="PerfisStr" placeholder="Ex: ADMIN, OPERADOR" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="OnClose">Cancelar</button>
                <button type="button" class="btn btn-primary" @onclick="Salvar">Salvar</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public UsuarioLocalResp? UsuarioEdicao { get; set; }

    private bool IsEdicao => UsuarioEdicao != null;

    private string Nome { get; set; } = "";
    private string Login { get; set; } = "";
    private string Senha { get; set; } = "";
    private bool Ativo { get; set; } = true;
    private bool ExigeTrocaSenha { get; set; } = true;
    private string PerfisStr { get; set; } = "";

    protected override void OnInitialized()
    {
        if (IsEdicao && UsuarioEdicao != null)
        {
            Nome = UsuarioEdicao.Nome;
            Login = UsuarioEdicao.Login;
            Ativo = UsuarioEdicao.Ativo;
            // Perfis seria legal vir do BD, mas simplificaremos via text aqui.
        }
    }

    private async Task Salvar()
    {
        try
        {
            var perfisList = string.IsNullOrWhiteSpace(PerfisStr) 
                ? new List<string>() 
                : PerfisStr.Split(',').Select(s => s.Trim()).ToList();

            UsuarioOperacaoResp resp;

            if (IsEdicao)
            {
                var req = new EditarUsuarioLocalReq(UsuarioEdicao!.Id, Nome, Ativo, perfisList);
                resp = await Tauri.InvocarAsync<UsuarioOperacaoResp>("editar_usuario_local", req);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(Senha) || Senha.Length < 8)
                {
                    Toast.ShowError("Senha inicial deve ter no mínimo 8 caracteres.");
                    return;
                }

                var req = new CriarUsuarioLocalReq(Nome, Login, Senha, perfisList, Ativo, ExigeTrocaSenha);
                resp = await Tauri.InvocarAsync<UsuarioOperacaoResp>("criar_usuario_local", req);
            }

            // LIMPAR MEMÓRIA LOGO APÓS O USO
            Senha = "";

            if (resp != null && resp.Sucesso)
            {
                Toast.ShowSuccess(resp.Mensagem);
                await OnSaved.InvokeAsync();
            }
            else
            {
                Toast.ShowError(resp?.Mensagem ?? "Erro desconhecido ao salvar usuário.");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError("Falha na comunicação: " + ex.Message);
        }
    }
}
