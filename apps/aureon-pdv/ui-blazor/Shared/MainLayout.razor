@inherits LayoutComponentBase

<div class="layout-principal">

    <!-- Cabeçalho -->
    <header class="cabecalho">
        <div style="display: flex; align-items: center; gap: 24px;">
            <div class="cabecalho-logo">⚡ AUREON PDV</div>
            <nav style="display: flex; gap: 16px; font-size: 14px; font-weight: 500;">
                <a href="/" style="color: white; text-decoration: none; opacity: 0.8;">Home</a>
                <a href="/dashboard" style="color: #00bcd4; text-decoration: none; font-weight: 600;">Dashboard</a>
                <a href="/relatorios" style="color: #ffb74d; text-decoration: none; font-weight: 600;">Relatórios</a>
                <a href="/caixa" style="color: white; text-decoration: none; opacity: 0.8;">Caixa</a>
                <a href="/pdv" style="color: #00e676; text-decoration: none; font-weight: 600;">PDV</a>
                <a href="/gourmet" style="color: #ff9800; text-decoration: none; font-weight: 600;">Gourmet</a>
                <a href="/delivery" style="color: #29b6f6; text-decoration: none; font-weight: 600;">Delivery</a>
                <a href="/estoque" style="color: #ffca28; text-decoration: none; font-weight: 600;">Estoque</a>
                <a href="/compras" style="color: #ab47bc; text-decoration: none; font-weight: 600;">Compras</a>
                <a href="/financeiro/contas-pagar" style="color: #ef5350; text-decoration: none; font-weight: 600;">A Pagar</a>
                <a href="/financeiro/contas-receber" style="color: #66bb6a; text-decoration: none; font-weight: 600;">A Receber</a>
                <a href="/financeiro/lancamentos" style="color: #26a69a; text-decoration: none; font-weight: 600;">Lançamentos</a>
                <a href="/reimpressoes" style="color: #f48fb1; text-decoration: none; font-weight: 600;">Impressão</a>
                
                <!-- Menu Fiscal Estrutural -->
                <div style="display: flex; gap: 8px; margin-left: 10px; border-left: 1px solid #555; padding-left: 10px;">
                    <a href="/fiscal/configuracoes" style="color: #ef9a9a; text-decoration: none; font-weight: 600;">Config. Fiscal</a>
                    <a href="/fiscal/dicionarios" style="color: #ef9a9a; text-decoration: none; font-weight: 600;">Dic. Fiscal</a>
                    <a href="/fiscal/regras" style="color: #ef9a9a; text-decoration: none; font-weight: 600;">Regras Fiscais</a>
                    <a href="/fiscal/sync" style="color: #ce93d8; text-decoration: none; font-weight: 600;">Sync Fiscal</a>
                </div>

                <!-- Menu Sistema/Licenciamento -->
                <div style="display: flex; gap: 8px; margin-left: 10px; border-left: 1px solid #555; padding-left: 10px;">
                    <a href="/licenca" style="color: #fff176; text-decoration: none; font-weight: 600;">Licença</a>
                    <a href="/backup" style="color: #80cbc4; text-decoration: none; font-weight: 600;">Backup</a>
                </div>
            </nav>
        </div>
        <div class="cabecalho-status">
            <span class="dot-status @(_sistemaOk ? "" : "erro")"></span>
            <span>@_statusTexto</span>
        </div>
    </header>

    <!-- Conteúdo da página -->
    <main class="conteudo">
        @Body
    </main>

</div>

@code {
    private bool _sistemaOk = true;
    private string _statusTexto = "Sistema iniciando...";

    protected override async Task OnInitializedAsync()
    {
        // Aguarda um breve momento para o Tauri inicializar
        await Task.Delay(300);
        _statusTexto = "Operacional";
        _sistemaOk   = true;
    }
}
