@using AureonPdvUi.Services
@inject TauriService Tauri

<div class="modal-overlay">
    <div class="modal-content card" style="max-width: 600px; width: 100%;">
        <div class="modal-header d-flex justify-content-between align-items-center mb-3">
            <h4 class="m-0 text-primary">Registrar Compra Manual</h4>
            <button type="button" class="btn-close btn-close-white" @onclick="Fechar"></button>
        </div>

        @if (erro != null)
        {
            <div class="alert alert-danger">@erro</div>
        }

        <div class="modal-body" style="max-height: 70vh; overflow-y: auto;">
            <!-- 1. Busca de Fornecedor -->
            <div class="mb-3">
                <label class="form-label fw-bold">Fornecedor <span class="text-danger">*</span></label>
                @if (fornecedorSelecionado == null)
                {
                    <div class="input-group mb-2">
                        <input type="text" class="form-control" placeholder="Buscar fornecedor por nome ou documento..."
                               @bind="buscaFornecedor" @bind:event="oninput" @onkeyup="AoDigitarFornecedor" />
                        <button class="btn btn-outline-secondary" @onclick="PesquisarFornecedores" type="button">Buscar</button>
                    </div>

                    @if (carregandoFornecedores)
                    {
                        <p class="text-muted small"><em>Buscando fornecedores...</em></p>
                    }
                    else if (fornecedoresEncontrados != null)
                    {
                        @if (fornecedoresEncontrados.Count == 0)
                        {
                            <p class="text-warning small">Nenhum fornecedor ativo encontrado.</p>
                        }
                        else
                        {
                            <div class="list-group mb-3" style="max-height: 150px; overflow-y: auto;">
                                @foreach (var f in fornecedoresEncontrados)
                                {
                                    <button type="button" class="list-group-item list-group-item-action py-1 px-2 small"
                                            @onclick="() => SelecionarFornecedor(f)">
                                        <strong>@f.Nome</strong> @(string.IsNullOrEmpty(f.Documento) ? "" : $" - Doc: {f.Documento}")
                                    </button>
                                }
                            </div>
                        }
                    }
                }
                else
                {
                    <div class="alert alert-info py-2 d-flex justify-content-between align-items-center m-0">
                        <div>
                            <strong>@fornecedorSelecionado.Nome</strong>
                            @if (!string.IsNullOrEmpty(fornecedorSelecionado.Documento))
                            {
                                <span class="text-muted small ms-2">Doc: @fornecedorSelecionado.Documento</span>
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-danger py-0 px-2" @onclick="LimparFornecedor">Alterar</button>
                    </div>
                }
            </div>

            <div class="row">
                <!-- Moeda -->
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Moeda <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="moedaCodigo" @bind:after="AoMudarMoeda">
                        <option value="BRL">BRL (R$)</option>
                        <option value="USD">USD ($)</option>
                        <option value="EUR">EUR (€)</option>
                    </select>
                </div>

                <!-- Taxa de Câmbio -->
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Taxa de Câmbio (escala 6)</label>
                    <input type="number" class="form-control" step="0.000001" min="0.000001"
                           @bind="taxaCambio" disabled="@(moedaCodigo == "BRL")" />
                </div>
            </div>

            <div class="row">
                <!-- Número da Nota -->
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Número da Nota</label>
                    <input type="text" class="form-control" placeholder="Ex: 000123" @bind="numeroNota" />
                </div>

                <!-- Série -->
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Série</label>
                    <input type="text" class="form-control" placeholder="Ex: 1" @bind="serie" />
                </div>
            </div>

            <!-- Chave de Acesso XML -->
            <div class="mb-3">
                <label class="form-label fw-bold">Chave de Acesso XML Fiscal</label>
                <input type="text" class="form-control" placeholder="Chave de 44 dígitos" @bind="chaveAcessoXmlFiscal" />
            </div>

            <!-- Observações -->
            <div class="mb-3">
                <label class="form-label fw-bold">Observações</label>
                <textarea class="form-control" rows="2" placeholder="Informações adicionais..." @bind="observacao"></textarea>
            </div>
        </div>

        <div class="modal-footer d-flex gap-2 justify-content-end mt-3">
            <button type="button" class="btn btn-secondary" @onclick="Fechar">Cancelar</button>
            <button type="button" class="btn btn-primary" @onclick="Confirmar" 
                    disabled="@(fornecedorSelecionado == null || processando)">
                @if (processando)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                Iniciar Compra
            </button>
        </div>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.6);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .modal-content {
        background: #1e1e2d !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px;
        color: #ffffff;
        padding: 20px;
    }
    .form-control, .form-select {
        background-color: #151521 !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #ffffff !important;
    }
    .form-control:focus, .form-select:focus {
        border-color: #ab47bc !important;
        box-shadow: 0 0 0 0.25rem rgba(171, 71, 188, 0.25) !important;
    }
    .list-group-item {
        background-color: #151521 !important;
        color: #ffffff !important;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
    }
    .list-group-item:hover {
        background-color: #2b2b40 !important;
        color: #ffffff !important;
    }
</style>

@code {
    [Parameter] public EventCallback OnFechar { get; set; }
    [Parameter] public EventCallback<CompraResp> OnSucesso { get; set; }

    private string buscaFornecedor = "";
    private List<FornecedorResp>? fornecedoresEncontrados;
    private FornecedorResp? fornecedorSelecionado;
    private bool carregandoFornecedores = false;

    private string moedaCodigo = "BRL";
    private decimal taxaCambio = 1.0m;
    private string? numeroNota;
    private string? serie;
    private string? chaveAcessoXmlFiscal;
    private string? observacao;

    private bool processando = false;
    private string? erro;

    private async Task AoDigitarFornecedor(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await PesquisarFornecedores();
        }
    }

    private async Task PesquisarFornecedores()
    {
        if (string.IsNullOrWhiteSpace(buscaFornecedor))
        {
            fornecedoresEncontrados = null;
            return;
        }

        carregandoFornecedores = true;
        erro = null;
        try
        {
            var resp = await Tauri.InvocarAsync<RespostaBase<List<FornecedorResp>>>("buscar_fornecedores_compra", new { busca = buscaFornecedor });
            if (resp.Sucesso && resp.Dados != null)
            {
                fornecedoresEncontrados = resp.Dados;
            }
            else
            {
                erro = resp.Mensagem;
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro ao buscar fornecedores: {ex.Message}";
        }
        finally
        {
            carregandoFornecedores = false;
        }
    }

    private void SelecionarFornecedor(FornecedorResp f)
    {
        fornecedorSelecionado = f;
        fornecedoresEncontrados = null;
    }

    private void LimparFornecedor()
    {
        fornecedorSelecionado = null;
        buscaFornecedor = "";
    }

    private void AoMudarMoeda()
    {
        if (moedaCodigo == "BRL")
        {
            taxaCambio = 1.0m;
        }
        else if (taxaCambio == 1.0m)
        {
            taxaCambio = 5.0m; // Sugestão base inicial
        }
    }

    private async Task Confirmar()
    {
        if (fornecedorSelecionado == null)
        {
            erro = "É necessário selecionar um fornecedor.";
            return;
        }

        processando = true;
        erro = null;

        try
        {
            long taxaEscala6 = (long)Math.Round(taxaCambio * 1000000m);

            var req = new IniciarCompraReq(
                fornecedor_id: fornecedorSelecionado.Id,
                numero_nota: string.IsNullOrWhiteSpace(numeroNota) ? null : numeroNota,
                serie: string.IsNullOrWhiteSpace(serie) ? null : serie,
                chave_acesso_xml_fiscal: string.IsNullOrWhiteSpace(chaveAcessoXmlFiscal) ? null : chaveAcessoXmlFiscal,
                data_emissao: DateTime.UtcNow.ToString("yyyy-MM-dd"), // data emissao simplificada de hoje
                moeda_codigo: moedaCodigo,
                taxa_cambio_escala6: taxaEscala6,
                observacao: string.IsNullOrWhiteSpace(observacao) ? null : observacao,
                usuario_id: "USR-001" // usuario fixo
            );

            var resp = await Tauri.InvocarAsync<RespostaBase<CompraResp>>("iniciar_compra", new { dto = req });
            if (resp.Sucesso && resp.Dados != null)
            {
                await OnSucesso.InvokeAsync(resp.Dados);
            }
            else
            {
                erro = resp.Mensagem ?? "Erro ao iniciar compra.";
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro de comunicação: {ex.Message}";
        }
        finally
        {
            processando = false;
        }
    }

    private async Task Fechar()
    {
        await OnFechar.InvokeAsync();
    }
}
