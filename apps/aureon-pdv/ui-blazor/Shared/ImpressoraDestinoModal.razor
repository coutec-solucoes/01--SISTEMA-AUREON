@using AureonPdvUi.Services

@if (Show)
{
    <div class="modal-overlay" style="display:block; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:9999;">
        <div class="modal-content" style="position:absolute; top:50%; left:50%; transform:translate(-50%, -50%); background:#1e1e2d; padding:20px; border-radius:8px; width:500px; color:white; box-shadow: 0 4px 15px rgba(0,0,0,0.5);">
            <h3 style="margin-top:0; color:#f48fb1; border-bottom:1px solid #444; padding-bottom:10px;">Configurar Impressora</h3>

            @if (!string.IsNullOrEmpty(Erro))
            {
                <div style="background:#ef5350; color:white; padding:10px; border-radius:4px; margin-bottom:15px; font-weight:bold;">
                    @Erro
                </div>
            }

            <div style="margin-bottom: 10px;">
                <label style="display:block; margin-bottom:5px; font-weight:600;">Nome / Identificador</label>
                <input @bind="Destino.Nome" type="text" style="width:100%; padding:8px; background:#2a2a3c; color:white; border:1px solid #444; border-radius:4px; outline:none;" />
            </div>

            <div style="margin-bottom: 10px;">
                <label style="display:block; margin-bottom:5px; font-weight:600;">Tipo de Destino</label>
                <select @bind="Destino.TipoDestino" style="width:100%; padding:8px; background:#2a2a3c; color:white; border:1px solid #444; border-radius:4px; outline:none;">
                    <option value="@TipoDestinoImpressao.SIMULADOR">Simulador (Arquivo TXT)</option>
                    <option value="@TipoDestinoImpressao.TCP_IP">Rede (TCP/IP)</option>
                    <option value="@TipoDestinoImpressao.WINDOWS_RAW">Windows Spooler (RAW)</option>
                </select>
            </div>

            @if (Destino.TipoDestino == TipoDestinoImpressao.TCP_IP)
            {
                <div style="display:flex; gap:10px; margin-bottom: 10px;">
                    <div style="flex:2;">
                        <label style="display:block; margin-bottom:5px; font-weight:600;">Endereço IP</label>
                        <input @bind="Destino.EnderecoIp" type="text" placeholder="192.168.0.100" style="width:100%; padding:8px; background:#2a2a3c; color:white; border:1px solid #444; border-radius:4px; outline:none;" />
                    </div>
                    <div style="flex:1;">
                        <label style="display:block; margin-bottom:5px; font-weight:600;">Porta</label>
                        <input @bind="Destino.Porta" type="number" style="width:100%; padding:8px; background:#2a2a3c; color:white; border:1px solid #444; border-radius:4px; outline:none;" />
                    </div>
                </div>
            }
            else if (Destino.TipoDestino == TipoDestinoImpressao.WINDOWS_RAW)
            {
                <div style="margin-bottom: 10px;">
                    <label style="display:block; margin-bottom:5px; font-weight:600;">Nome do Spooler no Windows</label>
                    <input @bind="Destino.NomeSpooler" type="text" placeholder="Ex: Impressora_Caixa_01" style="width:100%; padding:8px; background:#2a2a3c; color:white; border:1px solid #444; border-radius:4px; outline:none;" />
                </div>
            }
            else if (Destino.TipoDestino == TipoDestinoImpressao.SIMULADOR)
            {
                <div style="margin-bottom: 10px;">
                    <label style="display:block; margin-bottom:5px; font-weight:600;">Caminho Opcional (Usa temp se vazio)</label>
                    <input @bind="Destino.CaminhoSimulador" type="text" placeholder="C:\temp\aureon_cupom.txt" style="width:100%; padding:8px; background:#2a2a3c; color:white; border:1px solid #444; border-radius:4px; outline:none;" />
                </div>
            }

            <div style="margin-bottom: 15px;">
                <label style="display:block; margin-bottom:5px; font-weight:600;">Largura da Bobina</label>
                <select @bind="Destino.LarguraColunas" style="width:100%; padding:8px; background:#2a2a3c; color:white; border:1px solid #444; border-radius:4px; outline:none;">
                    <option value="32">32 Colunas (Ex: 58mm)</option>
                    <option value="42">42 Colunas</option>
                    <option value="48">48 Colunas (Ex: 80mm)</option>
                </select>
            </div>

            <div style="display:flex; gap:20px; margin-bottom:25px; padding:10px; background:#2a2a3c; border-radius:4px;">
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                    <input type="checkbox" @bind="Destino.CortarPapel" style="width:18px; height:18px;" /> 
                    <span>Cortar Papel no Final</span>
                </label>
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                    <input type="checkbox" @bind="Destino.AbrirGaveta" style="width:18px; height:18px;" /> 
                    <span>Acionar Gaveta</span>
                </label>
            </div>

            <div style="display:flex; justify-content:flex-end; gap:10px; border-top:1px solid #444; padding-top:15px;">
                <button @onclick="Cancelar" style="padding:10px 20px; background:#444; color:white; border:none; border-radius:4px; cursor:pointer; font-weight:bold;">Cancelar</button>
                <button @onclick="Salvar" style="padding:10px 20px; background:#f48fb1; color:#121212; border:none; border-radius:4px; cursor:pointer; font-weight:bold;">Aplicar Configuração</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public EventCallback<ImpressoraDestinoReq> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    public ImpressoraDestinoReq Destino { get; set; } = new()
    {
        Nome = "Aureon Print - Principal",
        TipoDestino = TipoDestinoImpressao.SIMULADOR,
        LarguraColunas = 48,
        CortarPapel = true,
        AbrirGaveta = false,
        Porta = 9100
    };

    private string Erro = "";

    private async Task Salvar()
    {
        Erro = "";
        
        if (Destino.TipoDestino == TipoDestinoImpressao.TCP_IP)
        {
            if (string.IsNullOrWhiteSpace(Destino.EnderecoIp))
            {
                Erro = "Para rede TCP/IP, o endereço IP é obrigatório.";
                return;
            }
            if (Destino.Porta == null || Destino.Porta <= 0)
            {
                Erro = "A Porta é inválida.";
                return;
            }
        }
        
        if (Destino.LarguraColunas != 32 && Destino.LarguraColunas != 42 && Destino.LarguraColunas != 48)
        {
            Erro = "A largura das colunas deve ser obrigatoriamente 32, 42 ou 48.";
            return;
        }

        await OnSave.InvokeAsync(Destino);
    }

    private async Task Cancelar()
    {
        Erro = "";
        await OnCancel.InvokeAsync();
    }
}
