@inject TauriService Tauri
@inject NotificationService Toast

<div class="modal fade show" style="display: block; background: rgba(0,0,0,0.5);" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Redefinir Senha do Usuário</h5>
                <button type="button" class="btn-close" @onclick="OnClose"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Nova Senha</label>
                    <input type="password" class="form-control" @bind="NovaSenha" />
                    <div class="form-text">Mínimo 8 caracteres.</div>
                </div>
                
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="exigeTrocaSenha" @bind="ExigeTrocaSenha" />
                    <label class="form-check-label" for="exigeTrocaSenha">Exigir que o usuário troque a senha no próximo login</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" @onclick="OnClose">Cancelar</button>
                <button type="button" class="btn btn-warning" @onclick="Salvar">Redefinir</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public string UsuarioId { get; set; } = "";

    private string NovaSenha { get; set; } = "";
    private bool ExigeTrocaSenha { get; set; } = true;

    private async Task Salvar()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(NovaSenha) || NovaSenha.Length < 8)
            {
                Toast.ShowError("A nova senha deve ter no mínimo 8 caracteres.");
                return;
            }

            var req = new RedefinirSenhaUsuarioReq(UsuarioId, NovaSenha, ExigeTrocaSenha);
            var resp = await Tauri.InvokeAsync<UsuarioOperacaoResp>("redefinir_senha_usuario", new { req });

            // LIMPAR DADOS SENSÍVEIS LOGO APÓS ENVIO
            NovaSenha = "";

            if (resp != null && resp.Sucesso)
            {
                Toast.ShowSuccess(resp.Mensagem);
                await OnSaved.InvokeAsync();
            }
            else
            {
                Toast.ShowError(resp?.Mensagem ?? "Falha ao redefinir senha.");
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError("Falha na comunicação: " + ex.Message);
        }
    }
}
