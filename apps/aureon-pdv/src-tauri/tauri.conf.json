{
  "productName": "Aureon PDV",
  "version": "0.0.1",
  "identifier": "com.aureon.pdv",
  "build": {
    "frontendDist": "..\\ui-blazor\\bin\\Release\\net8.0\\browser-wasm\\AppBundle",
    "devUrl": "http://localhost:5172",
    "beforeDevCommand": "",
    "beforeBuildCommand": "dotnet publish ..\\ui-blazor\\aureon-pdv-ui.csproj -c Release"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Aureon PDV",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; wasm-src 'self' blob:; connect-src 'self' http://localhost:7070"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
