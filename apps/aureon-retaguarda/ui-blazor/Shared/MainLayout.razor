@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthService AuthService

<AuthorizeView>
    <Authorized>
        <div class="layout-principal">
            <aside class="sidebar">
                <div class="sidebar-logo">
                    <span>⚡</span> AUREON GESTOR
                </div>

                <ul class="sidebar-menu">
                    <li class="sidebar-item @(IsActive("/") ? "ativo" : "")">
                        <a href="/">
                            <span>📊</span> Dashboard
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/configuracoes/empresa") ? "ativo" : "")">
                        <a href="/configuracoes/empresa">
                            <span>⚙️</span> Empresa & Moedas
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/configuracoes/operacionais") ? "ativo" : "")">
                        <a href="/configuracoes/operacionais/pdv">
                            <span>🛠️</span> Configurações Operacionais
                        </a>
                    </li>

                    <div class="sidebar-header" style="padding: 16px 24px 8px; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--cor-texto-disabled); font-weight: 600; margin-top: 16px;">
                        Sincronização
                    </div>
                    <li class="sidebar-item @(IsActive("/configuracoes/sync/terminais") ? "ativo" : "")">
                        <a href="/configuracoes/sync/terminais">
                            <span>🖥️</span> Status dos Terminais
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/configuracoes/sync/publicacao") ? "ativo" : "")">
                        <a href="/configuracoes/sync/publicacao">
                            <span>📤</span> Publicação de Dados
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/configuracoes/sync/logs") ? "ativo" : "")">
                        <a href="/configuracoes/sync/logs">
                            <span>📋</span> Logs de Sync
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/configuracoes/sync/diagnostico") ? "ativo" : "")">
                        <a href="/configuracoes/sync/diagnostico">
                            <span>🔍</span> Diagnóstico de Sync
                        </a>
                    </li>

                    <div class="sidebar-header" style="padding: 16px 24px 8px; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--cor-texto-disabled); font-weight: 600; margin-top: 16px;">
                        Cadastros
                    </div>
                    
                    <li class="sidebar-item @(IsActive("/cadastros/pessoas") || IsActive("/cadastros/clientes") || IsActive("/cadastros/fornecedores") || IsActive("/cadastros/funcionarios") || IsActive("/cadastros/vendedores") || IsActive("/cadastros/entregadores") || IsActive("/cadastros/transportadoras") ? "ativo" : "")">
                        <a href="/cadastros/pessoas">
                            <span>👥</span> Pessoas & Papéis
                        </a>
                    </li>
                    
                    <li class="sidebar-item @(IsActive("/cadastros/produtos") ? "ativo" : "")">
                        <a href="/cadastros/produtos">
                            <span>📦</span> Produtos & Estruturas
                        </a>
                    </li>
                    
                    <div class="sidebar-header" style="padding: 16px 24px 8px; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--cor-texto-disabled); font-weight: 600; margin-top: 16px;">
                        Segurança
                    </div>
                    
                    <li class="sidebar-item @(IsActive("/seguranca/usuarios") ? "ativo" : "")">
                        <a href="/seguranca/usuarios">
                            <span>👥</span> Usuários
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/seguranca/perfis") ? "ativo" : "")">
                        <a href="/seguranca/perfis">
                            <span>🛡️</span> Perfis & Permissões
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/seguranca/supervisores") ? "ativo" : "")">
                        <a href="/seguranca/supervisores">
                            <span>🔑</span> Supervisores
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/seguranca/autorizacoes") ? "ativo" : "")">
                        <a href="/seguranca/autorizacoes">
                            <span>✅</span> Autorizações
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/seguranca/auditoria") ? "ativo" : "")">
                        <a href="/seguranca/auditoria">
                            <span>📋</span> Auditoria & Logs
                        </a>
                    </li>

                    <div class="sidebar-header" style="padding: 16px 24px 8px; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: var(--cor-texto-disabled); font-weight: 600; margin-top: 16px;">
                        Fiscal
                    </div>
                    <li class="sidebar-item @(IsActive("/fiscal") ? "ativo" : "")">
                        <a href="/fiscal">
                            <span>🧾</span> Fiscal Mestre
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/fiscal/dicionarios") ? "ativo" : "")">
                        <a href="/fiscal/dicionarios">
                            <span>📖</span> Dicionários Fiscais
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/fiscal/regras") ? "ativo" : "")">
                        <a href="/fiscal/regras">
                            <span>📐</span> Regras Tributárias
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/fiscal/configuracoes") ? "ativo" : "")">
                        <a href="/fiscal/configuracoes">
                            <span>⚙️</span> Config. Fiscal
                        </a>
                    </li>
                    <li class="sidebar-item @(IsActive("/fiscal/publicacao") ? "ativo" : "")">
                        <a href="/fiscal/publicacao">
                            <span>📤</span> Publicação Fiscal
                        </a>
                    </li>
                </ul>

                <div class="sidebar-footer">
                    <div style="margin-bottom: 12px; font-size: 12px; font-weight: bold; color: var(--cor-primaria);">
                        @context.User.Identity?.Name
                    </div>
                    <button class="btn btn-outline" style="width: 100%; padding: 8px; font-size: 12px;" @onclick="Sair">Sair</button>
                    <p style="margin-top: 16px;">Aureon Gestor © 2026</p>
                    <p style="font-size: 10px; margin-top: 4px; color: var(--cor-texto-disabled);">Versão 1.0.0 (Fase 3)</p>
                </div>
            </aside>

            <main class="conteudo-principal">
                @Body
            </main>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="layout-login-fullscreen">
            @Body
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool IsActive(string rota)
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        
        if (rota == "/")
        {
            return string.IsNullOrEmpty(uri);
        }
        
        return uri.StartsWith(rota.TrimStart('/'), StringComparison.OrdinalIgnoreCase);
    }

    private async Task Sair()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
