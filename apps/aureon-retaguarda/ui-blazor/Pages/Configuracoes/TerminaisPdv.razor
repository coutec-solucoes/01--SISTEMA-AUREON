@page "/configuracoes/operacionais/terminais"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Cadastro de Terminais — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Terminais PDV</h1>
        <p class="subtitulo-pagina">Cadastre e gerencie estações de trabalho, computadores do PDV e dispositivos móveis autorizados.</p>
    </div>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">
        <span>+</span> Novo Terminal
    </button>
</div>

<SubmenuOperacionais />

@if (carregando)
{
    <div class="loading-state fade-in">Carregando terminais operacionais cadastrados...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box fade-in">@erroGeral</div>
}
else
{
    <div class="card-glass fade-in" style="overflow-x: auto; padding: 0;">
        <table class="table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>IP / Rede</th>
                    <th>Caixa Padrão</th>
                    <th>Status</th>
                    <th>Autorização</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in terminais)
                {
                    <tr>
                        <td style="font-weight: bold; color: #fff;">@t.codigo_terminal</td>
                        <td>
                            <div>@t.nome_terminal</div>
                            @if (!string.IsNullOrEmpty(t.descricao))
                            {
                                <span style="font-size: 11px; color: var(--cor-texto-sub);">@t.descricao</span>
                            }
                        </td>
                        <td>
                            <span class="badge" style="background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1);">
                                @t.tipo_terminal
                            </span>
                        </td>
                        <td>@(string.IsNullOrEmpty(t.ip_rede_local) ? "-" : t.ip_rede_local)</td>
                        <td>@(string.IsNullOrEmpty(t.registradora_nome) ? "Nenhum" : t.registradora_nome)</td>
                        <td>
                            @if (t.ativo)
                            {
                                <span class="badge badge-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge badge-error">Inativo</span>
                            }
                        </td>
                        <td>
                            @if (t.autorizado)
                            {
                                <span class="badge badge-success" style="background: rgba(0,198,255,0.1); color: #00c6ff; border: 1px solid rgba(0,198,255,0.25);">Autorizado</span>
                            }
                            else
                            {
                                <span class="badge badge-error">Pendente</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <button class="btn btn-sm btn-outline" @onclick="() => AbrirModalEditar(t)">Editar</button>
                                @if (!t.autorizado)
                                {
                                    <button class="btn btn-sm btn-outline" style="border-color: rgba(0,198,255,0.3); color: #00c6ff;" @onclick="() => Autorizar(t.id)">Autorizar</button>
                                }
                                @if (t.ativo)
                                {
                                    <button class="btn btn-sm btn-outline btn-perigo-outline" @onclick="() => Inativar(t.id)">Inativar</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!terminais.Any())
                {
                    <tr>
                        <td colspan="8" style="text-align: center; color: var(--cor-texto-sub); padding: 48px;">
                            Nenhum terminal cadastrado.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal de Cadastro / Edição -->
@if (mostrarModal)
{
    <div class="modal-backdrop fade-in">
        <div class="modal-content card-glass" style="max-width: 600px; width: 90%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                <h2 class="modal-title" style="margin: 0; color: #fff;">
                    @(modalEditandoId == Guid.Empty ? "Cadastrar Terminal" : "Editar Terminal")
                </h2>
                <button style="background: none; border: none; color: var(--cor-texto-sub); font-size: 20px; cursor: pointer;" @onclick="FecharModal">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(erroModal))
            {
                <div class="alert-error-box" style="margin-bottom: 20px;">@erroModal</div>
            }

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Código do Terminal *</label>
                    <input type="text" class="form-control" @bind="model.codigo_terminal" placeholder="Ex: TERM01..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Nome do Terminal *</label>
                    <input type="text" class="form-control" @bind="model.nome_terminal" placeholder="Ex: Caixa Principal..." />
                </div>

                <div class="form-grupo" style="grid-column: span 12;">
                    <label>Descrição</label>
                    <input type="text" class="form-control" @bind="model.descricao" placeholder="Finalidade ou localização do terminal..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Tipo do Terminal</label>
                    <select class="form-control" @bind="model.tipo_terminal">
                        <option value="FIXO">Fixo (Computador/Balcão)</option>
                        <option value="MOBI">Móvel (Tablet/Smartphone)</option>
                        <option value="TOTEM">Autoatendimento (Totem)</option>
                    </select>
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>IP de Rede Local</label>
                    <input type="text" class="form-control" @bind="model.ip_rede_local" placeholder="Ex: 192.168.1.50..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Caixa / Registradora Vinculada</label>
                    <select class="form-control" @bind="model.registradora_id">
                        <option value="">Nenhum Caixa Vinculado</option>
                        @foreach (var r in registradoras)
                        {
                            <option value="@r.id.ToString()">@r.nome (@r.codigo)</option>
                        }
                    </select>
                </div>

                <div class="form-grupo" style="grid-column: span 6; justify-content: center; display: flex; flex-direction: column; margin-top: 14px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="model.ativo" />
                        <span>Terminal Ativo</span>
                    </label>
                </div>
            </div>

            <div class="modal-actions" style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-outline" @onclick="FecharModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Salvar">Salvar Registro</button>
            </div>
        </div>
    </div>
}

<style>
    .header-pagina { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .titulo-pagina { font-size: 30px; font-weight: 700; color: #fff; }
    .subtitulo-pagina { color: var(--cor-texto-sub); font-size: 14px; }
    
    .badge { font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-success { background: rgba(16,185,129,0.12); color: #38ef7d; border: 1px solid rgba(16,185,129,0.25); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ff4b2b; border: 1px solid rgba(239,68,68,0.25); }

    .btn-sm { padding: 4px 10px; font-size: 12px; border-radius: 6px; }
    .btn-outline { background: transparent; border: 1px solid var(--cor-borda); color: var(--cor-texto-sub); transition: all 0.2s ease; cursor: pointer; }
    .btn-outline:hover { background: rgba(255,255,255,0.05); color: #fff; border-color: rgba(255,255,255,0.2); }
    
    .btn-perigo-outline { border-color: rgba(255,75,43,0.3); color: #ff4b2b; }
    .btn-perigo-outline:hover { background: rgba(255,75,43,0.1); border-color: #ff4b2b; color: #fff; }

    .checkbox-premium {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--cor-borda);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .checkbox-premium:hover {
        background: rgba(0, 198, 255, 0.03);
        border-color: var(--cor-borda-glow);
    }
    .checkbox-premium input[type=checkbox] {
        width: 18px;
        height: 18px;
        accent-color: #00c6ff;
        cursor: pointer;
    }

    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1100; }
    
    .alert-error-box { background: rgba(255,75,43,0.1); color: #ff4b2b; border: 1px solid rgba(255,75,43,0.2); padding: 12px 16px; border-radius: 8px; font-size: 14px; }
    .loading-state { text-align: center; color: var(--cor-texto-sub); padding: 64px; font-size: 16px; }
</style>

@code {
    private bool carregando = true;
    private string? erroGeral, erroModal;

    private List<TerminalDto> terminais = new();
    private List<RegistradoraDto> registradoras = new();

    private bool mostrarModal = false;
    private Guid modalEditandoId = Guid.Empty;
    private TerminalInput model = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<List<TerminalDto>>>("/configuracoes/operacionais/terminais");
            if (res?.sucesso == true) terminais = res.dados ?? new();

            var resReg = await Http.GetFromJsonAsync<Resposta<List<RegistradoraDto>>>("/configuracoes/operacionais/registradoras");
            if (resReg?.sucesso == true) registradoras = resReg.dados ?? new();
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private void AbrirModalNovo()
    {
        modalEditandoId = Guid.Empty;
        model = new TerminalInput { tipo_terminal = "FIXO", ativo = true };
        erroModal = null;
        mostrarModal = true;
    }

    private void AbrirModalEditar(TerminalDto t)
    {
        modalEditandoId = t.id;
        model = new TerminalInput
        {
            codigo_terminal = t.codigo_terminal,
            nome_terminal = t.nome_terminal,
            descricao = t.descricao,
            tipo_terminal = t.tipo_terminal,
            ip_rede_local = t.ip_rede_local,
            registradora_id = t.registradora_id?.ToString(),
            ativo = t.ativo
        };
        erroModal = null;
        mostrarModal = true;
    }

    private async Task Salvar()
    {
        erroModal = null;
        if (string.IsNullOrWhiteSpace(model.codigo_terminal))
        {
            erroModal = "Código do terminal é obrigatório.";
            return;
        }
        if (string.IsNullOrWhiteSpace(model.nome_terminal))
        {
            erroModal = "Nome do terminal é obrigatório.";
            return;
        }

        try
        {
            Guid? regId = string.IsNullOrEmpty(model.registradora_id) ? null : Guid.Parse(model.registradora_id);
            var payload = new
            {
                codigo_terminal = model.codigo_terminal,
                nome_terminal = model.nome_terminal,
                descricao = model.descricao,
                tipo_terminal = model.tipo_terminal,
                ip_rede_local = model.ip_rede_local,
                registradora_id = regId,
                ativo = model.ativo
            };

            HttpResponseMessage res;
            if (modalEditandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/configuracoes/operacionais/terminais", payload);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/configuracoes/operacionais/terminais/{modalEditandoId}", payload);
            }

            if (res.IsSuccessStatusCode)
            {
                mostrarModal = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModal = err?.mensagem ?? "Ocorreu uma falha ao salvar o terminal.";
            }
        }
        catch (Exception ex)
        {
            erroModal = "Erro ao enviar requisição: " + ex.Message;
        }
    }

    private async Task Inativar(Guid id)
    {
        try
        {
            var res = await Http.PutAsync($"/configuracoes/operacionais/terminais/{id}/inativar", null);
            if (res.IsSuccessStatusCode)
            {
                await CarregarDados();
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro ao inativar terminal: " + ex.Message;
        }
    }

    private async Task Autorizar(Guid id)
    {
        try
        {
            var res = await Http.PutAsync($"/configuracoes/operacionais/terminais/{id}/autorizar", null);
            if (res.IsSuccessStatusCode)
            {
                await CarregarDados();
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro ao autorizar terminal: " + ex.Message;
        }
    }

    private void FecharModal() => mostrarModal = false;

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class TerminalDto
    {
        public Guid id { get; set; }
        public string codigo_terminal { get; set; } = "";
        public string nome_terminal { get; set; } = "";
        public string? descricao { get; set; }
        public string tipo_terminal { get; set; } = "FIXO";
        public string? ip_rede_local { get; set; }
        public Guid? registradora_id { get; set; }
        public string? registradora_nome { get; set; }
        public bool ativo { get; set; }
        public bool autorizado { get; set; }
    }

    public class RegistradoraDto
    {
        public Guid id { get; set; }
        public string codigo { get; set; } = "";
        public string nome { get; set; } = "";
    }

    public class TerminalInput
    {
        public string codigo_terminal { get; set; } = "";
        public string nome_terminal { get; set; } = "";
        public string? descricao { get; set; }
        public string tipo_terminal { get; set; } = "FIXO";
        public string? ip_rede_local { get; set; }
        public string? registradora_id { get; set; }
        public bool ativo { get; set; } = true;
    }
}
