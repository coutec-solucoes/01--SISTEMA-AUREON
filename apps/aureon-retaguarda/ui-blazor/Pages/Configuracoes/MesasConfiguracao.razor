@page "/configuracoes/operacionais/mesas"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Configurações de Mesas — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Mesas & Atendimento Gourmet</h1>
        <p class="subtitulo-pagina">Configure o mapa de mesas, reservas, setores físicos e capacidade do salão de atendimento.</p>
    </div>
    @if (abaAtiva == "LISTA")
    {
        <button class="btn btn-primary" @onclick="AbrirModalNovaMesa">
            <span>+</span> Nova Mesa
        </button>
    }
</div>

<SubmenuOperacionais />

<div class="card-glass fade-in" style="padding: 12px; margin-bottom: 24px; display: flex; gap: 8px;">
    <button class='btn btn-sm @(abaAtiva == "PARAMETROS" ? "btn-primary" : "btn-outline")' @onclick='() => SetAba("PARAMETROS")'>Parâmetros Gerais</button>
    <button class='btn btn-sm @(abaAtiva == "LISTA" ? "btn-primary" : "btn-outline")' @onclick='() => SetAba("LISTA")'>Mapa de Mesas</button>
</div>

@if (carregando)
{
    <div class="loading-state fade-in">Carregando dados das mesas e parâmetros...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box fade-in">@erroGeral</div>
}
else
{
    @if (abaAtiva == "PARAMETROS")
    {
        <div class="card-glass fade-in" style="padding: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px; margin-bottom: 24px;">
                <h3 style="color: #fff; margin: 0; font-size: 16px;">Parâmetros Globais de Mesas</h3>
                @if (sucessoSalvarConfig)
                {
                    <span class="badge badge-success fade-in">✓ Configurações Salvas!</span>
                }
            </div>

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.mesas_ativas" />
                        <span>Habilitar Módulo de Mesas</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4;">
                    <label>Quantidade Estimada de Mesas</label>
                    <input type="number" class="form-control" @bind="config.quantidade_mesas" min="0" />
                </div>

                <div class="form-grupo" style="grid-column: span 4;">
                    <label>Prefixo de Exibição</label>
                    <input type="text" class="form-control" @bind="config.prefixo_mesa" placeholder="Ex: Mesa..." />
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.permitir_nome_informal" />
                        <span>Permitir Nome Informal do Cliente</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.permitir_reserva_mesa" />
                        <span>Permitir Reserva de Mesas</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.permitir_transferencia_mesa" />
                        <span>Permitir Transferência de Mesa</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.permitir_transferencia_parcial_itens" />
                        <span>Transferência Parcial de Itens</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.imprimir_producao_por_mesa" />
                        <span>Imprimir Produção por Mesa</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.bloquear_mesa_com_pendencia" />
                        <span>Bloquear Mesa com Pendência</span>
                    </label>
                </div>
            </div>

            <div style="margin-top: 32px; display: flex; justify-content: flex-end; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-primary" style="padding: 12px 32px;" @onclick="SalvarConfiguracao">
                    Salvar Parâmetros
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card-glass fade-in" style="overflow-x: auto; padding: 0;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Nome de Exibição</th>
                        <th>Setor / Área</th>
                        <th>Capacidade</th>
                        <th>Status</th>
                        <th>Observações</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in mesas)
                    {
                        <tr>
                            <td style="font-weight: bold; color: #fff; font-size: 16px;">@m.numero</td>
                            <td>@(string.IsNullOrEmpty(m.nome_exibicao) ? $"{config.prefixo_mesa} {m.numero}" : m.nome_exibicao)</td>
                            <td>@(string.IsNullOrEmpty(m.setor) ? "Geral" : m.setor)</td>
                            <td>@m.capacidade pessoas</td>
                            <td>
                                @if (m.ativo)
                                {
                                    <span class="badge badge-success">Ativa</span>
                                }
                                else
                                {
                                    <span class="badge badge-error">Inativa</span>
                                }
                            </td>
                            <td style="max-width: 250px; text-overflow: ellipsis; overflow: hidden; white-space: nowrap;">
                                @(string.IsNullOrEmpty(m.observacao) ? "-" : m.observacao)
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline" @onclick="() => AbrirModalEditarMesa(m)">Editar</button>
                            </td>
                        </tr>
                    }
                    @if (!mesas.Any())
                    {
                        <tr>
                            <td colspan="7" style="text-align: center; color: var(--cor-texto-sub); padding: 48px;">
                                Nenhuma mesa cadastrada no mapa.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<!-- Modal de Cadastro / Edição de Mesa -->
@if (mostrarModalMesa)
{
    <div class="modal-backdrop fade-in">
        <div class="modal-content card-glass" style="max-width: 500px; width: 90%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                <h2 class="modal-title" style="margin: 0; color: #fff;">
                    @(modalMesaEditandoId == Guid.Empty ? "Cadastrar Mesa" : "Editar Mesa")
                </h2>
                <button style="background: none; border: none; color: var(--cor-texto-sub); font-size: 20px; cursor: pointer;" @onclick="FecharModalMesa">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(erroModalMesa))
            {
                <div class="alert-error-box" style="margin-bottom: 20px;">@erroModalMesa</div>
            }

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Número da Mesa *</label>
                    <input type="number" class="form-control" @bind="mesaModel.numero" min="1" />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Nome de Exibição</label>
                    <input type="text" class="form-control" @bind="mesaModel.nome_exibicao" placeholder="Ex: Mesa VIP..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Setor / Área física</label>
                    <input type="text" class="form-control" @bind="mesaModel.setor" placeholder="Ex: Terraço, Salão..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Capacidade (Pessoas)</label>
                    <input type="number" class="form-control" @bind="mesaModel.capacidade" min="1" />
                </div>

                <div class="form-grupo" style="grid-column: span 12;">
                    <label>Observação / Restrições</label>
                    <input type="text" class="form-control" @bind="mesaModel.observacao" placeholder="Ex: Próxima à janela, ar condicionado..." />
                </div>

                <div class="form-grupo" style="grid-column: span 12; margin-top: 10px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="mesaModel.ativo" />
                        <span>Mesa Disponível p/ Venda</span>
                    </label>
                </div>
            </div>

            <div class="modal-actions" style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-outline" @onclick="FecharModalMesa">Cancelar</button>
                <button class="btn btn-primary" @onclick="SalvarMesa">Salvar Registro</button>
            </div>
        </div>
    </div>
}

<style>
    .header-pagina { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .titulo-pagina { font-size: 30px; font-weight: 700; color: #fff; }
    .subtitulo-pagina { color: var(--cor-texto-sub); font-size: 14px; }
    
    .badge { font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-success { background: rgba(16,185,129,0.12); color: #38ef7d; border: 1px solid rgba(16,185,129,0.25); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ff4b2b; border: 1px solid rgba(239,68,68,0.25); }

    .btn-sm { padding: 4px 10px; font-size: 12px; border-radius: 6px; }
    .btn-outline { background: transparent; border: 1px solid var(--cor-borda); color: var(--cor-texto-sub); transition: all 0.2s ease; cursor: pointer; }
    .btn-outline:hover { background: rgba(255,255,255,0.05); color: #fff; border-color: rgba(255,255,255,0.2); }

    .checkbox-premium {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--cor-borda);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .checkbox-premium:hover {
        background: rgba(0, 198, 255, 0.03);
        border-color: var(--cor-borda-glow);
    }
    .checkbox-premium input[type=checkbox] {
        width: 18px;
        height: 18px;
        accent-color: #00c6ff;
        cursor: pointer;
    }

    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1100; }
    
    .alert-error-box { background: rgba(255,75,43,0.1); color: #ff4b2b; border: 1px solid rgba(255,75,43,0.2); padding: 12px 16px; border-radius: 8px; font-size: 14px; }
    .loading-state { text-align: center; color: var(--cor-texto-sub); padding: 64px; font-size: 16px; }
</style>

@code {
    private string abaAtiva = "PARAMETROS";
    private bool carregando = true;
    private string? erroGeral, erroModalMesa;
    private bool sucessoSalvarConfig = false;

    private ConfigMesasDto config = new();
    private List<MesaDto> mesas = new();

    private bool mostrarModalMesa = false;
    private Guid modalMesaEditandoId = Guid.Empty;
    private MesaInput mesaModel = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private void SetAba(string aba)
    {
        abaAtiva = aba;
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var resConf = await Http.GetFromJsonAsync<Resposta<ConfigMesasDto>>("/configuracoes/operacionais/mesas/configuracao");
            if (resConf?.sucesso == true && resConf.dados != null) config = resConf.dados;

            var resMesas = await Http.GetFromJsonAsync<Resposta<List<MesaDto>>>("/configuracoes/operacionais/mesas");
            if (resMesas?.sucesso == true) mesas = resMesas.dados ?? new();
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task SalvarConfiguracao()
    {
        erroGeral = null; sucessoSalvarConfig = false;
        if (config.quantidade_mesas < 0)
        {
            erroGeral = "Quantidade de mesas não pode ser negativa.";
            return;
        }

        try
        {
            var res = await Http.PostAsJsonAsync("/configuracoes/operacionais/mesas/configuracao", config);
            if (res.IsSuccessStatusCode)
            {
                sucessoSalvarConfig = true;
                StateHasChanged();
                await Task.Delay(3000);
                sucessoSalvarConfig = false;
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroGeral = err?.mensagem ?? "Erro ao salvar parâmetros globais.";
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de rede: " + ex.Message;
        }
    }

    private void AbrirModalNovaMesa()
    {
        modalMesaEditandoId = Guid.Empty;
        mesaModel = new MesaInput { numero = mesas.Count + 1, capacidade = 4, ativo = true };
        erroModalMesa = null;
        mostrarModalMesa = true;
    }

    private void AbrirModalEditarMesa(MesaDto m)
    {
        modalMesaEditandoId = m.id;
        mesaModel = new MesaInput
        {
            numero = m.numero,
            nome_exibicao = m.nome_exibicao,
            setor = m.setor,
            capacidade = m.capacidade,
            ativo = m.ativo,
            observacao = m.observacao
        };
        erroModalMesa = null;
        mostrarModalMesa = true;
    }

    private async Task SalvarMesa()
    {
        erroModalMesa = null;
        if (mesaModel.numero <= 0)
        {
            erroModalMesa = "Número da mesa deve ser maior que zero.";
            return;
        }

        try
        {
            HttpResponseMessage res;
            if (modalMesaEditandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/configuracoes/operacionais/mesas", mesaModel);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/configuracoes/operacionais/mesas/{modalMesaEditandoId}", mesaModel);
            }

            if (res.IsSuccessStatusCode)
            {
                mostrarModalMesa = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModalMesa = err?.mensagem ?? "Erro ao salvar mesa.";
            }
        }
        catch (Exception ex)
        {
            erroModalMesa = "Erro ao enviar requisição: " + ex.Message;
        }
    }

    private void FecharModalMesa() => mostrarModalMesa = false;

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class ConfigMesasDto
    {
        public Guid id { get; set; }
        public bool mesas_ativas { get; set; } = true;
        public int quantidade_mesas { get; set; } = 20;
        public string prefixo_mesa { get; set; } = "Mesa";
        public bool permitir_nome_informal { get; set; } = true;
        public bool permitir_reserva_mesa { get; set; } = true;
        public bool permitir_transferencia_mesa { get; set; } = true;
        public bool permitir_transferencia_parcial_itens { get; set; } = true;
        public bool imprimir_producao_por_mesa { get; set; } = true;
        public bool bloquear_mesa_com_pendencia { get; set; } = false;
        public bool ativo { get; set; } = true;
    }

    public class MesaDto
    {
        public Guid id { get; set; }
        public int numero { get; set; }
        public string? nome_exibicao { get; set; }
        public string? setor { get; set; }
        public int capacidade { get; set; }
        public bool ativo { get; set; }
        public string? observacao { get; set; }
    }

    public class MesaInput
    {
        public int numero { get; set; }
        public string? nome_exibicao { get; set; }
        public string? setor { get; set; }
        public int capacidade { get; set; } = 4;
        public bool ativo { get; set; } = true;
        public string? observacao { get; set; }
    }
}
