@page "/configuracoes/operacionais/perifericos"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Periféricos & Integrações — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Periféricos (Gerais)</h1>
        <p class="subtitulo-pagina">Gerencie leitores de código de barras, gavetas acionadas por impressora, displays de cliente e teclados programáveis.</p>
    </div>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">
        <span>+</span> Novo Periférico
    </button>
</div>

<SubmenuOperacionais />

@if (carregando)
{
    <div class="loading-state fade-in">Carregando periféricos e hardware cadastrados...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box fade-in">@erroGeral</div>
}
else
{
    <div class="card-glass fade-in" style="overflow-x: auto; padding: 0;">
        <table class="table">
            <thead>
                <tr>
                    <th>Nome do Dispositivo</th>
                    <th>Tipo de Periférico</th>
                    <th>Marca / Modelo</th>
                    <th>Porta de Comunicação</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in perifericos)
                {
                    <tr>
                        <td style="font-weight: bold; color: #fff; font-size: 15px;">@p.nome</td>
                        <td>
                            <span class="badge" style="background: rgba(0,198,255,0.1); color: #00c6ff; border: 1px solid rgba(0,198,255,0.25);">
                                @p.tipo_periferico
                            </span>
                        </td>
                        <td>@p.marca_modelo</td>
                        <td>@p.porta_conexao_ip</td>
                        <td>
                            @if (p.ativo)
                            {
                                <span class="badge badge-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge badge-error">Inativo</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <button class="btn btn-sm btn-outline" @onclick="() => AbrirModalEditar(p)">Editar</button>
                                <button class="btn btn-sm btn-outline" style="border-color: rgba(56,239,125,0.3); color: #38ef7d;" @onclick="() => TestarPeriferico(p.id)">Testar pulso</button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!perifericos.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align: center; color: var(--cor-texto-sub); padding: 48px;">
                            Nenhum periférico geral cadastrado.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal de Cadastro / Edição -->
@if (mostrarModal)
{
    <div class="modal-backdrop fade-in">
        <div class="modal-content card-glass" style="max-width: 550px; width: 90%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                <h2 class="modal-title" style="margin: 0; color: #fff;">
                    @(modalEditandoId == Guid.Empty ? "Cadastrar Periférico" : "Editar Periférico")
                </h2>
                <button style="background: none; border: none; color: var(--cor-texto-sub); font-size: 20px; cursor: pointer;" @onclick="FecharModal">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(erroModal))
            {
                <div class="alert-error-box" style="margin-bottom: 20px;">@erroModal</div>
            }

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Nome do Periférico *</label>
                    <input type="text" class="form-control" @bind="model.nome" placeholder="Ex: Gaveta de Dinheiro Solenóide..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Tipo do Hardware *</label>
                    <select class="form-control" @bind="model.tipo_periferico">
                        <option value="GAVETA_DINHEIRO">Gaveta de Dinheiro (Pulso/RJ11)</option>
                        <option value="LEITOR_CODIGO_BARRAS">Leitor de Código de Barras</option>
                        <option value="DISPLAY_CLIENTE">Display Torre de Cliente (VFD/Serial)</option>
                        <option value="TERMINAL_TECLADO">Teclado Reduzido / Operacional</option>
                    </select>
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Marca / Modelo *</label>
                    <input type="text" class="form-control" @bind="model.marca_modelo" placeholder="Ex: Menno / Gerbo / Honeywell..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Porta (COM3, LPT1 ou Impressora) *</label>
                    <input type="text" class="form-control" @bind="model.porta_conexao_ip" placeholder="Ex: LPT1 ou acionamento por ESC/POS..." />
                </div>

                <div class="form-grupo" style="grid-column: span 12; margin-top: 10px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="model.ativo" />
                        <span>Dispositivo Ativo no Checkout</span>
                    </label>
                </div>
            </div>

            <div class="modal-actions" style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-outline" @onclick="FecharModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Salvar">Salvar Registro</button>
            </div>
        </div>
    </div>
}

<style>
    .header-pagina { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .titulo-pagina { font-size: 30px; font-weight: 700; color: #fff; }
    .subtitulo-pagina { color: var(--cor-texto-sub); font-size: 14px; }
    
    .badge { font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-success { background: rgba(16,185,129,0.12); color: #38ef7d; border: 1px solid rgba(16,185,129,0.25); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ff4b2b; border: 1px solid rgba(239,68,68,0.25); }

    .btn-sm { padding: 4px 10px; font-size: 12px; border-radius: 6px; }
    .btn-outline { background: transparent; border: 1px solid var(--cor-borda); color: var(--cor-texto-sub); transition: all 0.2s ease; cursor: pointer; }
    .btn-outline:hover { background: rgba(255,255,255,0.05); color: #fff; border-color: rgba(255,255,255,0.2); }

    .checkbox-premium {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--cor-borda);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .checkbox-premium:hover {
        background: rgba(0, 198, 255, 0.03);
        border-color: var(--cor-borda-glow);
    }
    .checkbox-premium input[type=checkbox] {
        width: 18px;
        height: 18px;
        accent-color: #00c6ff;
        cursor: pointer;
    }

    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1100; }
    
    .alert-error-box { background: rgba(255,75,43,0.1); color: #ff4b2b; border: 1px solid rgba(255,75,43,0.2); padding: 12px 16px; border-radius: 8px; font-size: 14px; }
    .loading-state { text-align: center; color: var(--cor-texto-sub); padding: 64px; font-size: 16px; }
</style>

@code {
    private bool carregando = true;
    private string? erroGeral, erroModal;

    private List<PerifericoDto> perifericos = new();

    private bool mostrarModal = false;
    private Guid modalEditandoId = Guid.Empty;
    private PerifericoInput model = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<List<PerifericoDto>>>("/configuracoes/operacionais/perifericos");
            if (res?.sucesso == true) perifericos = res.dados ?? new();
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private void AbrirModalNovo()
    {
        modalEditandoId = Guid.Empty;
        model = new PerifericoInput { tipo_periferico = "GAVETA_DINHEIRO", ativo = true };
        erroModal = null;
        mostrarModal = true;
    }

    private void AbrirModalEditar(PerifericoDto p)
    {
        modalEditandoId = p.id;
        model = new PerifericoInput
        {
            nome = p.nome,
            tipo_periferico = p.tipo_periferico,
            marca_modelo = p.marca_modelo,
            porta_conexao_ip = p.porta_conexao_ip,
            ativo = p.ativo
        };
        erroModal = null;
        mostrarModal = true;
    }

    private async Task Salvar()
    {
        erroModal = null;
        if (string.IsNullOrWhiteSpace(model.nome))
        {
            erroModal = "O nome do dispositivo é obrigatório.";
            return;
        }
        if (string.IsNullOrWhiteSpace(model.porta_conexao_ip))
        {
            erroModal = "Porta de conexão é obrigatória.";
            return;
        }

        try
        {
            HttpResponseMessage res;
            if (modalEditandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/configuracoes/operacionais/perifericos", model);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/configuracoes/operacionais/perifericos/{modalEditandoId}", model);
            }

            if (res.IsSuccessStatusCode)
            {
                mostrarModal = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModal = err?.mensagem ?? "Ocorreu uma falha ao salvar o periférico.";
            }
        }
        catch (Exception ex)
        {
            erroModal = "Erro ao enviar requisição: " + ex.Message;
        }
    }

    private async Task TestarPeriferico(Guid id)
    {
        try
        {
            var res = await Http.PostAsync($"/configuracoes/operacionais/perifericos/{id}/testar", null);
            if (res.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Pulso de abertura da gaveta/acionamento enviado!");
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                await JSRuntime.InvokeVoidAsync("alert", "Falha no teste: " + (err?.mensagem ?? "Erro desconhecido."));
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro ao disparar pulso: " + ex.Message);
        }
    }

    private void FecharModal() => mostrarModal = false;

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class PerifericoDto
    {
        public Guid id { get; set; }
        public string nome { get; set; } = "";
        public string tipo_periferico { get; set; } = "GAVETA_DINHEIRO";
        public string marca_modelo { get; set; } = "";
        public string porta_conexao_ip { get; set; } = "";
        public bool ativo { get; set; }
    }

    public class PerifericoInput
    {
        public string nome { get; set; } = "";
        public string tipo_periferico { get; set; } = "GAVETA_DINHEIRO";
        public string marca_modelo { get; set; } = "";
        public string porta_conexao_ip { get; set; } = "";
        public bool ativo { get; set; } = true;
    }
}
