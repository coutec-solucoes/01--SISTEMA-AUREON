@page "/configuracoes/operacionais/impressoras"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Cadastro de Impressoras — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Impressoras Térmicas</h1>
        <p class="subtitulo-pagina">Cadastre impressoras térmicas ESC/POS locais ou de rede e defina layouts de colunas e conexões.</p>
    </div>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">
        <span>+</span> Nova Impressora
    </button>
</div>

<SubmenuOperacionais />

@if (carregando)
{
    <div class="loading-state fade-in">Carregando periféricos de impressão cadastrados...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box fade-in">@erroGeral</div>
}
else
{
    <div class="card-glass fade-in" style="overflow-x: auto; padding: 0;">
        <table class="table">
            <thead>
                <tr>
                    <th>Nome da Impressora</th>
                    <th>Tipo de Conexão</th>
                    <th>IP / Porta / Endereço</th>
                    <th>Protocolo / Modelo</th>
                    <th>Largura (Colunas)</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var imp in impressoras)
                {
                    <tr>
                        <td style="font-weight: bold; color: #fff; font-size: 15px;">@imp.nome</td>
                        <td>
                            <span class="badge" style="background: rgba(255,255,255,0.05); color: #fff; border: 1px solid rgba(255,255,255,0.1);">
                                @imp.tipo_conexao
                            </span>
                        </td>
                        <td>@(string.IsNullOrEmpty(imp.ip_porta_conexao) ? "Local / USB" : imp.ip_porta_conexao)</td>
                        <td>@imp.marca_modelo_protocolo</td>
                        <td>@imp.largura_colunas_caracteres cols (80mm/58mm)</td>
                        <td>
                            @if (imp.ativo)
                            {
                                <span class="badge badge-success">Ativa</span>
                            }
                            else
                            {
                                <span class="badge badge-error">Inativa</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <button class="btn btn-sm btn-outline" @onclick="() => AbrirModalEditar(imp)">Editar</button>
                                <button class="btn btn-sm btn-outline" style="border-color: rgba(56,239,125,0.3); color: #38ef7d;" @onclick="() => TestarImpressora(imp.id)">Testar</button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!impressoras.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: var(--cor-texto-sub); padding: 48px;">
                            Nenhuma impressora térmica cadastrada.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal de Cadastro / Edição -->
@if (mostrarModal)
{
    <div class="modal-backdrop fade-in">
        <div class="modal-content card-glass" style="max-width: 550px; width: 90%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                <h2 class="modal-title" style="margin: 0; color: #fff;">
                    @(modalEditandoId == Guid.Empty ? "Cadastrar Impressora" : "Editar Impressora")
                </h2>
                <button style="background: none; border: none; color: var(--cor-texto-sub); font-size: 20px; cursor: pointer;" @onclick="FecharModal">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(erroModal))
            {
                <div class="alert-error-box" style="margin-bottom: 20px;">@erroModal</div>
            }

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Nome do Dispositivo *</label>
                    <input type="text" class="form-control" @bind="model.nome" placeholder="Ex: Impressora Cozinha..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Tipo de Conexão *</label>
                    <select class="form-control" @bind="model.tipo_conexao">
                        <option value="USB">USB / Local</option>
                        <option value="REDE">Rede TCP/IP (Ethernet/Wi-Fi)</option>
                        <option value="COMPARTILHADA">Compartilhada Windows (UNC)</option>
                    </select>
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>IP / Porta / Nome da Fila</label>
                    <input type="text" class="form-control" @bind="model.ip_porta_conexao" placeholder="Ex: 192.168.1.200:9100 ou \\PC\Caixa" />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Protocolo / Protocolo de Emulação</label>
                    <select class="form-control" @bind="model.marca_modelo_protocolo">
                        <option value="ESC_POS">ESC/POS Genérico</option>
                        <option value="BEMATECH">Protocolo Bematech</option>
                        <option value="DARUMA">Daruma Framework</option>
                    </select>
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Largura de Colunas (Caracteres)</label>
                    <select class="form-control" @bind="model.largura_colunas_caracteres">
                        <option value="48">48 Colunas (Bobina de 80mm)</option>
                        <option value="40">40 Colunas (Bobina Média)</option>
                        <option value="32">32 Colunas (Bobina Pequena 58mm)</option>
                    </select>
                </div>

                <div class="form-grupo" style="grid-column: span 6; justify-content: center; display: flex; flex-direction: column; margin-top: 14px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="model.ativo" />
                        <span>Dispositivo Ativo</span>
                    </label>
                </div>
            </div>

            <div class="modal-actions" style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-outline" @onclick="FecharModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Salvar">Salvar Impressora</button>
            </div>
        </div>
    </div>
}

<style>
    .header-pagina { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .titulo-pagina { font-size: 30px; font-weight: 700; color: #fff; }
    .subtitulo-pagina { color: var(--cor-texto-sub); font-size: 14px; }
    
    .badge { font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-success { background: rgba(16,185,129,0.12); color: #38ef7d; border: 1px solid rgba(16,185,129,0.25); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ff4b2b; border: 1px solid rgba(239,68,68,0.25); }

    .btn-sm { padding: 4px 10px; font-size: 12px; border-radius: 6px; }
    .btn-outline { background: transparent; border: 1px solid var(--cor-borda); color: var(--cor-texto-sub); transition: all 0.2s ease; cursor: pointer; }
    .btn-outline:hover { background: rgba(255,255,255,0.05); color: #fff; border-color: rgba(255,255,255,0.2); }

    .checkbox-premium {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--cor-borda);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .checkbox-premium:hover {
        background: rgba(0, 198, 255, 0.03);
        border-color: var(--cor-borda-glow);
    }
    .checkbox-premium input[type=checkbox] {
        width: 18px;
        height: 18px;
        accent-color: #00c6ff;
        cursor: pointer;
    }

    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1100; }
    
    .alert-error-box { background: rgba(255,75,43,0.1); color: #ff4b2b; border: 1px solid rgba(255,75,43,0.2); padding: 12px 16px; border-radius: 8px; font-size: 14px; }
    .loading-state { text-align: center; color: var(--cor-texto-sub); padding: 64px; font-size: 16px; }
</style>

@code {
    private bool carregando = true;
    private string? erroGeral, erroModal;

    private List<ImpressoraDto> impressoras = new();

    private bool mostrarModal = false;
    private Guid modalEditandoId = Guid.Empty;
    private ImpressoraInput model = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<List<ImpressoraDto>>>("/configuracoes/operacionais/impressoras");
            if (res?.sucesso == true) impressoras = res.dados ?? new();
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private void AbrirModalNovo()
    {
        modalEditandoId = Guid.Empty;
        model = new ImpressoraInput { tipo_conexao = "USB", marca_modelo_protocolo = "ESC_POS", largura_colunas_caracteres = 48, ativo = true };
        erroModal = null;
        mostrarModal = true;
    }

    private void AbrirModalEditar(ImpressoraDto i)
    {
        modalEditandoId = i.id;
        model = new ImpressoraInput
        {
            nome = i.nome,
            tipo_conexao = i.tipo_conexao,
            ip_porta_conexao = i.ip_porta_conexao,
            marca_modelo_protocolo = i.marca_modelo_protocolo,
            largura_colunas_caracteres = i.largura_colunas_caracteres,
            ativo = i.ativo
        };
        erroModal = null;
        mostrarModal = true;
    }

    private async Task Salvar()
    {
        erroModal = null;
        if (string.IsNullOrWhiteSpace(model.nome))
        {
            erroModal = "O nome da impressora é obrigatório.";
            return;
        }

        try
        {
            HttpResponseMessage res;
            if (modalEditandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/configuracoes/operacionais/impressoras", model);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/configuracoes/operacionais/impressoras/{modalEditandoId}", model);
            }

            if (res.IsSuccessStatusCode)
            {
                mostrarModal = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModal = err?.mensagem ?? "Ocorreu uma falha ao salvar a impressora.";
            }
        }
        catch (Exception ex)
        {
            erroModal = "Erro ao enviar requisição: " + ex.Message;
        }
    }

    private async Task TestarImpressora(Guid id)
    {
        try
        {
            var res = await Http.PostAsync($"/configuracoes/operacionais/impressoras/{id}/testar", null);
            if (res.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Comando de teste de impressão enviado com sucesso!");
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                await JSRuntime.InvokeVoidAsync("alert", "Falha no teste: " + (err?.mensagem ?? "Erro desconhecido."));
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro de conexão ao testar: " + ex.Message);
        }
    }

    private void FecharModal() => mostrarModal = false;

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class ImpressoraDto
    {
        public Guid id { get; set; }
        public string nome { get; set; } = "";
        public string tipo_conexao { get; set; } = "USB";
        public string? ip_porta_conexao { get; set; }
        public string marca_modelo_protocolo { get; set; } = "ESC_POS";
        public int largura_colunas_caracteres { get; set; } = 48;
        public bool ativo { get; set; }
    }

    public class ImpressoraInput
    {
        public string nome { get; set; } = "";
        public string tipo_conexao { get; set; } = "USB";
        public string? ip_porta_conexao { get; set; }
        public string marca_modelo_protocolo { get; set; } = "ESC_POS";
        public int largura_colunas_caracteres { get; set; } = 48;
        public bool ativo { get; set; } = true;
    }
}
