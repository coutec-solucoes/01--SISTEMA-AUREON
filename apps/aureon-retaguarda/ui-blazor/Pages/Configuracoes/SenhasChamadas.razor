@page "/configuracoes/operacionais/senhas-chamadas"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Painel de Senhas — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Painel de Senhas & Chamadas</h1>
        <p class="subtitulo-pagina">Configure displays e painéis de TV para chamadas de senhas por voz sintetizada e filas de preparo.</p>
    </div>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">
        <span>+</span> Novo Painel
    </button>
</div>

<SubmenuOperacionais />

@if (carregando)
{
    <div class="loading-state fade-in">Carregando painéis de chamada configurados...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box fade-in">@erroGeral</div>
}
else
{
    <div class="card-glass fade-in" style="overflow-x: auto; padding: 0;">
        <table class="table">
            <thead>
                <tr>
                    <th>Nome do Painel</th>
                    <th>Tipo de Chamada</th>
                    <th>Voz Sintetizada (TTS)</th>
                    <th>Tempo Médio de Espera</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in paineis)
                {
                    <tr>
                        <td style="font-weight: bold; color: #fff; font-size: 15px;">@p.nome_painel</td>
                        <td>
                            <span class="badge" style="background: rgba(0,198,255,0.1); color: #00c6ff; border: 1px solid rgba(0,198,255,0.25);">
                                @p.tipo_painel
                            </span>
                        </td>
                        <td>
                            @if (p.voz_sintetizada)
                            {
                                <span class="badge badge-success" style="background: rgba(56,239,125,0.1); color: #38ef7d; border: 1px solid rgba(56,239,125,0.25);">Habilitada (Voz)</span>
                            }
                            else
                            {
                                <span class="badge" style="background: rgba(255,255,255,0.02); color: var(--cor-texto-disabled); border: 1px solid var(--cor-borda);">Apenas Som (Bip)</span>
                            }
                        </td>
                        <td>
                            @if (p.exibir_tempo_medio_espera)
                            {
                                <span>Sim (Visível)</span>
                            }
                            else
                            {
                                <span style="color: var(--cor-texto-disabled);">Não</span>
                            }
                        </td>
                        <td>
                            @if (p.ativo)
                            {
                                <span class="badge badge-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge badge-error">Inativo</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <button class="btn btn-sm btn-outline" @onclick="() => AbrirModalEditar(p)">Editar</button>
                                <button class="btn btn-sm btn-outline" style="border-color: rgba(0,198,255,0.3); color: #00c6ff;" @onclick="() => TestarPainel(p.id)">Disparar Senha Teste</button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!paineis.Any())
                {
                    <tr>
                        <td colspan="6" style="text-align: center; color: var(--cor-texto-sub); padding: 48px;">
                            Nenhum painel ou display cadastrado.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal de Cadastro / Edição -->
@if (mostrarModal)
{
    <div class="modal-backdrop fade-in">
        <div class="modal-content card-glass" style="max-width: 550px; width: 90%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                <h2 class="modal-title" style="margin: 0; color: #fff;">
                    @(modalEditandoId == Guid.Empty ? "Cadastrar Painel" : "Editar Painel")
                </h2>
                <button style="background: none; border: none; color: var(--cor-texto-sub); font-size: 20px; cursor: pointer;" @onclick="FecharModal">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(erroModal))
            {
                <div class="alert-error-box" style="margin-bottom: 20px;">@erroModal</div>
            }

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 12;">
                    <label>Nome do Painel / Identificação *</label>
                    <input type="text" class="form-control" @bind="model.nome_painel" placeholder="Ex: TV Principal Salão..." />
                </div>

                <div class="form-grupo" style="grid-column: span 6;">
                    <label>Tipo do Painel *</label>
                    <select class="form-control" @bind="model.tipo_painel">
                        <option value="SENHAS">Senha Numérica (Chamada)</option>
                        <option value="FILA">Fila / Andamento (Preparo/Pronto)</option>
                        <option value="PRODUTO_PRONTO">Produto Pronto (Chamada por Nome)</option>
                    </select>
                </div>

                <div class="form-grupo" style="grid-column: span 6; justify-content: center; display: flex; flex-direction: column; margin-top: 14px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="model.voz_sintetizada" />
                        <span>Sintetizar Voz (TTS)</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 6; justify-content: center; display: flex; flex-direction: column; margin-top: 14px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="model.exibir_tempo_medio_espera" />
                        <span>Exibir Tempo Médio Espera</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 6; justify-content: center; display: flex; flex-direction: column; margin-top: 14px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="model.ativo" />
                        <span>Painel Ativo</span>
                    </label>
                </div>
            </div>

            <div class="modal-actions" style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-outline" @onclick="FecharModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Salvar">Salvar Painel</button>
            </div>
        </div>
    </div>
}

<style>
    .header-pagina { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .titulo-pagina { font-size: 30px; font-weight: 700; color: #fff; }
    .subtitulo-pagina { color: var(--cor-texto-sub); font-size: 14px; }
    
    .badge { font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-success { background: rgba(16,185,129,0.12); color: #38ef7d; border: 1px solid rgba(16,185,129,0.25); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ff4b2b; border: 1px solid rgba(239,68,68,0.25); }

    .btn-sm { padding: 4px 10px; font-size: 12px; border-radius: 6px; }
    .btn-outline { background: transparent; border: 1px solid var(--cor-borda); color: var(--cor-texto-sub); transition: all 0.2s ease; cursor: pointer; }
    .btn-outline:hover { background: rgba(255,255,255,0.05); color: #fff; border-color: rgba(255,255,255,0.2); }

    .checkbox-premium {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--cor-borda);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .checkbox-premium:hover {
        background: rgba(0, 198, 255, 0.03);
        border-color: var(--cor-borda-glow);
    }
    .checkbox-premium input[type=checkbox] {
        width: 18px;
        height: 18px;
        accent-color: #00c6ff;
        cursor: pointer;
    }

    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1100; }
    
    .alert-error-box { background: rgba(255,75,43,0.1); color: #ff4b2b; border: 1px solid rgba(255,75,43,0.2); padding: 12px 16px; border-radius: 8px; font-size: 14px; }
    .loading-state { text-align: center; color: var(--cor-texto-sub); padding: 64px; font-size: 16px; }
</style>

@code {
    private bool carregando = true;
    private string? erroGeral, erroModal;

    private List<PainelSenhaDto> paineis = new();

    private bool mostrarModal = false;
    private Guid modalEditandoId = Guid.Empty;
    private PainelSenhaInput model = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<List<PainelSenhaDto>>>("/configuracoes/operacionais/senhas-chamadas");
            if (res?.sucesso == true) paineis = res.dados ?? new();
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private void AbrirModalNovo()
    {
        modalEditandoId = Guid.Empty;
        model = new PainelSenhaInput { tipo_painel = "SENHAS", voz_sintetizada = true, exibir_tempo_medio_espera = false, ativo = true };
        erroModal = null;
        mostrarModal = true;
    }

    private void AbrirModalEditar(PainelSenhaDto p)
    {
        modalEditandoId = p.id;
        model = new PainelSenhaInput
        {
            nome_painel = p.nome_painel,
            tipo_painel = p.tipo_painel,
            exibir_tempo_medio_espera = p.exibir_tempo_medio_espera,
            voz_sintetizada = p.voz_sintetizada,
            ativo = p.ativo
        };
        erroModal = null;
        mostrarModal = true;
    }

    private async Task Salvar()
    {
        erroModal = null;
        if (string.IsNullOrWhiteSpace(model.nome_painel))
        {
            erroModal = "Nome do painel é obrigatório.";
            return;
        }

        try
        {
            HttpResponseMessage res;
            if (modalEditandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/configuracoes/operacionais/senhas-chamadas", model);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/configuracoes/operacionais/senhas-chamadas/{modalEditandoId}", model);
            }

            if (res.IsSuccessStatusCode)
            {
                mostrarModal = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModal = err?.mensagem ?? "Ocorreu uma falha ao salvar o painel.";
            }
        }
        catch (Exception ex)
        {
            erroModal = "Erro ao enviar requisição: " + ex.Message;
        }
    }

    private async Task TestarPainel(Guid id)
    {
        try
        {
            var res = await Http.PostAsync($"/configuracoes/operacionais/senhas-chamadas/{id}/testar", null);
            if (res.IsSuccessStatusCode)
            {
                await JSRuntime.InvokeVoidAsync("alert", "Senha de teste gerada e disparada para o painel com sucesso!");
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                await JSRuntime.InvokeVoidAsync("alert", "Falha no teste: " + (err?.mensagem ?? "Erro desconhecido."));
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro de conexão ao disparar teste: " + ex.Message);
        }
    }

    private void FecharModal() => mostrarModal = false;

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class PainelSenhaDto
    {
        public Guid id { get; set; }
        public string nome_painel { get; set; } = "";
        public string tipo_painel { get; set; } = "SENHAS";
        public bool exibir_tempo_medio_espera { get; set; }
        public bool voz_sintetizada { get; set; }
        public bool ativo { get; set; }
    }

    public class PainelSenhaInput
    {
        public string nome_painel { get; set; } = "";
        public string tipo_painel { get; set; } = "SENHAS";
        public bool exibir_tempo_medio_espera { get; set; } = false;
        public bool voz_sintetizada { get; set; } = true;
        public bool ativo { get; set; } = true;
    }
}
