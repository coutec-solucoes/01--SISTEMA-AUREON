@page "/configuracoes/operacionais/comandas"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Configurações de Comandas — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Comandas de Atendimento</h1>
        <p class="subtitulo-pagina">Configure a faixa de comandas físicas de numeração sequencial, controles de segurança e impressão.</p>
    </div>
    @if (abaAtiva == "LISTA")
    {
        <button class="btn btn-primary" @onclick="AbrirModalNovaComanda">
            <span>+</span> Nova Comanda
        </button>
    }
</div>

<SubmenuOperacionais />

<div class="card-glass fade-in" style="padding: 12px; margin-bottom: 24px; display: flex; gap: 8px;">
    <button class='btn btn-sm @(abaAtiva == "PARAMETROS" ? "btn-primary" : "btn-outline")' @onclick='() => SetAba("PARAMETROS")'>Parâmetros Gerais</button>
    <button class='btn btn-sm @(abaAtiva == "LISTA" ? "btn-primary" : "btn-outline")' @onclick='() => SetAba("LISTA")'>Listagem de Comandas</button>
</div>

@if (carregando)
{
    <div class="loading-state fade-in">Carregando dados das comandas e parâmetros...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box fade-in">@erroGeral</div>
}
else
{
    @if (abaAtiva == "PARAMETROS")
    {
        <div class="card-glass fade-in" style="padding: 24px;">
            <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px; margin-bottom: 24px;">
                <h3 style="color: #fff; margin: 0; font-size: 16px;">Parâmetros Globais de Comandas</h3>
                @if (sucessoSalvarConfig)
                {
                    <span class="badge badge-success fade-in">✓ Configurações Salvas!</span>
                }
            </div>

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.comandas_ativas" />
                        <span>Habilitar Comandas</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4;">
                    <label>Faixa Inicial de Comandas</label>
                    <input type="number" class="form-control" @bind="config.faixa_inicial" min="1" />
                </div>

                <div class="form-grupo" style="grid-column: span 4;">
                    <label>Faixa Final de Comandas</label>
                    <input type="number" class="form-control" @bind="config.faixa_final" min="1" />
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.permitir_nome_informal" />
                        <span>Permitir Nome Informal</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.permitir_transferencia_comanda" />
                        <span>Permitir Transferir Comanda</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.permitir_transferencia_parcial_itens" />
                        <span>Transferência Parcial de Itens</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.imprimir_producao_por_comanda" />
                        <span>Imprimir Produção por Comanda</span>
                    </label>
                </div>

                <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="config.bloquear_comanda_com_pendencia" />
                        <span>Bloquear Comanda com Pendência</span>
                    </label>
                </div>
            </div>

            <div style="margin-top: 32px; display: flex; justify-content: flex-end; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-primary" style="padding: 12px 32px;" @onclick="SalvarConfiguracao">
                    Salvar Parâmetros
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="card-glass fade-in" style="overflow-x: auto; padding: 0;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Código de Barras / QR Code</th>
                        <th>Status</th>
                        <th>Observações</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in comandas)
                    {
                        <tr>
                            <td style="font-weight: bold; color: #fff; font-size: 16px;">@c.numero</td>
                            <td>@(string.IsNullOrEmpty(c.codigo_barras_qr_futuro) ? "Automático" : c.codigo_barras_qr_futuro)</td>
                            <td>
                                @if (c.ativo)
                                {
                                    <span class="badge badge-success">Ativa</span>
                                }
                                else
                                {
                                    <span class="badge badge-error">Inativa</span>
                                }
                            </td>
                            <td>@(string.IsNullOrEmpty(c.observacao) ? "-" : c.observacao)</td>
                            <td>
                                <button class="btn btn-sm btn-outline" @onclick="() => AbrirModalEditarComanda(c)">Editar</button>
                            </td>
                        </tr>
                    }
                    @if (!comandas.Any())
                    {
                        <tr>
                            <td colspan="5" style="text-align: center; color: var(--cor-texto-sub); padding: 48px;">
                                Nenhuma comanda individual cadastrada.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<!-- Modal de Cadastro / Edição de Comanda -->
@if (mostrarModalComanda)
{
    <div class="modal-backdrop fade-in">
        <div class="modal-content card-glass" style="max-width: 500px; width: 90%;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                <h2 class="modal-title" style="margin: 0; color: #fff;">
                    @(modalComandaEditandoId == Guid.Empty ? "Cadastrar Comanda" : "Editar Comanda")
                </h2>
                <button style="background: none; border: none; color: var(--cor-texto-sub); font-size: 20px; cursor: pointer;" @onclick="FecharModalComanda">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(erroModalComanda))
            {
                <div class="alert-error-box" style="margin-bottom: 20px;">@erroModalComanda</div>
            }

            <div class="form-grid">
                <div class="form-grupo" style="grid-column: span 12;">
                    <label>Número da Comanda *</label>
                    <input type="number" class="form-control" @bind="comandaModel.numero" min="1" />
                </div>

                <div class="form-grupo" style="grid-column: span 12;">
                    <label>Código de Barras / QR Code (Opcional)</label>
                    <input type="text" class="form-control" @bind="comandaModel.codigo_barras_qr_futuro" placeholder="Código de barras da comanda..." />
                </div>

                <div class="form-grupo" style="grid-column: span 12;">
                    <label>Observação / Observações de Alerta</label>
                    <input type="text" class="form-control" @bind="comandaModel.observacao" placeholder="Ex: Comanda do balcão 2..." />
                </div>

                <div class="form-grupo" style="grid-column: span 12; margin-top: 10px;">
                    <label class="checkbox-premium">
                        <input type="checkbox" @bind="comandaModel.ativo" />
                        <span>Comanda Ativa para Atendimento</span>
                    </label>
                </div>
            </div>

            <div class="modal-actions" style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-outline" @onclick="FecharModalComanda">Cancelar</button>
                <button class="btn btn-primary" @onclick="SalvarComanda">Salvar Registro</button>
            </div>
        </div>
    </div>
}

<style>
    .header-pagina { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .titulo-pagina { font-size: 30px; font-weight: 700; color: #fff; }
    .subtitulo-pagina { color: var(--cor-texto-sub); font-size: 14px; }
    
    .badge { font-size: 11px; padding: 3px 8px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-success { background: rgba(16,185,129,0.12); color: #38ef7d; border: 1px solid rgba(16,185,129,0.25); }
    .badge-error { background: rgba(239,68,68,0.12); color: #ff4b2b; border: 1px solid rgba(239,68,68,0.25); }

    .btn-sm { padding: 4px 10px; font-size: 12px; border-radius: 6px; }
    .btn-outline { background: transparent; border: 1px solid var(--cor-borda); color: var(--cor-texto-sub); transition: all 0.2s ease; cursor: pointer; }
    .btn-outline:hover { background: rgba(255,255,255,0.05); color: #fff; border-color: rgba(255,255,255,0.2); }

    .checkbox-premium {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--cor-borda);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
    }
    .checkbox-premium:hover {
        background: rgba(0, 198, 255, 0.03);
        border-color: var(--cor-borda-glow);
    }
    .checkbox-premium input[type=checkbox] {
        width: 18px;
        height: 18px;
        accent-color: #00c6ff;
        cursor: pointer;
    }

    .modal-backdrop { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1100; }
    
    .alert-error-box { background: rgba(255,75,43,0.1); color: #ff4b2b; border: 1px solid rgba(255,75,43,0.2); padding: 12px 16px; border-radius: 8px; font-size: 14px; }
    .loading-state { text-align: center; color: var(--cor-texto-sub); padding: 64px; font-size: 16px; }
</style>

@code {
    private string abaAtiva = "PARAMETROS";
    private bool carregando = true;
    private string? erroGeral, erroModalComanda;
    private bool sucessoSalvarConfig = false;

    private ConfigComandasDto config = new();
    private List<ComandaDto> comandas = new();

    private bool mostrarModalComanda = false;
    private Guid modalComandaEditandoId = Guid.Empty;
    private ComandaInput comandaModel = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private void SetAba(string aba)
    {
        abaAtiva = aba;
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var resConf = await Http.GetFromJsonAsync<Resposta<ConfigComandasDto>>("/configuracoes/operacionais/comandas/configuracao");
            if (resConf?.sucesso == true && resConf.dados != null) config = resConf.dados;

            var resComandas = await Http.GetFromJsonAsync<Resposta<List<ComandaDto>>>("/configuracoes/operacionais/comandas");
            if (resComandas?.sucesso == true) comandas = resComandas.dados ?? new();
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task SalvarConfiguracao()
    {
        erroGeral = null; sucessoSalvarConfig = false;
        if (config.faixa_inicial > config.faixa_final)
        {
            erroGeral = "A faixa inicial deve ser menor ou igual à faixa final.";
            return;
        }

        try
        {
            var res = await Http.PostAsJsonAsync("/configuracoes/operacionais/comandas/configuracao", config);
            if (res.IsSuccessStatusCode)
            {
                sucessoSalvarConfig = true;
                StateHasChanged();
                await Task.Delay(3000);
                sucessoSalvarConfig = false;
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroGeral = err?.mensagem ?? "Erro ao salvar parâmetros globais.";
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de rede: " + ex.Message;
        }
    }

    private void AbrirModalNovaComanda()
    {
        modalComandaEditandoId = Guid.Empty;
        comandaModel = new ComandaInput { numero = comandas.Count + 1, ativo = true };
        erroModalComanda = null;
        mostrarModalComanda = true;
    }

    private void AbrirModalEditarComanda(ComandaDto c)
    {
        modalComandaEditandoId = c.id;
        comandaModel = new ComandaInput
        {
            numero = c.numero,
            codigo_barras_qr_futuro = c.codigo_barras_qr_futuro,
            ativo = c.ativo,
            observacao = c.observacao
        };
        erroModalComanda = null;
        mostrarModalComanda = true;
    }

    private async Task SalvarComanda()
    {
        erroModalComanda = null;
        if (comandaModel.numero <= 0)
        {
            erroModalComanda = "Número da comanda deve ser maior que zero.";
            return;
        }

        try
        {
            HttpResponseMessage res;
            if (modalComandaEditandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/configuracoes/operacionais/comandas", comandaModel);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/configuracoes/operacionais/comandas/{modalComandaEditandoId}", comandaModel);
            }

            if (res.IsSuccessStatusCode)
            {
                mostrarModalComanda = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModalComanda = err?.mensagem ?? "Erro ao salvar comanda.";
            }
        }
        catch (Exception ex)
        {
            erroModalComanda = "Erro ao enviar requisição: " + ex.Message;
        }
    }

    private void FecharModalComanda() => mostrarModalComanda = false;

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class ConfigComandasDto
    {
        public Guid id { get; set; }
        public bool comandas_ativas { get; set; } = true;
        public int faixa_inicial { get; set; } = 1;
        public int faixa_final { get; set; } = 100;
        public bool permitir_nome_informal { get; set; } = true;
        public bool permitir_transferencia_comanda { get; set; } = true;
        public bool permitir_transferencia_parcial_itens { get; set; } = true;
        public bool imprimir_producao_por_comanda { get; set; } = true;
        public bool bloquear_comanda_com_pendencia { get; set; } = false;
        public bool ativo { get; set; } = true;
    }

    public class ComandaDto
    {
        public Guid id { get; set; }
        public int numero { get; set; }
        public string? codigo_barras_qr_futuro { get; set; }
        public bool ativo { get; set; }
        public string? observacao { get; set; }
    }

    public class ComandaInput
    {
        public int numero { get; set; }
        public string? codigo_barras_qr_futuro { get; set; }
        public bool ativo { get; set; } = true;
        public string? observacao { get; set; }
    }
}
