@page "/configuracoes/operacionais/pre-vendas"
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Configurações de Pré-Vendas — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Configurações de Pré-Vendas</h1>
        <p class="subtitulo-pagina">Gerencie prazos de expiração, reservas de estoque e regras de preenchimento para pré-vendas operacionais.</p>
    </div>
</div>

<SubmenuOperacionais />

@if (carregando)
{
    <div class="loading-state fade-in">Carregando parâmetros operacionais de pré-vendas...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box fade-in">@erroGeral</div>
}
else
{
    <div class="card-glass fade-in" style="padding: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px; margin-bottom: 24px;">
            <h3 style="color: #fff; margin: 0; font-size: 18px; display: flex; align-items: center; gap: 8px;">
                <span>🛍️</span> Parâmetros de Pré-Vendas
            </h3>
            @if (sucesso)
            {
                <span class="badge badge-success fade-in">✓ Parâmetros Salvos!</span>
            }
        </div>

        <div class="form-grid">
            <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                <label class="checkbox-premium">
                    <input type="checkbox" @bind="config.permitir_pre_venda_pdv" />
                    <span>Permitir Pré-Vendas no PDV</span>
                </label>
            </div>

            <div class="form-grupo" style="grid-column: span 4;">
                <label>Validade das Pré-Vendas (Horas)</label>
                <input type="number" class="form-control" @bind="config.validade_horas_pre_venda" min="1" />
            </div>

            <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                <label class="checkbox-premium">
                    <input type="checkbox" @bind="config.exigir_cliente_pre_venda" />
                    <span>Exigir Identificação do Cliente</span>
                </label>
            </div>

            <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                <label class="checkbox-premium">
                    <input type="checkbox" @bind="config.reservar_estoque_pre_venda" />
                    <span>Reservar Estoque ao Criar</span>
                </label>
            </div>

            <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                <label class="checkbox-premium">
                    <input type="checkbox" @bind="config.ativo" />
                    <span>Configuração Ativa</span>
                </label>
            </div>
        </div>

        <div style="margin-top: 32px; display: flex; justify-content: flex-end; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
            <button class="btn btn-primary" style="padding: 12px 32px;" @onclick="Salvar">
                Salvar Configurações
            </button>
        </div>
    </div>
}

<style>
    .header-pagina { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
    .titulo-pagina { font-size: 30px; font-weight: 700; color: #fff; }
    .subtitulo-pagina { color: var(--cor-texto-sub); font-size: 14px; }
    
    .badge { font-size: 11px; padding: 4px 10px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
    .badge-success { background: rgba(16,185,129,0.12); color: #38ef7d; border: 1px solid rgba(16,185,129,0.25); }

    .checkbox-premium {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 14px;
        color: #fff;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--cor-borda);
        padding: 10px 14px;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s ease;
        height: 42px;
    }
    .checkbox-premium:hover {
        background: rgba(0, 198, 255, 0.03);
        border-color: var(--cor-borda-glow);
    }
    .checkbox-premium input[type=checkbox] {
        width: 18px;
        height: 18px;
        accent-color: #00c6ff;
        cursor: pointer;
    }

    .alert-error-box { background: rgba(255,75,43,0.1); color: #ff4b2b; border: 1px solid rgba(255,75,43,0.2); padding: 12px 16px; border-radius: 8px; font-size: 14px; }
    .loading-state { text-align: center; color: var(--cor-texto-sub); padding: 64px; font-size: 16px; }
</style>

@code {
    private bool carregando = true;
    private string? erroGeral;
    private bool sucesso = false;

    private PreVendaConfigDto config = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null; sucesso = false;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<PreVendaConfigDto>>("/configuracoes/operacionais/pre-vendas");
            if (res?.sucesso == true && res.dados != null)
            {
                config = res.dados;
            }
            else
            {
                erroGeral = res?.mensagem ?? "Erro ao carregar configurações de pré-venda.";
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private async Task Salvar()
    {
        erroGeral = null; sucesso = false;
        if (config.validade_horas_pre_venda <= 0)
        {
            erroGeral = "Validade de pré-vendas deve ser de no mínimo 1 hora.";
            return;
        }

        try
        {
            var res = await Http.PostAsJsonAsync("/configuracoes/operacionais/pre-vendas", config);
            if (res.IsSuccessStatusCode)
            {
                sucesso = true;
                StateHasChanged();
                await Task.Delay(3000);
                sucesso = false;
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroGeral = err?.mensagem ?? "Erro ao salvar configurações de pré-venda.";
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro ao enviar requisição: " + ex.Message;
        }
    }

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class PreVendaConfigDto
    {
        public Guid id { get; set; }
        public Guid empresa_id { get; set; }
        public bool permitir_pre_venda_pdv { get; set; } = true;
        public int validade_horas_pre_venda { get; set; } = 24;
        public bool exigir_cliente_pre_venda { get; set; } = false;
        public bool reservar_estoque_pre_venda { get; set; } = true;
        public bool ativo { get; set; } = true;
    }
}
