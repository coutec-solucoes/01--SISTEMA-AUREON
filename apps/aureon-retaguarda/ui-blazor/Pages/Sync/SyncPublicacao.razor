@page "/configuracoes/sync/publicacao"
@using System.Net.Http.Json
@inject HttpClient Http

<h3>Publicação de Dados Mestres</h3>

<button class="btn btn-primary" @onclick="PublicarDados">Publicar Dados Mestres</button>

@if (!string.IsNullOrEmpty(mensagem))
{
    <div class="alert alert-info mt-3">@mensagem</div>
}

@code {
    private string mensagem = "";

    private async Task PublicarDados()
    {
        try
        {
            var res = await Http.PostAsJsonAsync("http://localhost:7000/sync/publicar", new { tipo_publicacao = "GERAL" });
            var conteudo = await res.Content.ReadFromJsonAsync<RespostaBase<object>>();
            if (conteudo != null && conteudo.Sucesso)
            {
                mensagem = "Publicação realizada com sucesso.";
            }
            else
            {
                mensagem = $"Erro: {conteudo?.Mensagem}";
            }
        }
        catch (Exception ex)
        {
            mensagem = $"Erro: {ex.Message}";
        }
    }

    public class RespostaBase<T>
    {
        public string Mensagem { get; set; } = "";
        public bool Sucesso { get; set; }
        public T? Dados { get; set; }
    }
}
