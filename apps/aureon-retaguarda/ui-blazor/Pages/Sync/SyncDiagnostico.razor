@page "/configuracoes/sync/diagnostico"

<h3>Diagnóstico de Sincronização</h3>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Terminais Ativos</h5>
                <p class="card-text">3</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Pendentes</h5>
                <p class="card-text">1</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Com Erro</h5>
                <p class="card-text">0</p>
            </div>
        </div>
    </div>
</div>

<button class="btn btn-secondary mt-3">Atualizar Diagnóstico</button>

