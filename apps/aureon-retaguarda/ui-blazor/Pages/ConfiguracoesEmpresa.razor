        <!-- ABA 12: Crédito & Offline -->
        @if (_abaAtiva == 12)
        {
            <h3 style="color: #fff; margin-bottom: 24px;">Bloco 12: Regras de Crédito (Crediário) & Limite Offline</h3>
            
            <div class="form-grid">
                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_param.permitir_venda_prazo" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <span style="font-weight: bold; color: #fff; display: block;">Habilitar Vendas a Prazo (Crediário/Fiado)</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Habilita a modalidade de pagamento em conta cliente.</span>
                    </div>
                </div>

                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_param.exigir_cliente_completo_crediario" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <span style="font-weight: bold; color: #fff; display: block;">Exigir Cadastro Completo para Crediário</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Bloqueia vendas a prazo para clientes sem endereço e telefone informados.</span>
                    </div>
                </div>

                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px; margin-top: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_param.permitir_venda_offline" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <span style="font-weight: bold; color: #fff; display: block;">Permitir Funcionamento Totalmente Offline</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Habilita a gravação de vendas localmente no SQLite/Tauri sem conexão com o servidor.</span>
                    </div>
                </div>

                <div class="form-grupo col-6" style="grid-column: span 6; margin-top: 16px;">
                    <label>Limite Máximo de Dias em Modo Offline</label>
                    <input type="number" class="form-control" @bind="_param.dias_maximos_offline" />
                </div>
            </div>
        }

        <!-- ABA 13: Histórico de Auditoria -->
        @if (_abaAtiva == 13)
        {
            <h3 style="color: #fff; margin-bottom: 24px;">Bloco 13: Log de Auditoria & Eventos de Segurança</h3>
            <p style="color: var(--cor-texto-sub); margin-bottom: 24px; font-size: 14px;">
                Exibição em tempo real dos últimos 100 eventos críticos que alteraram as configurações deste estabelecimento.
            </p>

            <div class="tabela-container">
                <table class="tabela-premium">
                    <thead>
                        <tr>
                            <th>Data/Hora</th>
                            <th>Ação</th>
                            <th>Módulo/Tabela</th>
                            <th>Entidade ID</th>
                            <th>Motivo / Histórico</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_auditoriaEventos.Count == 0)
                        {
                            <tr>
                                <td colspan="5" style="text-align: center; color: var(--cor-texto-disabled);">Nenhum evento registrado no log de auditoria.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var ev in _auditoriaEventos)
                            {
                                <tr>
                                    <td style="white-space: nowrap; color: #fff;">@ev.criado_em.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>
                                        <span class="tag-badge @ev.acao.ToLower()">@ev.acao</span>
                                    </td>
                                    <td style="font-family: monospace;">@ev.entidade</td>
                                    <td style="font-family: monospace; font-size: 12px; color: var(--cor-texto-sub);">@ev.entidade_id</td>
                                    <td>@ev.motivo</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    }

</div>

@code {
    private int _abaAtiva = 1;
    private bool _carregando = true;
    private bool _salvando = false;
    private string? _mensagemSucesso;
    private string? _mensagemErro;

    // Modelos locais
    private EmpresaConfiguracaoCompleta _config = new();
    private EmpresaMoedasCompleta _moedasConfig = new();
    private List<MoedaConfig> _moedasDisponiveis = new();
    private List<CotacaoExibicao> _cotacoes = new();
    private CotacaoCadastro _novaCotacao = new() { moeda_origem_codigo = "USD", moeda_destino_codigo = "BRL" };
    private string _taxaInversaCalculada = "0.00";
    private FiscalBaseCompleto _fiscal = new() 
    { 
        brasil = new() { regime_tributario = "SIMPLES_NACIONAL", ambiente = "HOMOLOGACAO" },
        paraguai = new() { regime_tributario = "REGIME_GERAL", ambiente = "TESTE" }
    };
    private ParametrosOperacionais _param = new();
    private List<AuditoriaEvento> _auditoriaEventos = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    private async Task CarregarDados()
    {
        _carregando = true;
        _mensagemErro = null;
        _mensagemSucesso = null;

        try
        {
            // 1. Carrega dados gerais da empresa (Identificação/Contatos)
            var resEmp = await Http.GetFromJsonAsync<ResBase<EmpresaConfiguracaoCompleta>>("/empresa/configuracao");
            if (resEmp != null && resEmp.sucesso && resEmp.dados != null)
            {
                _config = resEmp.dados;
            }

            // 2. Carrega moedas associadas
            var resMoe = await Http.GetFromJsonAsync<ResBase<EmpresaMoedasCompleta>>("/empresa/moedas");
            if (resMoe != null && resMoe.sucesso && resMoe.dados != null)
            {
                _moedasConfig = resMoe.dados;
            }

            // 3. Define moedas estáticas
            _moedasDisponiveis = new List<MoedaConfig>
            {
                new() { moeda_id = Guid.Parse("b1111111-1111-1111-1111-111111111111"), codigo = "BRL", nome = "Real Brasileiro", simbolo = "R$", tipo_moeda = "PRINCIPAL", ordem_exibicao = 1 },
                new() { moeda_id = Guid.Parse("b2222222-2222-2222-2222-222222222222"), codigo = "PYG", nome = "Guarani Paraguaio", simbolo = "₲", tipo_moeda = "SECUNDARIA", ordem_exibicao = 2 },
                new() { moeda_id = Guid.Parse("b3333333-3333-3333-3333-333333333333"), codigo = "USD", nome = "Dólar Americano", simbolo = "$", tipo_moeda = "SECUNDARIA", ordem_exibicao = 3 }
            };

            // Atualiza status de principal/secundária com base no que veio do banco
            if (_moedasConfig.moedas != null && _moedasConfig.moedas.Count == 0 == false)
            {
                foreach (var m in _moedasDisponiveis)
                {
                    var cadastrada = _moedasConfig.moedas.Find(x => x.codigo == m.codigo);
                    if (cadastrada != null)
                    {
                        m.tipo_moeda = cadastrada.tipo_moeda;
                        m.ordem_exibicao = cadastrada.ordem_exibicao;
                    }
                }
            }

            // 4. Carrega cotações do dia
            var resCot = await Http.GetFromJsonAsync<ResBase<List<CotacaoExibicao>>>("/empresa/cotacoes");
            if (resCot != null && resCot.sucesso && resCot.dados != null)
            {
                _cotacoes = resCot.dados;
            }

            // 5. Carrega regras fiscais
            var resFis = await Http.GetFromJsonAsync<ResBase<FiscalBaseCompleto>>("/empresa/fiscal");
            if (resFis != null && resFis.sucesso && resFis.dados != null)
            {
                _fiscal = resFis.dados;
                if (_fiscal.brasil == null) _fiscal.brasil = new() { regime_tributario = "SIMPLES_NACIONAL", ambiente = "HOMOLOGACAO" };
                if (_fiscal.paraguai == null) _fiscal.paraguai = new() { regime_tributario = "REGIME_GERAL", ambiente = "TESTE" };
            }

            // 6. Carrega parâmetros operacionais
            var resPar = await Http.GetFromJsonAsync<ResBase<ParametrosOperacionais>>("/empresa/parametros-operacionais");
            if (resPar != null && resPar.sucesso && resPar.dados != null)
            {
                _param = resPar.dados;
            }

            // 7. Carrega log de auditoria
            var resAud = await Http.GetFromJsonAsync<ResBase<List<AuditoriaEvento>>>("/empresa/auditoria");
            if (resAud != null && resAud.sucesso && resAud.dados != null)
            {
                _auditoriaEventos = resAud.dados;
            }
        }
        catch (Exception ex)
        {
            _mensagemErro = $"Erro ao carregar dados da API local: {ex.Message}";
        }
        finally
        {
            _carregando = false;
        }
    }

    private void MudarAba(int aba)
    {
        _abaAtiva = aba;
        _mensagemSucesso = null;
        _mensagemErro = null;
    }

    private bool AbaAtiva(int aba) => _abaAtiva == aba;

    private bool EstaMoedaHabilitada(Guid id)
    {
        if (_moedasConfig.moedas == null) return false;
        return _moedasConfig.moedas.Exists(x => x.moeda_id == id);
    }

    private void ToggleMoeda(MoedaConfig moeda, ChangeEventArgs e)
    {
        if (e.Value is bool checkedValue)
        {
            if (checkedValue)
            {
                if (_moedasConfig.moedas == null) _moedasConfig.moedas = new();
                if (!_moedasConfig.moedas.Exists(x => x.moeda_id == moeda.moeda_id))
                {
                    _moedasConfig.moedas.Add(moeda);
                }
            }
            else
            {
                _moedasConfig.moedas?.RemoveAll(x => x.moeda_id == moeda.moeda_id);
            }
        }
    }

    private void AlterarTipoMoeda(MoedaConfig moeda, ChangeEventArgs e)
    {
        if (e.Value is string valor)
        {
            moeda.tipo_moeda = valor;
            if (valor == "PRINCIPAL")
            {
                // Garante que só ela é a principal
                foreach (var m in _moedasDisponiveis)
                {
                    if (m.moeda_id != moeda.moeda_id)
                    {
                        m.tipo_moeda = "SECUNDARIA";
                    }
                }
            }
        }
    }

    private void OnTaxaDiretaChanged(ChangeEventArgs e)
    {
        if (e.Value is string str && decimal.TryParse(str, out var taxa) && taxa > 0)
        {
            _novaCotacao.taxa_direta = taxa;
            var inv = 1m / taxa;
            _taxaInversaCalculada = inv.ToString("N6");
        }
        else
        {
            _taxaInversaCalculada = "0.00";
        }
    }

    private async Task GravarCotacao()
    {
        _mensagemErro = null;
        _mensagemSucesso = null;

        if (_novaCotacao.taxa_direta <= 0)
        {
            _mensagemErro = "A taxa direta de cotação deve ser maior que zero.";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("/empresa/cotacoes", _novaCotacao);
            var res = await response.Content.ReadFromJsonAsync<ResBase<bool>>();
            if (res != null && res.sucesso)
            {
                _mensagemSucesso = "Cotação diária gravada com absoluto sucesso!";
                // Reseta
                _novaCotacao = new() { moeda_origem_codigo = "USD", moeda_destino_codigo = "BRL" };
                _taxaInversaCalculada = "0.00";
                // Recarrega cotações e auditoria
                await CarregarDados();
            }
            else
            {
                _mensagemErro = res?.mensagem ?? "Erro ao gravar cotação.";
            }
        }
        catch (Exception ex)
        {
            _mensagemErro = $"Erro de rede: {ex.Message}";
        }
    }

    private async Task CancelarCotacao(Guid id)
    {
        _mensagemErro = null;
        _mensagemSucesso = null;

        try
        {
            var response = await Http.PutAsync($"/empresa/cotacoes/{id}/cancelar", null);
            var res = await response.Content.ReadFromJsonAsync<ResBase<bool>>();
            if (res != null && res.sucesso)
            {
                _mensagemSucesso = "Cotação cancelada com absoluto sucesso!";
                await CarregarDados();
            }
            else
            {
                _mensagemErro = res?.mensagem ?? "Erro ao cancelar cotação.";
            }
        }
        catch (Exception ex)
        {
            _mensagemErro = $"Erro ao cancelar: {ex.Message}";
        }
    }

    private async Task SalvarTudo()
    {
        _salvando = true;
        _mensagemErro = null;
        _mensagemSucesso = null;

        try
        {
            // Validações básicas
            if (string.IsNullOrWhiteSpace(_config.nome_fantasia))
            {
                _mensagemErro = "O Nome Fantasia é obrigatório.";
                return;
            }
            if (string.IsNullOrWhiteSpace(_config.razao_social))
            {
                _mensagemErro = "A Razão Social é obrigatória.";
                return;
            }

            // 1. Salvar Configurações Gerais
            var res1 = await Http.PostAsJsonAsync("/empresa/configuracao", _config);
            var r1 = await res1.Content.ReadFromJsonAsync<ResBase<bool>>();
            if (r1 == null || !r1.sucesso)
            {
                _mensagemErro = r1?.mensagem ?? "Erro ao salvar informações gerais da empresa.";
                return;
            }

            // 2. Salvar Moedas Habilitadas
            // Sincroniza lista da config com as marcadas
            _moedasConfig.moedas = new();
            foreach (var m in _moedasDisponiveis)
            {
                if (m.tipo_moeda == "PRINCIPAL" || EstaMoedaHabilitada(m.moeda_id))
                {
                    _moedasConfig.moedas.Add(m);
                }
            }

            var res2 = await Http.PutAsJsonAsync("/empresa/moedas", _moedasConfig);
            var r2 = await res2.Content.ReadFromJsonAsync<ResBase<bool>>();
            if (r2 == null || !r2.sucesso)
            {
                _mensagemErro = r2?.mensagem ?? "Erro ao salvar moedas da empresa.";
                return;
            }

            // 3. Salvar Fiscal Base
            var res3 = await Http.PutAsJsonAsync("/empresa/fiscal", _fiscal);
            var r3 = await res3.Content.ReadFromJsonAsync<ResBase<bool>>();
            if (r3 == null || !r3.sucesso)
            {
                _mensagemErro = r3?.mensagem ?? "Erro ao salvar parâmetros fiscais.";
                return;
            }

            // 4. Salvar Parâmetros Operacionais
            var res4 = await Http.PutAsJsonAsync("/empresa/parametros-operacionais", _param);
            var r4 = await res4.Content.ReadFromJsonAsync<ResBase<bool>>();
            if (r4 == null || !r4.sucesso)
            {
                _mensagemErro = r4?.mensagem ?? "Erro ao salvar parâmetros operacionais.";
                return;
            }

            _mensagemSucesso = "Todas as 13 seções de configuração da Fase 2 foram gravadas com sucesso no PostgreSQL!";
            await CarregarDados();
        }
        catch (Exception ex)
        {
            _mensagemErro = $"Erro geral de salvamento: {ex.Message}";
        }
        finally
        {
            _salvando = false;
        }
    }

