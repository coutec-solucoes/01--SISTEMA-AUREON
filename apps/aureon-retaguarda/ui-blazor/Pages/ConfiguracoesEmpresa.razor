@page "/configuracoes/empresa"
@inject HttpClient Http
@using System.Text.Json

<PageTitle>Configurações da Empresa — Aureon Gestor</PageTitle>

<div class="cabecalho-pagina">
    <div class="cabecalho-titulo">
        <h1>Configurações da Empresa</h1>
        <p>Gerencie o cadastro, as moedas, as políticas fiscais, as regras operacionais e audite as alterações.</p>
    </div>
    
    <div>
        <button class="btn-premium" @onclick="SalvarTudo" disabled="@_salvando">
            @if (_salvando)
            {
                <span>⏳ Salvando...</span>
            }
            else
            {
                <span>💾 Salvar Configurações</span>
            }
        </button>
    </div>
</div>

@if (_mensagemSucesso != null)
{
    <div class="alerta-container sucesso">
        <span>✅ @_mensagemSucesso</span>
    </div>
}

@if (_mensagemErro != null)
{
    <div class="alerta-container erro">
        <span>⚠️ @_mensagemErro</span>
    </div>
}

<!-- Barra de Abas Horizontal Premium (Fase 2 - 13 Blocos Reorganizados por Área) -->
<div class="abas-container">
    <button class="aba-botao @(AbaAtiva(1) ? "ativa" : "")" @onclick="() => MudarAba(1)">
        <span class="aba-numero">1</span> Identificação Geral
    </button>
    <button class="aba-botao @(AbaAtiva(2) ? "ativa" : "")" @onclick="() => MudarAba(2)">
        <span class="aba-numero">2</span> Contatos & Endereço
    </button>
    <button class="aba-botao @(AbaAtiva(3) ? "ativa" : "")" @onclick="() => MudarAba(3)">
        <span class="aba-numero">3</span> Moedas & Multimoeda
    </button>
    <button class="aba-botao @(AbaAtiva(4) ? "ativa" : "")" @onclick="() => MudarAba(4)">
        <span class="aba-numero">4</span> Cotações do Dia
    </button>
    <button class="aba-botao @(AbaAtiva(5) ? "ativa" : "")" @onclick="() => MudarAba(5)">
        <span class="aba-numero">5</span> Regime Tributário
    </button>
    <button class="aba-botao @(AbaAtiva(6) ? "ativa" : "")" @onclick="() => MudarAba(6)">
        <span class="aba-numero">6</span> Documentos Fiscais
    </button>
    <button class="aba-botao @(AbaAtiva(7) ? "ativa" : "")" @onclick="() => MudarAba(7)">
        <span class="aba-numero">7</span> Regras Tributárias Base
    </button>
    <button class="aba-botao @(AbaAtiva(8) ? "ativa" : "")" @onclick="() => MudarAba(8)">
        <span class="aba-numero">8</span> Ambiente Fiscal
    </button>
    <button class="aba-botao @(AbaAtiva(9) ? "ativa" : "")" @onclick="() => MudarAba(9)">
        <span class="aba-numero">9</span> Provedores Fiscais
    </button>
    <button class="aba-botao @(AbaAtiva(10) ? "ativa" : "")" @onclick="() => MudarAba(10)">
        <span class="aba-numero">10</span> Controle de Estoque
    </button>
    <button class="aba-botao @(AbaAtiva(11) ? "ativa" : "")" @onclick="() => MudarAba(11)">
        <span class="aba-numero">11</span> Parâmetros do PDV
    </button>
    <button class="aba-botao @(AbaAtiva(12) ? "ativa" : "")" @onclick="() => MudarAba(12)">
        <span class="aba-numero">12</span> Crédito & Offline
    </button>
    <button class="aba-botao @(AbaAtiva(13) ? "ativa" : "")" @onclick="() => MudarAba(13)">
        <span class="aba-numero">13</span> Histórico de Auditoria
    </button>
</div>

<!-- CONTEÚDO DAS ABAS -->
<div class="card-glass">

    @if (_carregando)
    {
        <div style="text-align: center; padding: 48px;">
            <div class="splash-icon">⏳</div>
            <p style="color: var(--cor-texto-sub); margin-top: 16px;">Carregando dados da API Local...</p>
        </div>
    }
    else
    {
        <!-- ABA 1: Identificação Geral -->
        @if (_abaAtiva == 1)
        {
            <h3 style="color: #fff; margin-bottom: 24px;">Bloco 1: Identificação Geral do Estabelecimento</h3>
            <div class="form-grid">
                <div class="form-grupo col-6" style="grid-column: span 6;">
                    <label>Nome Fantasia (Obrigatório)</label>
                    <input type="text" class="form-control" @bind="_config.nome_fantasia" placeholder="Ex: Aureon Store" />
                </div>
                <div class="form-grupo col-6" style="grid-column: span 6;">
                    <label>Razão Social (Obrigatório)</label>
                    <input type="text" class="form-control" @bind="_config.razao_social" placeholder="Ex: Aureon Comércio Inteligente Ltda" />
                </div>
                
                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 16px;">
                    <label>Tipo de Pessoa</label>
                    <select class="form-control" @bind="_config.tipo_pessoa">
                        <option value="JURIDICA">Pessoa Jurídica</option>
                        <option value="FISICA">Pessoa Física</option>
                    </select>
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 16px;">
                    <label>Status Operacional</label>
                    <select class="form-control" @bind="_config.status_empresa">
                        <option value="EM_CONFIGURACAO">Em Configuração (Bloqueia Caixa)</option>
                        <option value="ATIVA">Ativa (Libera Caixa/Vendas)</option>
                        <option value="SUSPENSA">Suspensa</option>
                    </select>
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 16px;">
                    <label>Código da Empresa</label>
                    <input type="text" class="form-control" @bind="_config.codigo" disabled />
                </div>

                <div class="form-grupo col-12" style="grid-column: span 12; margin-top: 16px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                    <h4 style="color: var(--primaria); margin-bottom: 8px;">Documentação Fiscal Base</h4>
                    <p style="color: var(--cor-texto-sub); font-size: 13px;">Preencha os documentos fiscais base do seu país.</p>
                </div>

                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>CNPJ (Brasil)</label>
                    <input type="text" class="form-control" @bind="_config.cnpj" placeholder="00.000.000/0000-00" />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Inscrição Estadual (IE)</label>
                    <input type="text" class="form-control" @bind="_config.inscricao_estadual" placeholder="IE do Estado" />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Inscrição Municipal (IM)</label>
                    <input type="text" class="form-control" @bind="_config.inscricao_municipal" placeholder="IM do Município" />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>CPF (Brasil - Pessoa Física)</label>
                    <input type="text" class="form-control" @bind="_config.cpf" placeholder="000.000.000-00" />
                </div>

                <div class="form-grupo col-3" style="grid-column: span 3; margin-top: 16px;">
                    <label>RUC (Paraguai)</label>
                    <input type="text" class="form-control" @bind="_config.ruc" placeholder="Ex: 80012345-6" />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3; margin-top: 16px;">
                    <label>Cédula de Identidade (CI)</label>
                    <input type="text" class="form-control" @bind="_config.ci" placeholder="Ex: 1234567" />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3; margin-top: 16px;">
                    <label>Registro Geral (RG)</label>
                    <input type="text" class="form-control" @bind="_config.rg" placeholder="Registro geral de identidade" />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3; margin-top: 16px;">
                    <label>Observações Internas</label>
                    <input type="text" class="form-control" @bind="_config.observacoes" placeholder="Notas sobre a empresa" />
                </div>
            </div>
        }

        <!-- ABA 2: Contatos & Endereço -->
        @if (_abaAtiva == 2)
        {
            <h3 style="color: #fff; margin-bottom: 24px;">Bloco 2: Contatos, Localização & Idioma</h3>
            <div class="form-grid">
                <div class="form-grupo col-4" style="grid-column: span 4;">
                    <label>Telefone Principal</label>
                    <input type="text" class="form-control" @bind="_config.telefone_principal" placeholder="Ex: 45 3522-0000" />
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4;">
                    <label>WhatsApp (Notificações)</label>
                    <input type="text" class="form-control" @bind="_config.whatsapp" placeholder="Ex: 45 99999-9999" />
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4;">
                    <label>E-mail de Contato</label>
                    <input type="email" class="form-control" @bind="_config.email" placeholder="financeiro@aureon.com" />
                </div>

                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 16px;">
                    <label>Responsável Legal</label>
                    <input type="text" class="form-control" @bind="_config.responsavel" placeholder="Ex: Administrador Principal" />
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 16px;">
                    <label>Site Oficial</label>
                    <input type="text" class="form-control" @bind="_config.site" placeholder="https://aureon.com.br" />
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 16px;">
                    <label>País Operacional</label>
                    <select class="form-control" @bind="_config.pais">
                        <option value="BR">Brasil</option>
                        <option value="PY">Paraguai</option>
                    </select>
                </div>

                <div class="form-grupo col-12" style="grid-column: span 12; margin-top: 16px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                    <h4 style="color: var(--primaria); margin-bottom: 8px;">Endereço Físico</h4>
                </div>

                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>CEP / Código Postal</label>
                    <input type="text" class="form-control" @bind="_config.cep" placeholder="85851-000" />
                </div>
                <div class="form-grupo col-2" style="grid-column: span 2;">
                    <label>Estado / Departamento</label>
                    <input type="text" class="form-control" @bind="_config.estado" placeholder="PR, Alto Paraná..." />
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4;">
                    <label>Cidade</label>
                    <input type="text" class="form-control" @bind="_config.cidade" placeholder="Foz do Iguaçu, Ciudad del Este..." />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Bairro</label>
                    <input type="text" class="form-control" @bind="_config.bairro" placeholder="Centro, Boquerón..." />
                </div>

                <div class="form-grupo col-6" style="grid-column: span 6; margin-top: 16px;">
                    <label>Logradouro / Rua</label>
                    <input type="text" class="form-control" @bind="_config.logradouro" placeholder="Avenida Brasil" />
                </div>
                <div class="form-grupo col-2" style="grid-column: span 2; margin-top: 16px;">
                    <label>Número</label>
                    <input type="text" class="form-control" @bind="_config.numero" placeholder="123" />
                </div>
                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 16px;">
                    <label>Complemento</label>
                    <input type="text" class="form-control" @bind="_config.complemento" placeholder="Sala 402, Bloco A" />
                </div>

                <div class="form-grupo col-12" style="grid-column: span 12; margin-top: 24px; border-top: 1px solid var(--cor-borda); padding-top: 24px;">
                    <h4 style="color: var(--primaria); margin-bottom: 16px;">Configuração de Idiomas do Sistema</h4>
                </div>

                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Idioma Principal Painel</label>
                    <select class="form-control" @bind="_config.idioma_padrao">
                        <option value="pt-BR">Português (Brasil)</option>
                        <option value="es-PY">Espanhol (Paraguai)</option>
                        <option value="en-US">Inglês</option>
                    </select>
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Idioma Comprovantes (PDV)</label>
                    <select class="form-control" @bind="_config.idioma_comprovantes">
                        <option value="pt-BR">Português (Brasil)</option>
                        <option value="es-PY">Espanhol (Paraguai)</option>
                    </select>
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Idioma Autoatendimento</label>
                    <select class="form-control" @bind="_config.idioma_autoatendimento">
                        <option value="pt-BR">Português (Brasil)</option>
                        <option value="es-PY">Espanhol (Paraguai)</option>
                        <option value="en-US">Inglês</option>
                    </select>
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3; display: flex; flex-direction: row; align-items: center; gap: 12px; margin-top: 24px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_config.permitir_idioma_usuario" />
                        <span class="slider"></span>
                    </label>
                    <span style="font-size: 13px; font-weight: 600; color: var(--cor-texto-sub);">Permitir alterar idioma por usuário</span>
                </div>
            </div>
        }

        <!-- ABA 3: Moedas & Multimoeda -->
        @if (_abaAtiva == 3)
        {
            <h3 style="color: #fff; margin-bottom: 24px;">Bloco 3: Moedas Operacionais & Multimoeda</h3>
            
            <div style="background: rgba(0, 198, 255, 0.03); border: 1px solid var(--cor-borda-glow); padding: 20px; border-radius: 12px; margin-bottom: 32px;">
                <h4 style="color: var(--primaria); margin-bottom: 8px;">Modelo Multimoeda Aureon</h4>
                <p style="color: var(--cor-texto-sub); font-size: 14px; line-height: 1.6;">
                    Defina abaixo a sua <strong>Moeda Principal</strong> (na qual o estoque e os relatórios fiscais são totalizados) e selecione as
                    <strong>Moedas Secundárias</strong> ativas no estabelecimento. O sistema fará a conversão automática nas vendas e caixas.
                </p>
            </div>

            <div class="form-grid" style="margin-bottom: 32px;">
                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_moedasConfig.permitir_pagamento_multiplo" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <span style="font-size: 14px; font-weight: bold; color: #fff; display: block;">Permitir Pagamento em Múltiplas Moedas</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Permite receber parte do valor em Real e parte em Dólar/Guarani numa mesma venda.</span>
                    </div>
                </div>
                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_moedasConfig.permitir_troco_diferente" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <span style="font-size: 14px; font-weight: bold; color: #fff; display: block;">Permitir Troco em Moeda Diferente</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Permite devolver o troco em Real mesmo que a moeda principal de pagamento tenha sido Dólar.</span>
                    </div>
                </div>
            </div>

            <h4 style="color: #fff; margin-bottom: 16px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 8px;">Moedas Habilitadas</h4>
            <div class="tabela-container">
                <table class="tabela-premium">
                    <thead>
                        <tr>
                            <th>Habilitar</th>
                            <th>Código</th>
                            <th>Nome da Moeda</th>
                            <th>Símbolo</th>
                            <th>Tipo / Função</th>
                            <th>Ordem Exibição</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _moedasDisponiveis)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" checked="@EstaMoedaHabilitada(m.moeda_id)" 
                                           @onchange="(e) => ToggleMoeda(m, e)" 
                                           disabled="@(m.tipo_moeda == "PRINCIPAL")" 
                                           style="width: 18px; height: 18px;" />
                                </td>
                                <td style="font-weight: bold; color: var(--primaria);">@m.codigo</td>
                                <td>@m.nome</td>
                                <td style="font-weight: bold;">@m.simbolo</td>
                                <td>
                                    <select class="form-control" style="padding: 6px 12px; font-size: 13px;"
                                            value="@m.tipo_moeda"
                                            @onchange="(e) => AlterarTipoMoeda(m, e)">
                                        <option value="PRINCIPAL">PRINCIPAL</option>
                                        <option value="SECUNDARIA">SECUNDÁRIA</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="number" class="form-control" style="width: 80px; padding: 6px 12px;" 
                                           @bind="m.ordem_exibicao" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- ABA 4: Cotações do Dia -->
        @if (_abaAtiva == 4)
        {
            <h3 style="color: #fff; margin-bottom: 24px;">Bloco 4: Taxas de Câmbio / Cotações do Dia</h3>
            
            <div class="form-grid" style="margin-bottom: 32px; background: rgba(255,255,255,0.02); padding: 24px; border-radius: 12px; border: 1px solid var(--cor-borda);">
                <div class="form-grupo col-12" style="grid-column: span 12; margin-bottom: 12px;">
                    <h4 style="color: var(--primaria);">Lançar Nova Taxa Diária</h4>
                    <p style="color: var(--cor-texto-sub); font-size: 13px;">As taxas são usadas para conversão no PDV offline-first.</p>
                </div>

                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Moeda Origem</label>
                    <select class="form-control" @bind="_novaCotacao.moeda_origem_codigo">
                        <option value="USD">USD - Dólar Americano</option>
                        <option value="BRL">BRL - Real Brasileiro</option>
                        <option value="PYG">PYG - Guarani Paraguaio</option>
                    </select>
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Moeda Destino (Converter Para)</label>
                    <select class="form-control" @bind="_novaCotacao.moeda_destino_codigo">
                        <option value="BRL">BRL - Real Brasileiro</option>
                        <option value="PYG">PYG - Guarani Paraguaio</option>
                        <option value="USD">USD - Dólar Americano</option>
                    </select>
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Taxa Direta (Multiplicador)</label>
                    <input type="number" step="any" class="form-control" 
                           value="@_novaCotacao.taxa_direta" 
                           @oninput="OnTaxaDiretaChanged" 
                           placeholder="Ex: 5.25" />
                </div>
                <div class="form-grupo col-3" style="grid-column: span 3;">
                    <label>Taxa Inversa (Calculada)</label>
                    <input type="text" class="form-control" value="@_taxaInversaCalculada" disabled style="background: rgba(0,0,0,0.2);" />
                </div>

                <div class="form-grupo col-8" style="grid-column: span 8; margin-top: 16px;">
                    <label>Observação / Fonte da Taxa</label>
                    <input type="text" class="form-control" @bind="_novaCotacao.observacao" placeholder="Ex: Cotação Banco Central Paraguai - BCP" />
                </div>

                <div class="form-grupo col-4" style="grid-column: span 4; margin-top: 32px; display: flex; justify-content: flex-end;">
                    <button class="btn-premium" @onclick="GravarCotacao" style="width: 100%; box-shadow: none;">
                        ⚡ Inserir Taxa Oficial
                    </button>
                </div>
            </div>

            <h4 style="color: #fff; margin-bottom: 16px;">Histórico das Últimas Taxas Operacionais</h4>
            <div class="tabela-container">
                <table class="tabela-premium">
                    <thead>
                        <tr>
                            <th>Data Cotação</th>
                            <th>De / Origem</th>
                            <th>Para / Destino</th>
                            <th>Taxa Direta</th>
                            <th>Taxa Inversa</th>
                            <th>Status</th>
                            <th>Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_cotacoes.Count == 0)
                        {
                            <tr>
                                <td colspan="7" style="text-align: center; color: var(--cor-texto-disabled);">Nenhuma cotação manual lançada ainda para hoje.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var c in _cotacoes)
                            {
                                <tr>
                                    <td>@c.data_cotacao.ToString("dd/MM/yyyy")</td>
                                    <td style="font-weight: bold; color: var(--primaria);">@c.moeda_origem_codigo</td>
                                    <td style="font-weight: bold; color: var(--primaria);">@c.moeda_destino_codigo</td>
                                    <td style="font-weight: bold; color: #fff;">@c.taxa_direta</td>
                                    <td style="color: var(--cor-texto-sub);">@c.taxa_inversa</td>
                                    <td>
                                        <span class="tag-badge" style="background: @(c.status == "ATIVA" ? "rgba(56, 239, 125, 0.15)" : "rgba(255, 255, 255, 0.05)"); color: @(c.status == "ATIVA" ? "#38ef7d" : "var(--cor-texto-sub)")">
                                            @c.status
                                        </span>
                                    </td>
                                    <td>
                                        @if (c.status == "ATIVA")
                                        {
                                            <button class="btn-secundario" style="padding: 6px 12px; font-size: 11px;" @onclick="() => CancelarCotacao(c.id)">
                                                Cancelar
                                            </button>
                                        }
                                        else
                                        {
                                            <span style="color: var(--cor-texto-disabled); font-size: 11px;">Inalterável</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- ABA 5: Regime Tributário -->
        @if (_abaAtiva == 5)
        {
            <h3 style="color: #fff; margin-bottom: 24px;">Bloco 5: Regime Tributário & Fiscal Base</h3>
            
            <div class="form-grid">
                <div class="form-grupo col-6" style="grid-column: span 6;">
                    <h4 style="color: #fff; border-bottom: 1px solid var(--cor-borda); padding-bottom: 8px; margin-bottom: 16px;">Brasil (NF-e/NFC-e)</h4>
                    
                    <div class="form-grupo" style="margin-bottom: 16px;">
                        <label>Regime de Tributação (CRT)</label>
                        <select class="form-control" @bind="_fiscal.brasil.regime_tributario">
                            <option value="SIMPLES_NACIONAL">1 - Simples Nacional</option>
