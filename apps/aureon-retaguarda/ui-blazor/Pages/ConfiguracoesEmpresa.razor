                    </label>
                    <div>
                        <span style="font-weight: bold; color: #fff; display: block;">Exigir Supervisor para Descontos</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Solicita autenticação de perfil Supervisor ao aplicar descontos acima de 10%.</span>
                    </div>
                </div>

                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px; margin-top: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_param.exigir_supervisor_cancelamento" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <span style="font-weight: bold; color: #fff; display: block;">Exigir Supervisor para Cancelar Itens/Vendas</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Previne fraudes exigindo senha de gerente/supervisor para remover produtos do carrinho.</span>
                    </div>
