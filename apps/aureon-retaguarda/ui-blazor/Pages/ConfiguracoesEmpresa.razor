                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_param.permitir_desconto_pdv" />
                        <span class="slider"></span>
                    </label>
                    <div>
                        <span style="font-weight: bold; color: #fff; display: block;">Habilitar Desconto nos Itens</span>
                        <span style="font-size: 12px; color: var(--cor-texto-sub);">Habilita o botão de desconto em percentual ou valor no PDV.</span>
                    </div>
                </div>

                <div class="form-grupo col-6" style="grid-column: span 6; display: flex; flex-direction: row; align-items: center; gap: 16px; margin-top: 16px;">
                    <label class="toggle-switch">
                        <input type="checkbox" @bind="_param.exigir_supervisor_desconto" />
