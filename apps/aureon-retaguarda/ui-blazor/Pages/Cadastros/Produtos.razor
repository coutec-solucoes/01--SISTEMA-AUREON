@page "/cadastros/produtos"

@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Produtos — Aureon Gestor</PageTitle>

<div class="header-pagina fade-in">
    <div>
        <h1 class="titulo-pagina">Catálogo de Produtos</h1>
        <p class="subtitulo-pagina">Gerencie seu catálogo completo, incluindo balança, combos, adicionais e controle de pizzas.</p>
    </div>
    <button class="btn btn-primary" @onclick="AbrirModalNovo">
        <span>+</span> Cadastrar Produto
    </button>
</div>

<!-- Componente de Submenu Compartilhado -->
<SubmenuProdutos />

<!-- Barra de Filtros Premium -->
<div class="card-glass fade-in" style="padding: 20px; margin-bottom: 24px;">
    <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: center;">
        <div style="flex: 1; min-width: 250px;">
            <input type="text" class="form-control" @bind-value="buscaTexto" @bind-value:event="oninput" placeholder="Buscar por descrição, referência ou código de barras..." style="width: 100%;" />
        </div>
        
        <div style="width: 200px;">
            <select class="form-control" @bind="grupoFiltro" style="width: 100%;">
                <option value="">Todos os Grupos</option>
                @foreach (var g in grupos)
                {
                    <option value="@g.id">@g.nome_grupo</option>
                }
            </select>
        </div>

        <div style="width: 160px;">
            <select class="form-control" @bind="statusFiltro" style="width: 100%;">
                <option value="ATIVOS">Somente Ativos</option>
                <option value="INATIVOS">Somente Inativos</option>
                <option value="TODOS">Todos</option>
            </select>
        </div>
    </div>
</div>

@if (carregando)
{
    <div class="loading-state fade-in">Carregando catálogo de produtos...</div>
}
else if (!string.IsNullOrEmpty(erroGeral))
{
    <div class="alert-error-box">@erroGeral</div>
}
else
{
    <div class="card-glass fade-in" style="overflow-x: auto; padding: 0;">
        <table class="table">
            <thead>
                <tr>
                    <th>Ref / Cód. Barras</th>
                    <th>Descrição</th>
                    <th>Grupo / Subgrupo</th>
                    <th>Preço de Venda</th>
                    <th>Estoque</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in ProdutosFiltrados)
                {
                    <tr>
                        <td style="font-size: 12px; color: var(--cor-texto-sub);">
                            <div>Ref: @(p.referencia ?? "-")</div>
                            <div style="font-family: monospace; color: var(--cor-texto-disabled);">@(p.codigo_barras ?? "-")</div>
                        </td>
                        <td style="font-weight: 600; color: #fff;">
                            <div>@p.descricao</div>
                            <div style="display: flex; gap: 4px; margin-top: 4px;">
                                @if (p.produto_pizza) { <span class="badge badge-pizza">Pizza</span> }
                                @if (p.produto_combo) { <span class="badge badge-combo">Combo</span> }
                                @if (p.permite_adicionais) { <span class="badge badge-adicional">Adicionais</span> }
                            </div>
                        </td>
                        <td>
                            <div>@(ObterNomeGrupo(p.grupo_id))</div>
                            <span style="font-size: 11px; color: var(--cor-texto-sub);">@(ObterNomeSubgrupo(p.subgrupo_id))</span>
                        </td>
                        <td style="font-weight: bold; color: var(--cor-primaria);">
                            @p.preco_venda.ToString("C2")
                        </td>
                        <td>
                            @if (p.controla_estoque)
                            {
                                <span style='color: @(p.estoque_atual_base <= p.estoque_minimo ? "var(--cor-erro)" : "#38ef7d")'>
                                    @p.estoque_atual_base.ToString("N3")
                                </span>
                            }
                            else
                            {
                                <span style="color: var(--cor-texto-disabled);">Sem contr.</span>
                            }
                        </td>
                        <td>
                            @if (p.ativo)
                            {
                                <span class="badge badge-success">Ativo</span>
                            }
                            else
                            {
                                <span class="badge badge-error">Inativo</span>
                            }
                        </td>
                        <td>
                            <div style="display: flex; gap: 8px;">
                                <button class="btn btn-sm btn-outline" @onclick="() => AbrirModalEditar(p.id)">Editar</button>
                                @if (p.ativo)
                                {
                                    <button class="btn btn-sm btn-outline btn-perigo-outline" @onclick="() => InativarProduto(p.id)">Inativar</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!ProdutosFiltrados.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: var(--cor-texto-sub); padding: 48px;">
                            Nenhum produto cadastrado com os filtros atuais.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal de Cadastro / Edição Principal com 10 Abas -->
@if (mostrarModal)
{
    <div class="modal-backdrop fade-in">
        <div class="modal-content card-glass" style="max-width: 900px; width: 95%; max-height: 90vh; overflow-y: auto;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; border-bottom: 1px solid var(--cor-borda); padding-bottom: 16px;">
                <h2 class="modal-title" style="margin: 0; color: #fff;">
                    @(editandoId == Guid.Empty ? "Cadastrar Novo Produto" : "Editar Produto")
                </h2>
                <button style="background: none; border: none; color: var(--cor-texto-sub); font-size: 20px; cursor: pointer;" @onclick="FecharModal">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(erroModal))
            {
                <div class="alert-error-box" style="margin-bottom: 20px;">@erroModal</div>
            }
            @if (!string.IsNullOrEmpty(sucessoModal))
            {
                <div class="alert-success-box" style="margin-bottom: 20px;">@sucessoModal</div>
            }

            <!-- Navegação de 10 Abas do Modal -->
            <div class="abas-container" style="margin-bottom: 24px; display: flex; flex-wrap: wrap; gap: 4px;">
                <button class="aba-botao @(abaAtiva == "GERAL" ? "ativa" : "")" @onclick='() => SetAba("GERAL")'>Gerais</button>
                <button class="aba-botao @(abaAtiva == "PRECOS" ? "ativa" : "")" @onclick='() => SetAba("PRECOS")'>Preços</button>
                <button class="aba-botao @(abaAtiva == "ESTOQUE" ? "ativa" : "")" @onclick='() => SetAba("ESTOQUE")'>Estoque</button>
                <button class="aba-botao @(abaAtiva == "FISCAL" ? "ativa" : "")" @onclick='() => SetAba("FISCAL")'>Fiscal</button>
                <button class="aba-botao @(abaAtiva == "BALANCA" ? "ativa" : "")" @onclick='() => SetAba("BALANCA")'>Balança</button>
                
                @if (model.produto_pizza)
                {
                    <button class="aba-botao @(abaAtiva == "PIZZA" ? "ativa" : "")" @onclick='() => SetAba("PIZZA")' style="border-color: #00c6ff;">🍕 Pizza</button>
                }
                @if (model.produto_combo)
                {
                    <button class="aba-botao @(abaAtiva == "COMBO" ? "ativa" : "")" @onclick='() => SetAba("COMBO")' style="border-color: #a855f7;">🍔 Combo</button>
                }
                @if (model.permite_adicionais)
                {
                    <button class="aba-botao @(abaAtiva == "ADICIONAIS" ? "ativa" : "")" @onclick='() => SetAba("ADICIONAIS")' style="border-color: #38ef7d;">➕ Adicionais</button>
                }
                
                <button class="aba-botao @(abaAtiva == "PRODUCAO" ? "ativa" : "")" @onclick='() => SetAba("PRODUCAO")'>Produção</button>
                
                @if (editandoId != Guid.Empty)
                {
                    <button class="aba-botao @(abaAtiva == "HISTORICO" ? "ativa" : "")" @onclick='() => SetAba("HISTORICO")'>📈 Histórico</button>
                }
            </div>

            <div class="modal-body-scroll">
                
                <!-- ABA 1: DADOS GERAIS -->
                @if (abaAtiva == "GERAL")
                {
                    <div class="form-grid fade-in">
                        <div class="form-grupo" style="grid-column: span 8;">
                            <label>Descrição / Nome do Produto *</label>
                            <input type="text" class="form-control" @bind="model.descricao" placeholder="Ex: Coca Cola 2L, Pizza Margherita..." />
                        </div>
                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Referência Interna</label>
                            <input type="text" class="form-control" @bind="model.referencia" placeholder="Ref. única..." />
                        </div>

                        <div class="form-grupo" style="grid-column: span 6;">
                            <label>Código de Barras (EAN)</label>
                            <input type="text" class="form-control" @bind="model.codigo_barras" placeholder="Cód. barras..." />
                        </div>
                        <div class="form-grupo" style="grid-column: span 3;">
                            <label>Unidade de Medida</label>
                            <select class="form-control" @bind="model.unidade_medida">
                                <option value="UN">Unidade (UN)</option>
                                <option value="KG">Quilo (KG)</option>
                                <option value="LT">Litro (LT)</option>
                                <option value="PCT">Pacote (PCT)</option>
                                <option value="CX">Caixa (CX)</option>
                            </select>
                        </div>
                        <div class="form-grupo" style="grid-column: span 3; justify-content: center; display: flex; flex-direction: column;">
                            <label class="checkbox-premium">
                                <input type="checkbox" @bind="model.ativo" />
                                <span>Produto Ativo</span>
                            </label>
                        </div>

                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Grupo *</label>
                            <select class="form-control" @bind="model.grupo_id" @bind:after="CarregarSubgruposDoGrupo">
                                <option value="">Selecione...</option>
                                @foreach (var g in grupos)
                                {
                                    <option value="@g.id">@g.nome_grupo</option>
                                }
                            </select>
                        </div>
                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Subgrupo</label>
                            <select class="form-control" @bind="model.subgrupo_id">
                                <option value="">Selecione...</option>
                                @foreach (var s in subgruposFiltradosModal)
                                {
                                    <option value="@s.id">@s.nome_subgrupo</option>
                                }
                            </select>
                        </div>
                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Marca</label>
                            <select class="form-control" @bind="model.marca_id">
                                <option value="">Selecione...</option>
                                @foreach (var m in marcas)
                                {
                                    <option value="@m.id">@m.nome_marca</option>
                                }
                            </select>
                        </div>

                        <!-- FLAGS DE MODOS ESPECIAIS -->
                        <div class="form-grupo" style="grid-column: span 12; margin-top: 12px; border-top: 1px solid var(--cor-borda); padding-top: 16px;">
                            <label style="margin-bottom: 12px; display: block; font-weight: bold; color: var(--cor-primaria);">Configurações Especiais do Produto</label>
                            <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px;">
                                <label class="checkbox-premium">
                                    <input type="checkbox" @bind="model.produto_pizza" />
                                    <span>🍕 É Sabor de Pizza</span>
                                </label>
                                <label class="checkbox-premium">
                                    <input type="checkbox" @bind="model.produto_combo" />
                                    <span>🍔 É um Combo</span>
                                </label>
                                <label class="checkbox-premium">
                                    <input type="checkbox" @bind="model.permite_adicionais" />
                                    <span>➕ Permite Adicionais</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-grupo" style="grid-column: span 12;">
                            <label>Descrição Detalhada / Composição</label>
                            <textarea class="form-control" @bind="model.descricao_detalhada" rows="3" placeholder="Informações de ingredientes, especificações..."></textarea>
                        </div>
                    </div>
                }

                <!-- ABA 2: PREÇOS -->
                else if (abaAtiva == "PRECOS")
                {
                    <div class="form-grid fade-in">
                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Preço de Custo *</label>
                            <input type="number" class="form-control" @bind="model.preco_custo" @bind:after="RecalcularPorCusto" min="0" step="0.01" />
                        </div>
                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Margem de Lucro (%)</label>
                            <input type="number" class="form-control" @bind="model.margem_lucro" @bind:after="RecalcularPorMargem" min="0" step="0.01" />
                        </div>
                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Preço de Venda *</label>
                            <input type="number" class="form-control" @bind="model.preco_venda" @bind:after="RecalcularPorVenda" min="0" step="0.01" />
                        </div>
                        <div class="form-grupo" style="grid-column: span 4;">
                            <label>Desconto Máximo Permitido (%)</label>
                            <input type="number" class="form-control" @bind="model.desconto_maximo_permitido" min="0" max="100" step="0.01" />
                        </div>
                    </div>
                }

                <!-- ABA 3: ESTOQUE BASE -->
                else if (abaAtiva == "ESTOQUE")
                {
                    <div class="form-grid fade-in">
                        <div class="form-grupo" style="grid-column: span 6; justify-content: center; display: flex; flex-direction: column;">
                            <label class="checkbox-premium">
                                <input type="checkbox" @bind="model.controla_estoque" />
                                <span>Controla Estoque</span>
                            </label>
                        </div>
                        <div class="form-grupo" style="grid-column: span 6; justify-content: center; display: flex; flex-direction: column;">
                            <label class="checkbox-premium">
                                <input type="checkbox" @bind="model.controla_validade" />
                                <span>Controla Validade</span>
                            </label>
                        </div>

                        @if (model.controla_estoque)
                        {
                            <div class="form-grupo" style="grid-column: span 6;">
                                <label>Estoque Atual Base</label>
                                <input type="number" class="form-control" @bind="model.estoque_atual_base" step="0.001" />
                            </div>
                            <div class="form-grupo" style="grid-column: span 6;">
                                <label>Estoque Mínimo *</label>
                                <input type="number" class="form-control" @bind="model.estoque_minimo" min="0" step="0.001" />
                            </div>
                        }
                    </div>
                }

                <!-- ABA 4: FISCAL -->
                else if (abaAtiva == "FISCAL")
                {
                    <div class="form-grid fade-in">
                        <div class="form-grupo" style="grid-column: span 6;">
                            <label>NCM (Classificação Fiscal)</label>
                            <input type="text" class="form-control" @bind="model.fiscal_ncm" placeholder="Ex: 2202.10.00..." />
                        </div>
                        <div class="form-grupo" style="grid-column: span 6;">
                            <label>CEST</label>
                            <input type="text" class="form-control" @bind="model.fiscal_cest" placeholder="Ex: 03.010.00..." />
                        </div>

                        <div class="form-grupo" style="grid-column: span 6;">
                            <label>CFOP Padrão</label>
                            <input type="text" class="form-control" @bind="model.fiscal_cfop_padrao" placeholder="Ex: 5102..." />
                        </div>
                        <div class="form-grupo" style="grid-column: span 6;">
                            <label>Origem da Mercadoria</label>
                            <select class="form-control" @bind="model.fiscal_origem_mercadoria">
                                <option value="0">0 - Nacional</option>
                                <option value="1">1 - Estrangeira - Importação Direta</option>
                                <option value="2">2 - Estrangeira - Adquirida no Mercado Interno</option>
                            </select>
                        </div>
                    </div>
                }

                <!-- ABA 5: BALANÇA -->
                else if (abaAtiva == "BALANCA")
                {
                    <div class="form-grid fade-in">
                        <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                            <label class="checkbox-premium">
                                <input type="checkbox" @bind="model.produto_balanca" />
                                <span>Produto de Balança</span>
                            </label>
                        </div>
                        <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                            <label class="checkbox-premium">
                                <input type="checkbox" @bind="model.reconfirmacao_pesagem" />
                                <span>Reconfirmação de Pesagem</span>
                            </label>
                        </div>
                        <div class="form-grupo" style="grid-column: span 4; justify-content: center; display: flex; flex-direction: column;">
                            <label class="checkbox-premium">
                                <input type="checkbox" @bind="model.leitura_etiqueta" />
                                <span>Leitura de Etiqueta</span>
                            </label>
                        </div>
                    </div>
                }

                <!-- ABA 6: PIZZA (APENAS SE SABOR DE PIZZA FOR ATIVO) -->
                else if (abaAtiva == "PIZZA" && model.produto_pizza)
                {
                    <div class="fade-in">
                        <h3 style="color: #00c6ff; font-size: 15px; margin-bottom: 16px;">Vincular Preços de Sabor por Tamanho de Pizza</h3>
                        <div class="alert-error-box" style="margin-bottom: 16px; font-size: 13px;">
                            ℹ️ Defina o preço de venda para cada tamanho de pizza que utiliza este sabor.
                        </div>
                        <table class="table" style="background: rgba(255,255,255,0.01);">
                            <thead>
                                <tr>
                                    <th>Sabor</th>
                                    <th>Tamanho da Pizza</th>
                                    <th>Preço de Venda</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var saborId in listSaboresDisponiveis)
                                {
                                    @foreach (var tam in listTamanhosPizza)
                                    {
                                        var item = ObterOuCriarSaborPreco(saborId, tam);
                                        <tr>
                                            <td>@(ObterNomeSabor(saborId))</td>
                                            <td><span class="badge" style="background: rgba(0,198,255,0.1); color: #00c6ff;">@tam</span></td>
                                            <td>
                                                <input type="number" class="form-control" @bind="item.preco_venda" style="max-width: 150px;" min="0" step="0.01" />
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <!-- ABA 7: COMBO (APENAS SE PRODUTO COMBO FOR ATIVO) -->
                else if (abaAtiva == "COMBO" && model.produto_combo)
                {
                    <div class="fade-in">
                        <h3 style="color: #a855f7; font-size: 15px; margin-bottom: 16px;">Componentes do Combo</h3>
                        <div style="display: flex; gap: 8px; margin-bottom: 16px; align-items: flex-end;">
                            <div style="flex: 2;">
                                <label style="font-size: 12px; margin-bottom: 4px; display:block;">Produto Vinculado</label>
                                <select class="form-control" @bind="novoComboItemProdId">
                                    <option value="">Selecione...</option>
                                    @foreach (var p in todosProdutosCadastrados)
                                    {
                                        @if (p.id != editandoId)
                                        {
                                            <option value="@p.id">@p.descricao</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div style="flex: 1;">
                                <label style="font-size: 12px; margin-bottom: 4px; display:block;">Quantidade</label>
                                <input type="number" class="form-control" @bind="novoComboItemQtd" min="1" />
                            </div>
                            <div style="flex: 1;">
                                <label style="font-size: 12px; margin-bottom: 4px; display:block;">Preço Adic.</label>
                                <input type="number" class="form-control" @bind="novoComboItemPreco" min="0" step="0.01" />
                            </div>
                            <button class="btn btn-primary" type="button" @onclick="AdicionarComboItem">Adicionar</button>
                        </div>

                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Produto Componente</th>
                                    <th>Quantidade</th>
                                    <th>Preço Adicional</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ci in model.combo_itens)
                                {
                                    <tr>
                                        <td>@ObterNomeProdutoCadastrado(ci.produto_vinculado_id)</td>
                                        <td>@ci.quantidade.ToString("N0")</td>
                                        <td>@ci.preco_adicional.ToString("C2")</td>
                                        <td>
                                            <button class="btn btn-sm btn-outline btn-perigo-outline" type="button" @onclick="() => RemoverComboItem(ci.produto_vinculado_id)">Remover</button>
                                        </td>
                                    </tr>
                                }
                                @if (!model.combo_itens.Any())
                                {
                                    <tr><td colspan="4" style="text-align: center; color: var(--cor-texto-sub); padding: 24px;">Nenhum produto adicionado ao combo ainda.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <!-- ABA 8: ADICIONAIS (APENAS SE PERMITE ADICIONAIS FOR ATIVO) -->
                else if (abaAtiva == "ADICIONAIS" && model.permite_adicionais)
                {
                    <div class="fade-in">
                        <h3 style="color: #38ef7d; font-size: 15px; margin-bottom: 16px;">Vincular Adicionais Permitidos</h3>
                        <div style="display: flex; gap: 8px; margin-bottom: 16px; align-items: flex-end;">
                            <div style="flex: 2;">
                                <label style="font-size: 12px; margin-bottom: 4px; display:block;">Adicional Disponível</label>
                                <select class="form-control" @bind="novoAdicionalId">
                                    <option value="">Selecione...</option>
                                    @foreach (var ad in adicionaisCadastrados)
                                    {
                                        <option value="@ad.id">@ad.nome_adicional (@ad.preco_venda.ToString("C2"))</option>
                                    }
                                </select>
                            </div>
                            <div style="flex: 1;">
                                <label style="font-size: 12px; margin-bottom: 4px; display:block;">Preço Diferenciado (Opcional)</label>
                                <input type="number" class="form-control" @bind="novoAdicionalPreco" min="0" step="0.01" placeholder="Usar padrão..." />
                            </div>
                            <button class="btn btn-primary" type="button" @onclick="AdicionarAdicionalVinculo">Vincular</button>
                        </div>

                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Nome do Adicional</th>
                                    <th>Preço Diferenciado</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ad in model.adicionais)
                                {
                                    <tr>
                                        <td>@ObterNomeAdicionalCadastrado(ad.adicional_id)</td>
                                        <td>
                                            @if (ad.preco_venda_diferenciado.HasValue)
                                            {
                                                @ad.preco_venda_diferenciado.Value.ToString("C2")
                                            }
                                            else
                                            {
                                                <span style="color: var(--cor-texto-disabled);">Padrão</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline btn-perigo-outline" type="button" @onclick="() => RemoverAdicionalVinculo(ad.adicional_id)">Remover</button>
                                        </td>
                                    </tr>
                                }
                                @if (!model.adicionais.Any())
                                {
                                    <tr><td colspan="3" style="text-align: center; color: var(--cor-texto-sub); padding: 24px;">Nenhum adicional vinculado.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                <!-- ABA 9: PRODUÇÃO -->
                else if (abaAtiva == "PRODUCAO")
                {
                    <div class="form-grid fade-in">
                        <div class="form-grupo" style="grid-column: span 12;">
                            <label>Local de Produção / Impressora Física</label>
                            <select class="form-control" @bind="model.local_producao_id">
                                <option value="">Selecione...</option>
                                @foreach (var lp in locaisProducao)
                                {
                                    <option value="@lp.id">@lp.nome_local</option>
                                }
                            </select>
                        </div>
                    </div>
                }

                <!-- ABA 10: HISTÓRICO DE PREÇOS (APENAS EM EDIÇÃO) -->
                else if (abaAtiva == "HISTORICO" && editandoId != Guid.Empty)
                {
                    <div class="fade-in">
                        <h3 style="color: #fff; font-size: 15px; margin-bottom: 16px;">📈 Histórico de Atualizações de Preço</h3>
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Data Alteração</th>
                                    <th>Custo Anterior</th>
                                    <th>Custo Novo</th>
                                    <th>Venda Anterior</th>
                                    <th>Venda Nova</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hist in model.historico_precos)
                                {
                                    <tr>
                                        <td>@hist.data_alteracao.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@hist.preco_custo_anterior.ToString("C2")</td>
                                        <td style="font-weight: bold; color: var(--cor-erro);">@hist.preco_custo_novo.ToString("C2")</td>
                                        <td>@hist.preco_venda_anterior.ToString("C2")</td>
                                        <td style="font-weight: bold; color: #38ef7d;">@hist.preco_venda_novo.ToString("C2")</td>
                                    </tr>
                                }
                                @if (!model.historico_precos.Any())
                                {
                                    <tr><td colspan="5" style="text-align: center; color: var(--cor-texto-sub); padding: 24px;">Nenhuma alteração de preço registrada no histórico.</td></tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>

            <div class="modal-actions" style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 12px; border-top: 1px solid var(--cor-borda); padding-top: 20px;">
                <button class="btn btn-outline" @onclick="FecharModal">Cancelar</button>
                <button class="btn btn-primary" @onclick="Salvar">Salvar Produto</button>
            </div>
        </div>
    </div>
}

<style>
