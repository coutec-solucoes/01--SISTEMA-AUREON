@code {
    private bool carregando = true;
    private string? erroGeral, erroModal, sucessoModal;

    private string buscaTexto = "";
    private string grupoFiltro = "";
    private string statusFiltro = "ATIVOS";

    private List<ProdutoDto> produtos = new();
    private List<GrupoDto> grupos = new();
    private List<SubgrupoDto> subgrupos = new();
    private List<MarcaDto> marcas = new();
    private List<LocalProducaoDto> locaisProducao = new();

    // Dados auxiliares para pizza, combo, adicionais
    private List<SaborPizzaDto> saboresCadastrados = new();
    private List<AdicionalDto> adicionaisCadastrados = new();
    private List<ProdutoDto> todosProdutosCadastrados = new();

    // Estado do Modal
    private bool mostrarModal = false;
    private Guid editandoId = Guid.Empty;
    private string abaAtiva = "GERAL";
    private ProdutoModel model = new();

    // Listas auxiliares do modal
    private List<SubgrupoDto> subgruposFiltradosModal = new();
    private List<string> listTamanhosPizza = new() { "GIGANTE", "GRANDE", "MEDIA", "PEQUENA", "BROTO" };
    private List<Guid> listSaboresDisponiveis = new();

    // Estados do Formulário de Combo/Adicionais
    private Guid? novoComboItemProdId;
    private decimal novoComboItemQtd = 1;
    private decimal novoComboItemPreco = 0;

    private Guid? novoAdicionalId;
    private decimal? novoAdicionalPreco;

    private IEnumerable<ProdutoDto> ProdutosFiltrados
    {
        get
        {
            var res = produtos.AsEnumerable();

            if (!string.IsNullOrEmpty(grupoFiltro))
            {
                var gId = Guid.Parse(grupoFiltro);
                res = res.Where(p => p.grupo_id == gId);
            }

            if (statusFiltro == "ATIVOS")
            {
                res = res.Where(p => p.ativo);
            }
            else if (statusFiltro == "INATIVOS")
            {
                res = res.Where(p => !p.ativo);
            }

            if (!string.IsNullOrEmpty(buscaTexto))
            {
                var t = buscaTexto.ToLower().Trim();
                res = res.Where(p => p.descricao.ToLower().Contains(t) || 
                                     (p.referencia != null && p.referencia.ToLower().Contains(t)) ||
                                     (p.codigo_barras != null && p.codigo_barras.Contains(t)));
            }

            return res;
        }
    }

    protected override async Task OnInitializedAsync() => await CarregarDados();

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var resP = await Http.GetFromJsonAsync<Resposta<List<ProdutoDto>>>("/cadastros/produtos");
            if (resP?.sucesso == true) produtos = resP.dados ?? new();

            var resG = await Http.GetFromJsonAsync<Resposta<List<GrupoDto>>>("/cadastros/produtos/grupos");
            if (resG?.sucesso == true) grupos = resG.dados ?? new();

            var resS = await Http.GetFromJsonAsync<Resposta<List<SubgrupoDto>>>("/cadastros/produtos/subgrupos");
            if (resS?.sucesso == true) subgrupos = resS.dados ?? new();

            var resM = await Http.GetFromJsonAsync<Resposta<List<MarcaDto>>>("/cadastros/produtos/marcas");
            if (resM?.sucesso == true) marcas = resM.dados ?? new();

            var resL = await Http.GetFromJsonAsync<Resposta<List<LocalProducaoDto>>>("/cadastros/produtos/locais-producao");
            if (resL?.sucesso == true) locaisProducao = resL.dados ?? new();

            // Adicionais e Sabores de Pizza
            var resSab = await Http.GetFromJsonAsync<Resposta<List<SaborPizzaDto>>>("/cadastros/produtos/sabores-pizza");
            if (resSab?.sucesso == true) saboresCadastrados = resSab.dados ?? new();

            var resAd = await Http.GetFromJsonAsync<Resposta<List<AdicionalDto>>>("/cadastros/produtos/adicionais");
            if (resAd?.sucesso == true) adicionaisCadastrados = resAd.dados ?? new();

            var resAll = await Http.GetFromJsonAsync<Resposta<List<ProdutoDto>>>("/cadastros/produtos");
            if (resAll?.sucesso == true) todosProdutosCadastrados = resAll.dados ?? new();
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private string ObterNomeGrupo(Guid id) => grupos.FirstOrDefault(g => g.id == id)?.nome_grupo ?? "Sem Grupo";
    private string ObterNomeSubgrupo(Guid? id) => id.HasValue ? (subgrupos.FirstOrDefault(s => s.id == id.Value)?.nome_subgrupo ?? "") : "";

    private string ObterNomeSabor(Guid id) => saboresCadastrados.FirstOrDefault(s => s.id == id)?.nome_sabor ?? "Desconhecido";
    private string ObterNomeProdutoCadastrado(Guid id) => todosProdutosCadastrados.FirstOrDefault(p => p.id == id)?.descricao ?? "Produto Desconhecido";
    private string ObterNomeAdicionalCadastrado(Guid id) => adicionaisCadastrados.FirstOrDefault(a => a.id == id)?.nome_adicional ?? "Adicional Desconhecido";

    private void SetAba(string aba) => abaAtiva = aba;

    private void CarregarSubgruposDoGrupo()
    {
        if (model.grupo_id.HasValue)
        {
            subgruposFiltradosModal = subgrupos.Where(s => s.grupo_id == model.grupo_id.Value).ToList();
        }
        else
        {
            subgruposFiltradosModal.Clear();
        }
        model.subgrupo_id = null;
    }

    // ================================================================
    // RECALCULOS DINÂMICOS DE PREÇOS
    // ================================================================
    private void RecalcularPorCusto()
    {
        if (model.preco_custo >= 0 && model.margem_lucro >= 0)
        {
            model.preco_venda = model.preco_custo * (1 + (model.margem_lucro / 100));
        }
    }

    private void RecalcularPorMargem()
    {
        if (model.preco_custo >= 0 && model.margem_lucro >= 0)
        {
            model.preco_venda = model.preco_custo * (1 + (model.margem_lucro / 100));
        }
    }

    private void RecalcularPorVenda()
    {
        if (model.preco_custo > 0 && model.preco_venda >= 0)
        {
            model.margem_lucro = ((model.preco_venda - model.preco_custo) / model.preco_custo) * 100;
        }
    }

    // ================================================================
    // SABORES E PREÇOS DE PIZZA
    // ================================================================
    private ProdutoSaborPrecoModel ObterOuCriarSaborPreco(Guid saborId, string tamanho)
    {
        var item = model.sabores_precos.FirstOrDefault(sp => sp.sabor_id == saborId && sp.tamanho_pizza == tamanho);
        if (item == null)
        {
            item = new ProdutoSaborPrecoModel { sabor_id = saborId, tamanho_pizza = tamanho, preco_venda = model.preco_venda };
            model.sabores_precos.Add(item);
        }
        return item;
    }

    // ================================================================
    // COMBOS ITENS
    // ================================================================
    private void AdicionarComboItem()
    {
        if (!novoComboItemProdId.HasValue || novoComboItemProdId == Guid.Empty) return;
        if (novoComboItemQtd <= 0) return;

        // Se já existe, remove primeiro
        model.combo_itens.RemoveAll(ci => ci.produto_vinculado_id == novoComboItemProdId.Value);

        model.combo_itens.Add(new ProdutoComboItemModel
        {
            produto_vinculado_id = novoComboItemProdId.Value,
            quantidade = novoComboItemQtd,
            preco_adicional = novoComboItemPreco
        });

        novoComboItemProdId = null;
        novoComboItemQtd = 1;
        novoComboItemPreco = 0;
    }

    private void RemoverComboItem(Guid prodId)
    {
        model.combo_itens.RemoveAll(ci => ci.produto_vinculado_id == prodId);
    }

    // ================================================================
    // ADICIONAIS VINCLADOS
    // ================================================================
    private void AdicionarAdicionalVinculo()
    {
        if (!novoAdicionalId.HasValue || novoAdicionalId == Guid.Empty) return;

        model.adicionais.RemoveAll(a => a.adicional_id == novoAdicionalId.Value);

        model.adicionais.Add(new ProdutoAdicionalVinculoModel
        {
            adicional_id = novoAdicionalId.Value,
            preco_venda_diferenciado = novoAdicionalPreco
        });

        novoAdicionalId = null;
        novoAdicionalPreco = null;
    }

    private void RemoverAdicionalVinculo(Guid adId)
    {
        model.adicionais.RemoveAll(a => a.adicional_id == adId);
    }

    // ================================================================
    // FLUXO DO MODAL
    // ================================================================
    private void AbrirModalNovo()
    {
        editandoId = Guid.Empty;
        model = new ProdutoModel();
        
        // Pega todos sabores cadastrados e deixa disponível
        listSaboresDisponiveis = saboresCadastrados.Where(s => s.ativo).Select(s => s.id).ToList();

        erroModal = null; sucessoModal = null;
        abaAtiva = "GERAL";
        mostrarModal = true;
    }

    private async Task AbrirModalEditar(Guid id)
    {
        editandoId = id; erroModal = null; sucessoModal = null;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<ProdutoDetalheDto>>($"/cadastros/produtos/{id}");
            if (res?.sucesso == true && res.dados != null)
            {
                var d = res.dados;
                model = new ProdutoModel
                {
                    codigo_barras = d.codigo_barras,
                    descricao = d.descricao,
                    descricao_detalhada = d.descricao_detalhada,
                    referencia = d.referencia,
                    grupo_id = d.grupo_id,
                    subgrupo_id = d.subgrupo_id,
                    marca_id = d.marca_id,
                    unidade_medida = d.unidade_medida,
                    preco_custo = d.preco_custo,
                    margem_lucro = d.margem_lucro,
                    preco_venda = d.preco_venda,
                    estoque_atual_base = d.estoque_atual_base,
                    estoque_minimo = d.estoque_minimo,
                    controla_estoque = d.controla_estoque,
                    controla_validade = d.controla_validade,
                    desconto_maximo_permitido = d.desconto_maximo_permitido,
                    fiscal_ncm = d.fiscal_ncm,
                    fiscal_cest = d.fiscal_cest,
                    fiscal_cfop_padrao = d.fiscal_cfop_padrao,
                    fiscal_origem_mercadoria = d.fiscal_origem_mercadoria,
                    local_producao_id = d.local_producao_id,
                    produto_pizza = d.produto_pizza,
                    produto_combo = d.produto_combo,
                    permite_adicionais = d.permite_adicionais,
                    produto_balanca = d.produto_balanca,
                    reconfirmacao_pesagem = d.reconfirmacao_pesagem,
                    leitura_etiqueta = d.leitura_etiqueta,
                    ativo = d.ativo,

                    sabores_precos = d.sabores_precos ?? new(),
                    combo_itens = d.combo_itens ?? new(),
                    adicionais = d.adicionais ?? new(),
                    historico_precos = d.historico_precos ?? new()
                };

                // Carrega subgrupos baseados no grupo atual
                if (model.grupo_id.HasValue)
                {
                    subgruposFiltradosModal = subgrupos.Where(s => s.grupo_id == model.grupo_id.Value).ToList();
                }
                
                listSaboresDisponiveis = saboresCadastrados.Where(s => s.ativo).Select(s => s.id).ToList();

                abaAtiva = "GERAL";
                mostrarModal = true;
            }
            else
            {
                erroGeral = res?.mensagem ?? "Erro ao carregar detalhes do produto.";
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de rede: " + ex.Message;
        }
    }

    private async Task Salvar()
    {
        erroModal = null; sucessoModal = null;
        
        // Validações visuais obrigatórias do Bloco 5
        if (string.IsNullOrWhiteSpace(model.descricao))
        {
            erroModal = "A descrição do produto é obrigatória.";
            abaAtiva = "GERAL";
            return;
        }

        if (!model.grupo_id.HasValue || model.grupo_id.Value == Guid.Empty)
        {
            erroModal = "O grupo do produto é de preenchimento obrigatório.";
            abaAtiva = "GERAL";
            return;
        }

        if (model.preco_custo < 0)
        {
            erroModal = "O preço de custo não pode ser negativo.";
            abaAtiva = "PRECOS";
            return;
        }

        if (model.preco_venda < 0)
        {
            erroModal = "O preço de venda não pode ser negativo.";
            abaAtiva = "PRECOS";
            return;
        }

        if (model.margem_lucro < 0)
        {
            erroModal = "A margem de lucro não pode ser negativa.";
            abaAtiva = "PRECOS";
            return;
        }

        if (model.controla_estoque && model.estoque_minimo < 0)
        {
            erroModal = "O estoque mínimo não pode ser negativo.";
            abaAtiva = "ESTOQUE";
            return;
        }

        if (model.desconto_maximo_permitido < 0 || model.desconto_maximo_permitido > 100)
        {
            erroModal = "O desconto máximo permitido deve estar entre 0% e 100%.";
            abaAtiva = "PRECOS";
            return;
        }

        try
        {
            HttpResponseMessage res;
            if (editandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/cadastros/produtos", model);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/cadastros/produtos/{editandoId}", model);
            }

            if (res.IsSuccessStatusCode)
            {
                sucessoModal = "Produto salvo com sucesso!";
                
                // Limpar campos de documentos confidenciais
                model.codigo_barras = ""; model.referencia = "";

                await Task.Delay(1000);
                mostrarModal = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModal = err?.mensagem ?? "Falha ao salvar as informações do produto.";
            }
        }
        catch (Exception ex)
        {
            erroModal = "Falha crítica na rede: " + ex.Message;
        }
    }

    private async Task InativarProduto(Guid id)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Tem certeza que deseja inativar este produto?");
        if (!confirm) return;

        try
        {
            var res = await Http.PutAsync($"/cadastros/produtos/{id}/inativar", null);
            if (res.IsSuccessStatusCode)
            {
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                await JSRuntime.InvokeVoidAsync("alert", err?.mensagem ?? "Falha ao inativar o produto.");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro ao conectar ao servidor: " + ex.Message);
        }
    }

    private void FecharModal() => mostrarModal = false;

    // ================================================================
    // DTOs & Models locais
    // ================================================================

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class GrupoDto
    {
        public Guid id { get; set; }
        public string nome_grupo { get; set; } = "";
    }

    public class SubgrupoDto
    {
        public Guid id { get; set; }
        public Guid grupo_id { get; set; }
        public string nome_subgrupo { get; set; } = "";
    }

    public class MarcaDto
    {
        public Guid id { get; set; }
        public string nome_marca { get; set; } = "";
    }

    public class LocalProducaoDto
    {
        public Guid id { get; set; }
        public string nome_local { get; set; } = "";
    }

    public class SaborPizzaDto
    {
        public Guid id { get; set; }
        public string nome_sabor { get; set; } = "";
        public bool ativo { get; set; }
    }

    public class AdicionalDto
    {
        public Guid id { get; set; }
        public string nome_adicional { get; set; } = "";
        public decimal preco_venda { get; set; }
    }

    public class ProdutoDto
    {
        public Guid id { get; set; }
        public string? codigo_barras { get; set; }
        public string descricao { get; set; } = "";
        public string? referencia { get; set; }
        public Guid grupo_id { get; set; }
        public Guid? subgrupo_id { get; set; }
        public decimal preco_venda { get; set; }
        public decimal estoque_atual_base { get; set; }
        public decimal estoque_minimo { get; set; }
        public bool controla_estoque { get; set; }
        public bool produto_pizza { get; set; }
        public bool produto_combo { get; set; }
        public bool permite_adicionais { get; set; }
        public bool ativo { get; set; }
    }

    public class ProdutoDetalheDto
    {
        public Guid id { get; set; }
        public string? codigo_barras { get; set; }
        public string descricao { get; set; } = "";
        public string? descricao_detalhada { get; set; }
