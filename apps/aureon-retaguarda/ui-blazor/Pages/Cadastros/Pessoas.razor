@code {
    private bool carregando = true;
    private string? erroGeral, erroModal, sucessoModal;
    
    private string buscaTexto = "";
    private string papelFiltro = "TODOS";
    private string statusFiltro = "ATIVOS";

    private List<PessoaDto> pessoas = new();
    
    private Guid editandoId = Guid.Empty;
    private bool mostrarModal = false;
    private string abaAtiva = "GERAL";
    private PessoaModel model = new();

    // Filtros e busca no Cliente (Offline-First Performance)
    private IEnumerable<PessoaDto> PessoasFiltradas
    {
        get
        {
            var res = pessoas.AsEnumerable();

            if (papelFiltro != "TODOS")
            {
                res = res.Where(p => p.papeis.Contains(papelFiltro));
            }

            if (statusFiltro == "ATIVOS")
            {
                res = res.Where(p => p.ativo);
            }
            else if (statusFiltro == "INATIVOS")
            {
                res = res.Where(p => !p.ativo);
            }

            if (!string.IsNullOrEmpty(buscaTexto))
            {
                var t = buscaTexto.ToLower().Trim();
                res = res.Where(p => p.nome_razao_social.ToLower().Contains(t) || 
                                     (p.nome_fantasia != null && p.nome_fantasia.ToLower().Contains(t)) ||
                                     (p.cpf != null && p.cpf.Contains(t)) ||
                                     (p.cnpj != null && p.cnpj.Contains(t)) ||
                                     (p.ci != null && p.ci.Contains(t)) ||
                                     (p.ruc != null && p.ruc.Contains(t)));
            }

            return res;
        }
    }

    protected override async Task OnInitializedAsync() => await CarregarDados();

    protected override void OnParametersSet()
    {
        var uri = Navigation.Uri.ToLower();
        if (uri.Contains("clientes")) papelFiltro = "CLIENTE";
        else if (uri.Contains("fornecedores")) papelFiltro = "FORNECEDOR";
        else if (uri.Contains("funcionarios")) papelFiltro = "FUNCIONARIO";
        else if (uri.Contains("vendedores")) papelFiltro = "VENDEDOR";
        else if (uri.Contains("entregadores")) papelFiltro = "ENTREGADOR";
        else if (uri.Contains("transportadoras")) papelFiltro = "TRANSPORTADORA";
        else papelFiltro = "TODOS";
    }

    private async Task CarregarDados()
    {
        carregando = true; erroGeral = null;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<List<PessoaDto>>>("/cadastros/pessoas");
            if (res?.sucesso == true)
            {
                pessoas = res.dados ?? new();
            }
            else
            {
                erroGeral = res?.mensagem ?? "Erro desconhecido ao carregar.";
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de conexão: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private void SetAba(string aba) => abaAtiva = aba;

    private void TogglePapel(string papel, object? checkedValue)
    {
        bool marcou = checkedValue is bool b && b;
        if (marcou)
        {
            if (!model.papeis.Contains(papel)) model.papeis.Add(papel);
        }
        else
        {
            model.papeis.Remove(papel);
        }
    }

    private void AbrirModalNovo()
    {
        editandoId = Guid.Empty;
        model = new PessoaModel();
        
        // Se estiver em uma rota de papel pré-definida, adiciona automaticamente o papel
        if (papelFiltro != "TODOS")
        {
            model.papeis.Add(papelFiltro);
        }
        
        erroModal = null; sucessoModal = null;
        abaAtiva = "GERAL";
        mostrarModal = true;
    }

    private async Task AbrirModalEditar(Guid id)
    {
        editandoId = id; erroModal = null; sucessoModal = null;
        try
        {
            var res = await Http.GetFromJsonAsync<Resposta<PessoaDetalheDto>>($"/cadastros/pessoas/{id}");
            if (res?.sucesso == true && res.dados != null)
            {
                var d = res.dados;
                model = new PessoaModel
                {
                    tipo_pessoa = d.tipo_pessoa,
                    nome_razao_social = d.nome_razao_social,
                    nome_fantasia = d.nome_fantasia,
                    cpf = d.cpf,
                    cnpj = d.cnpj,
                    ci = d.ci,
                    ruc = d.ruc,
                    rg = d.rg,
                    inscricao_estadual = d.inscricao_estadual,
                    inscricao_municipal = d.inscricao_municipal,
                    data_nascimento = d.data_nascimento,
                    observacao = d.observacao,
                    papeis = d.papeis,
                    
                    contato = d.contato ?? new ContatoModel(),
                    endereco = d.endereco ?? new EnderecoModel(),
                    cliente_config = d.cliente_config ?? new ClienteConfigModel(),
                    fornecedor_config = d.fornecedor_config ?? new FornecedorConfigModel(),
                    funcionario_config = d.funcionario_config ?? new FuncionarioConfigModel(),
                    vendedor_config = d.vendedor_config ?? new VendedorConfigModel(),
                    entregador_config = d.entregador_config ?? new EntregadorConfigModel(),
                    transportadora_config = d.transportadora_config ?? new TransportadoraConfigModel()
                };
                
                abaAtiva = "GERAL";
                mostrarModal = true;
            }
            else
            {
                erroGeral = res?.mensagem ?? "Erro ao carregar detalhes do registro.";
            }
        }
        catch (Exception ex)
        {
            erroGeral = "Erro de rede: " + ex.Message;
        }
    }

    private async Task Salvar()
    {
        erroModal = null; sucessoModal = null;
        
        // Validações visuais locais
        if (string.IsNullOrWhiteSpace(model.nome_razao_social))
        {
            erroModal = "O Nome ou Razão Social é de preenchimento obrigatório.";
            abaAtiva = "GERAL";
            return;
        }

        if (model.papeis.Count == 0)
        {
            erroModal = "Marque pelo menos um Papel para esta pessoa (ex: Cliente, Fornecedor).";
            abaAtiva = "GERAL";
            return;
        }

        // Validação de email básica
        if (!string.IsNullOrWhiteSpace(model.contato.email) && (!model.contato.email.Contains("@") || !model.contato.email.Contains(".")))
        {
            erroModal = "O e-mail digitado possui formato inválido.";
            abaAtiva = "GERAL";
            return;
        }

        // Validação limite de crédito
        if (model.cliente_config.limite_credito < 0)
        {
            erroModal = "O Limite de Crédito do cliente não pode ser negativo.";
            abaAtiva = "CONFIG_PAPEIS";
            return;
        }

        // Validação comissão vendedor
        if (model.vendedor_config.tipo_comissao == "PERCENTUAL" && (model.vendedor_config.percentual_comissao < 0 || model.vendedor_config.percentual_comissao > 100))
        {
            erroModal = "A comissão do vendedor deve estar entre 0% e 100%.";
            abaAtiva = "CONFIG_PAPEIS";
            return;
        }

        try
        {
            HttpResponseMessage res;
            if (editandoId == Guid.Empty)
            {
                res = await Http.PostAsJsonAsync("/cadastros/pessoas", model);
            }
            else
            {
                res = await Http.PutAsJsonAsync($"/cadastros/pessoas/{editandoId}", model);
            }

            if (res.IsSuccessStatusCode)
            {
                sucessoModal = "Cadastro realizado com sucesso!";
                
                // Limpar campos sensíveis
                model.cpf = ""; model.cnpj = ""; model.ci = ""; model.ruc = "";
                
                await Task.Delay(1000);
                mostrarModal = false;
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                erroModal = err?.mensagem ?? "Erro ao salvar as informações.";
            }
        }
        catch (Exception ex)
        {
            erroModal = "Ocorreu uma falha na requisição: " + ex.Message;
        }
    }

    private async Task InativarPessoa(Guid id)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", "Tem certeza que deseja inativar esta pessoa?");
        if (!confirm) return;

        try
        {
            var res = await Http.PutAsync($"/cadastros/pessoas/{id}/inativar", null);
            if (res.IsSuccessStatusCode)
            {
                await CarregarDados();
            }
            else
            {
                var err = await res.Content.ReadFromJsonAsync<Resposta<object>>();
                await JSRuntime.InvokeVoidAsync("alert", err?.mensagem ?? "Falha ao inativar.");
            }
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Erro de conexão: " + ex.Message);
        }
    }

    private void FecharModal() => mostrarModal = false;

    // ================================================================
    // DTOs & Models locais do Front-End Blazor
    // ================================================================

    public class Resposta<T>
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; } = "";
        public T? dados { get; set; }
    }

    public class PessoaDto
    {
        public Guid id { get; set; }
        public string tipo_pessoa { get; set; } = "FISICA";
        public string nome_razao_social { get; set; } = "";
        public string? nome_fantasia { get; set; }
        public string? cpf { get; set; }
        public string? cnpj { get; set; }
        public string? ci { get; set; }
        public string? ruc { get; set; }
        public bool ativo { get; set; }
        public List<string> papeis { get; set; } = new();
    }

    public class PessoaDetalheDto
    {
        public Guid id { get; set; }
        public string tipo_pessoa { get; set; } = "FISICA";
        public string nome_razao_social { get; set; } = "";
        public string? nome_fantasia { get; set; }
        public string? cpf { get; set; }
        public string? cnpj { get; set; }
        public string? ci { get; set; }
        public string? ruc { get; set; }
        public string? rg { get; set; }
        public string? inscricao_estadual { get; set; }
        public string? inscricao_municipal { get; set; }
        public DateTime? data_nascimento { get; set; }
        public string? observacao { get; set; }
        public bool ativo { get; set; }
        public List<string> papeis { get; set; } = new();
        
        public ContatoModel? contato { get; set; }
        public EnderecoModel? endereco { get; set; }
        public ClienteConfigModel? cliente_config { get; set; }
        public FornecedorConfigModel? fornecedor_config { get; set; }
        public FuncionarioConfigModel? funcionario_config { get; set; }
        public VendedorConfigModel? vendedor_config { get; set; }
        public EntregadorConfigModel? entregador_config { get; set; }
        public TransportadoraConfigModel? transportadora_config { get; set; }
    }

    public class PessoaModel
    {
        public string tipo_pessoa { get; set; } = "FISICA";
        public string nome_razao_social { get; set; } = "";
        public string? nome_fantasia { get; set; }
        public string? cpf { get; set; }
        public string? cnpj { get; set; }
        public string? ci { get; set; }
        public string? ruc { get; set; }
        public string? rg { get; set; }
        public string? inscricao_estadual { get; set; }
        public string? inscricao_municipal { get; set; }
        public DateTime? data_nascimento { get; set; }
        public string? observacao { get; set; }
        public List<string> papeis { get; set; } = new();
        
        public ContatoModel contato { get; set; } = new();
        public EnderecoModel endereco { get; set; } = new();
        public ClienteConfigModel cliente_config { get; set; } = new();
        public FornecedorConfigModel fornecedor_config { get; set; } = new();
        public FuncionarioConfigModel funcionario_config { get; set; } = new();
        public VendedorConfigModel vendedor_config { get; set; } = new();
        public EntregadorConfigModel entregador_config { get; set; } = new();
        public TransportadoraConfigModel transportadora_config { get; set; } = new();
    }

    public class ContatoModel
    {
        public string? telefone_principal { get; set; }
        public string? whatsapp { get; set; }
        public string? telefone_secundario { get; set; }
        public string? email { get; set; }
        public string? site { get; set; }
        public string? responsavel { get; set; }
        public string? observacao { get; set; }
    }

    public class EnderecoModel
    {
        public string tipo_endereco { get; set; } = "PRINCIPAL";
        public string pais { get; set; } = "BR";
        public string? estado_departamento { get; set; }
        public string? cidade { get; set; }
        public string? bairro { get; set; }
        public string? logradouro { get; set; }
        public string? numero { get; set; }
        public string? complemento { get; set; }
        public string? cep_codigo_postal { get; set; }
        public string? referencia { get; set; }
        public bool principal { get; set; } = true;
    }

    public class ClienteConfigModel
    {
        public decimal limite_credito { get; set; } = 0;
        public bool permitir_crediario { get; set; } = false;
        public bool bloquear_venda_prazo { get; set; } = false;
        public string? observacao_credito { get; set; }
        public string status_cliente { get; set; } = "ATIVO";
    }

    public class FornecedorConfigModel
    {
        public int? prazo_pagamento_padrao { get; set; } = 30;
        public string moeda_padrao_compra { get; set; } = "BRL";
        public string? observacao_comercial { get; set; }
        public string status_fornecedor { get; set; } = "ATIVO";
    }

    public class FuncionarioConfigModel
    {
        public string? cargo { get; set; }
        public DateTime? data_admissao { get; set; }
        public DateTime? data_demissao { get; set; }
        public decimal? salario_base { get; set; } = 0;
        public bool ativo_funcionario { get; set; } = true;
        public string? observacao_funcionario { get; set; }
    }

    public class VendedorConfigModel
    {
        public string? codigo_vendedor { get; set; }
        public string tipo_comissao { get; set; } = "SEM_COMISSAO";
        public decimal percentual_comissao { get; set; } = 0;
        public decimal valor_comissao_fixa { get; set; } = 0;
        public bool comissao_ativa { get; set; } = true;
    }

    public class EntregadorConfigModel
    {
        public string? tipo_entregador { get; set; } = "PROPRIO";
        public string? veiculo { get; set; }
        public string? placa { get; set; }
        public bool ativo_entregador { get; set; } = true;
    }

    public class TransportadoraConfigModel
    {
        public string? contato_logistica { get; set; }
        public string? observacao_logistica { get; set; }
        public bool ativa_transportadora { get; set; } = true;
    }
}
