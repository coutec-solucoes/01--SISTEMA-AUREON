@page "/"
@using AureonPdvUi.Services
@using System.ComponentModel.DataAnnotations
@inject TauriService TauriService

<div class="wizard-container">
    <div class="wizard-header">
        <h1>AUREON - Assistente de Instalação</h1>
        <p>Configuração Técnica do Servidor e Banco de Dados</p>
    </div>

    <div class="wizard-steps">
        <div class="step @(currentStep == 1 ? "active" : "") @(currentStep > 1 ? "completed" : "")">1. Banco e Empresa</div>
        <div class="step @(currentStep == 2 ? "active" : "") @(currentStep > 2 ? "completed" : "")">2. Administrador</div>
        <div class="step @(currentStep == 3 ? "active" : "") @(currentStep > 3 ? "completed" : "")">3. Criptografia</div>
        <div class="step @(currentStep == 4 ? "active" : "")">4. Concluir</div>
    </div>

    <div class="wizard-content">
        @if (currentStep == 1)
        {
            <h3>Conexão e Criação do Banco</h3>
            <p>Informe as credenciais do PostgreSQL local e o nome da empresa para criarmos o banco isolado.</p>
            
            <div class="form-group">
                <label>Host</label>
                <input type="text" class="form-control" @bind="host" placeholder="localhost" />
            </div>
            <div class="form-group">
                <label>Porta</label>
                <input type="number" class="form-control" @bind="porta" />
            </div>
            <div class="form-group">
                <label>Usuário Administrador (com permissão CREATEDB)</label>
                <input type="text" class="form-control" @bind="usuario_pg" placeholder="postgres" />
            </div>
            <div class="form-group">
                <label>Senha</label>
                <input type="password" class="form-control" @bind="senha_pg" />
            </div>
            <hr style="margin: 20px 0; border: 0; border-top: 1px solid #eee;" />
            <div class="form-group">
                <label>Nome Fantasia da Empresa</label>
                <input type="text" class="form-control" @bind="nome_empresa" placeholder="Ex: Padaria São João" />
            </div>

            <div class="actions">
                <button class="btn btn-primary" @onclick="TestarECriarBanco" disabled="@isLoading">
                    @if(isLoading) { <span>Processando...</span> } else { <span>Conectar e Criar Banco</span> }
                </button>
            </div>
        }
        else if (currentStep == 2)
        {
            <h3>Administrador Inicial</h3>
            <p>Crie o usuário de acesso Root do AUREON. Guarde esta senha em segurança.</p>
            
            <div class="form-group">
                <label>Nome do Administrador</label>
                <input type="text" class="form-control" @bind="admin_nome" placeholder="Ex: Admin Sistema" />
            </div>
            <div class="form-group">
                <label>E-mail (Login)</label>
                <input type="email" class="form-control" @bind="admin_email" placeholder="admin@empresa.com" />
            </div>
            <div class="form-group">
                <label>Senha de Acesso</label>
                <input type="password" class="form-control" @bind="admin_senha" />
            </div>

            <div class="actions">
                <button class="btn btn-secondary" @onclick="Voltar" disabled="@isLoading">Voltar</button>
                <button class="btn btn-primary" @onclick="AvancarAdmin">Continuar</button>
            </div>
        }
        else if (currentStep == 3)
        {
            <h3>Keystore e Criptografia</h3>
            <p>O sistema vai gerar um cofre local de chaves (AES-256-GCM) para proteger dados sensíveis. O arquivo será criado em <strong>C:/Aureon/config/.keystore</strong>.</p>
            
            <div class="actions">
                <button class="btn btn-secondary" @onclick="Voltar" disabled="@isLoading">Voltar</button>
                <button class="btn btn-primary" @onclick="GerarKeystore" disabled="@isLoading">
                    @if(isLoading) { <span>Gerando...</span> } else { <span>Inicializar Keystore</span> }
                </button>
            </div>
        }
        else if (currentStep == 4)
        {
            <h3>Pronto para Instalar</h3>
            <p>Todas as informações foram coletadas. Clique em Instalar para aplicar a estrutura base (migrations, moedas, perfis) e finalizar o setup.</p>
            
            <div class="actions">
                <button class="btn btn-secondary" @onclick="Voltar" disabled="@isLoading">Voltar</button>
                <button class="btn btn-success" @onclick="FinalizarSetup" disabled="@isLoading">
                    @if(isLoading) { <span>Finalizando...</span> } else { <span>Concluir Instalação</span> }
                </button>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mt-3">@errorMessage</div>
    }
    
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success mt-3">@successMessage</div>
    }
</div>

@code {
    private int currentStep = 1;
    private bool isLoading = false;
    private string errorMessage = "";
    private string successMessage = "";

    // DTO State
    private string host = "localhost";
    private int porta = 5432;
    private string usuario_pg = "postgres";
    private string senha_pg = "";
    private string nome_empresa = "";
    private string admin_nome = "";
    private string admin_email = "";
    private string admin_senha = "";

    private async Task TestarECriarBanco()
    {
        if (string.IsNullOrWhiteSpace(nome_empresa)) {
            errorMessage = "O nome da empresa é obrigatório para criarmos o banco.";
            return;
        }

        errorMessage = "";
        successMessage = "";
        isLoading = true;
        try {
            var dados = new { host = host, porta = porta, usuario = usuario_pg, senha_plana = senha_pg };
            
            // 1. Testa a conexão primária com postgres genérico
            var resTeste = await TauriService.InvocarAsync<RespostaBase>("testar_postgres", new { dados = dados });
            
            if (resTeste != null && resTeste.sucesso) {
                // 2. Se a conexão passou, cria o banco da empresa
                var resCriar = await TauriService.InvocarAsync<RespostaBase>("criar_banco_empresa", new { dados = dados, nomeEmpresa = nome_empresa });
                if (resCriar != null && resCriar.sucesso) {
                    currentStep = 2; // Avança pro admin
                } else {
                    errorMessage = resCriar?.erro?.detalhe ?? "Erro ao criar o banco da empresa.";
                }
            } else {
                errorMessage = resTeste?.erro?.detalhe ?? "Erro de conexão genérico. Verifique usuário e senha.";
            }
        } catch (Exception ex) {
            errorMessage = $"Falha crítica: {ex.Message}";
        } finally {
            isLoading = false;
        }
    }

    private void AvancarAdmin()
    {
        if (string.IsNullOrWhiteSpace(admin_nome) || string.IsNullOrWhiteSpace(admin_email) || string.IsNullOrWhiteSpace(admin_senha)) {
            errorMessage = "Preencha todos os campos do administrador.";
            return;
        }
        errorMessage = "";
        currentStep = 3;
    }

    private async Task GerarKeystore()
    {
        errorMessage = "";
        isLoading = true;
        try {
            var res = await TauriService.InvocarAsync<RespostaBase>("inicializar_keystore", new {});
            if (res != null && res.sucesso) {
                currentStep = 4;
            } else {
                errorMessage = res?.erro?.detalhe ?? "Erro ao criar keystore.";
            }
        } catch (Exception ex) {
            errorMessage = $"Falha crítica: {ex.Message}";
        } finally {
            isLoading = false;
        }
    }

    private async Task FinalizarSetup()
    {
        errorMessage = "";
        successMessage = "";
        isLoading = true;
        try {
            var dbDto = new { host = host, porta = porta, usuario = usuario_pg, senha_plana = senha_pg };
            var payload = new {
                db = dbDto,
                nome_empresa = nome_empresa,
                admin_nome = admin_nome,
                admin_email = admin_email,
                admin_senha_plana = admin_senha
            };
            
            var res = await TauriService.InvocarAsync<RespostaBase>("finalizar_instalacao", new { dados = payload });
            
            if (res != null && res.sucesso) {
                successMessage = "Instalação concluída com sucesso! O PDV já pode ser iniciado.";
                senha_pg = ""; // Limpa memória local
                admin_senha = ""; 
            } else {
                errorMessage = res?.erro?.detalhe ?? "Erro na finalização.";
            }
        } catch (Exception ex) {
            errorMessage = $"Falha crítica: {ex.Message}";
        } finally {
            isLoading = false;
        }
    }

    private void Voltar()
    {
        errorMessage = "";
        successMessage = "";
        if (currentStep > 1) currentStep--;
    }

    public class RespostaBase
    {
        public bool sucesso { get; set; }
        public string mensagem { get; set; }
        public RespostaErro erro { get; set; }
    }

    public class RespostaErro
    {
        public string codigo { get; set; }
        public string detalhe { get; set; }
    }
}
