{
  "productName": "AUREON Config",
  "version": "0.0.1",
  "identifier": "com.aureon.config",
  "build": {
    "frontendDist": "../ui-blazor/bin/Release/net8.0/browser-wasm/AppBundle",
    "devUrl": "http://localhost:5172",
    "beforeDevCommand": "",
    "beforeBuildCommand": "dotnet publish ../ui-blazor/aureon-config-ui.csproj -c Release"
  },
  "app": {
    "windows": [
      {
        "title": "AUREON Config",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; wasm-src 'self' blob:; connect-src 'self' http://localhost:7070"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
